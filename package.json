{
  "name": "music-library",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "node scripts/postbuild.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "db:migrate:local": "wrangler d1 execute music-library --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute music-library --remote --file=./schema.sql",
    "generate:world-map": "node scripts/generate-world-map.mjs",
    "backfill:country-counts": "node scripts/backfill-country-counts.mjs",
    "backfill:country-counts:remote": "node scripts/backfill-country-counts.mjs --remote"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.0.1",
    "arctic": "^3.7.0",
    "astro": "^7.0.3",
    "marked": "^18.0.5",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "wrangler": "^4.100.0"
  }
}
