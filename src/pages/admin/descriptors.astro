---
import Layout from '../../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import { invalidateDescriptorCache } from '../../lib/descriptor-cache';

const user = Astro.locals.user;
if (!user || !user.is_admin) return new Response(null, { status: 403 });

const db = env.DB;
const kv = env.GENRE_CACHE;

// ── POST handlers ─────────────────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const action = Astro.url.searchParams.get('action');
  const data   = await Astro.request.formData();

  if (action === 'add') {
    const name = (data.get('name') as string)?.trim().toLowerCase();
    if (name) {
      await db.prepare(
        'INSERT INTO descriptors (name, is_canonical) VALUES (?, 1) ON CONFLICT(name) DO UPDATE SET is_canonical = 1'
      ).bind(name).run();
    }

  } else if (action === 'promote') {
    const id = parseInt(data.get('id') as string);
    if (id) await db.prepare('UPDATE descriptors SET is_canonical = 1 WHERE id = ?').bind(id).run();

  } else if (action === 'demote') {
    const id = parseInt(data.get('id') as string);
    if (id) await db.prepare('UPDATE descriptors SET is_canonical = 0 WHERE id = ?').bind(id).run();

  } else if (action === 'delete') {
    const id = parseInt(data.get('id') as string);
    if (id) await db.prepare('DELETE FROM descriptors WHERE id = ?').bind(id).run();
  }

  await invalidateDescriptorCache(kv);
  return Astro.redirect('/admin/descriptors');
}

// ── GET ───────────────────────────────────────────────────────────────────────
const { results: canonical } = await db.prepare(
  `SELECT id, name FROM descriptors WHERE is_canonical = 1 ORDER BY name ASC`
).all<{ id: number; name: string }>();

const { results: pending } = await db.prepare(
  `SELECT id, name FROM descriptors WHERE is_canonical = 0 ORDER BY name ASC`
).all<{ id: number; name: string }>();
---

<Layout title="Admin — Descriptors">
  <div class="page-header" slot="header">
    <h1>Admin — Descriptors</h1>
    <div style="display:flex;gap:8px">
      <a href="/admin" class="btn">← Admin</a>
      <a href={`/${user.profile_url}/`} class="btn">My Dashboard</a>
    </div>
  </div>

  <div class="admin-wrap">

    <!-- Add canonical descriptor -->
    <form method="post" action="/admin/descriptors?action=add" class="add-form">
      <input name="name" type="text" placeholder="New descriptor…" required class="admin-input" />
      <button type="submit" class="btn btn-primary">Add</button>
    </form>

    <!-- Canonical list -->
    <section class="desc-section">
      <h2 class="section-heading">Canonical ({canonical.length})</h2>
      <div class="chip-grid">
        {canonical.map(d => (
          <span class="desc-chip">
            <span class="desc-name">{d.name}</span>
            <form method="post" action="/admin/descriptors?action=demote" class="inline-form">
              <input type="hidden" name="id" value={d.id} />
              <button type="submit" class="chip-action" title="Demote">↓</button>
            </form>
            <form method="post" action="/admin/descriptors?action=delete"
                  onsubmit={`return confirm('Delete "${d.name}"?')`} class="inline-form">
              <input type="hidden" name="id" value={d.id} />
              <button type="submit" class="chip-action chip-del" title="Delete">×</button>
            </form>
          </span>
        ))}
      </div>
    </section>

    <!-- Pending (user-entered, not yet canonical) -->
    {pending.length > 0 && (
      <section class="desc-section">
        <h2 class="section-heading">Pending review ({pending.length})</h2>
        <p class="section-hint">User-submitted descriptors not yet in the canonical list.</p>
        <div class="chip-grid">
          {pending.map(d => (
            <span class="desc-chip desc-chip-pending">
              <span class="desc-name">{d.name}</span>
              <form method="post" action="/admin/descriptors?action=promote" class="inline-form">
                <input type="hidden" name="id" value={d.id} />
                <button type="submit" class="chip-action chip-promote" title="Promote to canonical">✓</button>
              </form>
              <form method="post" action="/admin/descriptors?action=delete"
                    onsubmit={`return confirm('Delete "${d.name}"?')`} class="inline-form">
                <input type="hidden" name="id" value={d.id} />
                <button type="submit" class="chip-action chip-del" title="Delete">×</button>
              </form>
            </span>
          ))}
        </div>
      </section>
    )}

  </div>
</Layout>

<style>
.admin-wrap { max-width: 860px; }

.add-form {
  display: flex; gap: 8px; margin-bottom: 28px; align-items: center;
}
.admin-input {
  background: var(--bg); border: 1px solid var(--border); color: var(--text);
  padding: 5px 10px; border-radius: 4px; font-size: 13px; font-family: inherit;
  width: 220px;
}

.desc-section { margin-bottom: 28px; }
.section-heading {
  font-size: 11px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 10px;
}
.section-hint { font-size: 12px; color: var(--text-muted); margin-bottom: 10px; }

.chip-grid { display: flex; flex-wrap: wrap; gap: 6px; }

.desc-chip {
  display: inline-flex; align-items: center; gap: 2px;
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 3px; padding: 3px 4px 3px 9px; font-size: 12px;
}
.desc-chip-pending {
  border-color: var(--text-muted); opacity: 0.7;
}
.desc-name { color: var(--text); margin-right: 2px; }

.inline-form { display: inline; }
.chip-action {
  background: none; border: none; cursor: pointer;
  color: var(--text-muted); font-size: 13px; padding: 0 3px; line-height: 1;
}
.chip-action:hover { color: var(--text); }
.chip-promote:hover { color: var(--color-green, #4caf50); }
.chip-del:hover     { color: var(--color-danger, #e05252); }
</style>
