---
import Layout from '../../layouts/Layout.astro';
import { env } from 'cloudflare:workers';

const user = Astro.locals.user;
if (!user || !user.is_admin) return new Response(null, { status: 403 });

const db = env.DB;

const [
  { results: [{ gc }] },
  { results: [{ sc }] },
  { results: [{ dc }] },
] = await Promise.all([
  db.prepare('SELECT COUNT(*) as gc FROM genres').all<{ gc: number }>(),
  db.prepare('SELECT COUNT(*) as sc FROM subgenres').all<{ sc: number }>(),
  db.prepare('SELECT COUNT(*) as dc FROM descriptors WHERE is_canonical = 1').all<{ dc: number }>(),
]);
---

<Layout title="Admin">
  <div class="page-header" slot="header">
    <h1>Admin</h1>
  </div>

  <div class="hub">
    <a href="/admin/genres" class="hub-card">
      <p class="hub-title">Genres &amp; Subgenres</p>
      <p class="hub-stat">{gc} genre{gc !== 1 ? 's' : ''} · {sc} subgenre{sc !== 1 ? 's' : ''}</p>
    </a>
    <a href="/admin/descriptors" class="hub-card">
      <p class="hub-title">Descriptors</p>
      <p class="hub-stat">{dc} canonical</p>
    </a>
  </div>
</Layout>

<style>
.hub {
  display: flex; flex-wrap: wrap; gap: 16px; margin-top: 8px;
}
.hub-card {
  display: flex; flex-direction: column; gap: 6px;
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 8px; padding: 20px 28px;
  text-decoration: none; color: inherit;
  min-width: 180px;
  transition: border-color 0.15s;
}
.hub-card:hover { border-color: var(--text-muted); }
.hub-title {
  font-size: 14px; font-weight: 600; color: var(--text);
}
.hub-stat {
  font-size: 12px; color: var(--text-muted);
}
</style>
