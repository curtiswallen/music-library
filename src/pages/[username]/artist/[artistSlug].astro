---
import Layout from '../../../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import { slugify, countryCode } from '../../../lib/utils';

const { username, artistSlug } = Astro.params;
if (!username || !artistSlug) return Astro.redirect('/');

const db = env.DB;

const profileUser = await db.prepare(`
  SELECT id, username, display_name, profile_url, is_private
  FROM users WHERE profile_url = ?
`).bind(username).first<{
  id: number; username: string; display_name: string | null;
  profile_url: string; is_private: number;
}>();

if (!profileUser || profileUser.is_private) {
  return new Response(null, { status: 404 });
}

const displayName = profileUser.display_name || profileUser.username;

// Find artist name by matching slugified name
const { results: allArtists } = await db.prepare(`
  SELECT DISTINCT a.artist FROM albums a
  JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ? AND ua.is_hidden = 0
`).bind(profileUser.id).all<{ artist: string }>();

const artistName = allArtists.find(r => slugify(r.artist) === artistSlug)?.artist;
if (!artistName) return new Response(null, { status: 404 });

const { results: albums } = await db.prepare(`
  SELECT a.id, a.slug, a.artist, a.album, a.country, a.year, a.cover_url,
         ua.genre, ua.subgenres, ua.rating, ua.notes, ua.recommended
  FROM albums a
  JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
  WHERE a.artist = ? AND ua.is_hidden = 0
  ORDER BY a.year ASC NULLS LAST
`).bind(profileUser.id, artistName).all<{
  id: number; slug: string; artist: string; album: string; country: string;
  year: number | null; cover_url: string | null;
  genre: string; subgenres: string; rating: number | null; notes: string; recommended: number;
}>();

function ratingClass(r: number | null) {
  if (r == null) return '';
  if (r >= 70) return 'rating-hi';
  if (r >= 50) return 'rating-mid';
  return 'rating-lo';
}
function sortedSubs(subs: string[]) {
  return [...subs].sort((a, b) => a === 'Sketchy' ? -1 : b === 'Sketchy' ? 1 : 0);
}

const firstAlbum = albums[0];
const cc = firstAlbum ? countryCode(firstAlbum.country).toLowerCase() : '';
const base = `/${username}`;
---

<Layout title={`${artistName} — ${displayName}'s Library`}>
  <div class="page-header artist-header">
    <div class="breadcrumb">
      <h1><a href={base}>{displayName}'s Library</a></h1>
      <h1><span class="breadcrumb-sep">›</span></h1>
      <h1><span class="breadcrumb-current">{artistName} {firstAlbum && (
        cc
          ? <span class={`fi fi-${cc} country-flag`} title={firstAlbum.country} />
          : firstAlbum.country && <span style="color:var(--text-muted);font-size:11px">{firstAlbum.country}</span>
      )}</span></h1>
      <span class="count" style="margin-left:4px">({albums.length} album{albums.length !== 1 ? 's' : ''})</span>
    </div>
    {Astro.locals.user
      ? <a href="/" class="btn">← My Library</a>
      : <a href="/auth/login" class="btn">Sign In</a>
    }
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th></th>
          <th>Album</th>
          <th>Year</th>
          <th>Genre</th>
          <th>Subgenres</th>
          <th>Rating</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        {albums.map(a => {
          const subs: string[] = JSON.parse(a.subgenres || '[]');
          return (
            <tr data-href={`/${username}/album/${a.slug}`}>
              <td>
                <div class="cover-thumb" style="background:#000;overflow:hidden">
                  {a.cover_url && (
                    <img src={a.cover_url} alt="" loading="lazy"
                         style="width:100%;height:100%;object-fit:cover;display:block"
                         onerror="this.style.display='none'" />
                  )}
                </div>
              </td>
              <td><a href={`/${username}/album/${a.slug}`}>{a.album} {a.recommended ? <span class="rec-star" title="Recommended"> ★</span> : null}</a></td>
              <td>{a.year ?? ''}</td>
              <td>
                {a.genre && <span class="genre">{a.genre}</span>}
              </td>
              <td>
                {sortedSubs(subs).map(s => (
                  <span class={`tag${s === 'Sketchy' ? ' tag-sketchy' : ''}`}>{s}</span>
                ))}
              </td>
              <td><span class={`rating ${ratingClass(a.rating)}`}>{a.rating ?? '—'}</span></td>
              <td class="notes-cell">
                <span class="notes-text">{a.notes}</span>
                {a.notes && <span class="notes-tip-body">{a.notes}</span>}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
</Layout>

<script>
document.querySelectorAll<HTMLTableRowElement>('tr[data-href]').forEach(tr => {
  tr.addEventListener('click', e => {
    if ((e.target as Element).closest('a')) return;
    window.location.href = tr.dataset.href!;
  });
});
</script>
