---
import Layout from '../../../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import { slugify, countryCode } from '../../../lib/utils';
import { mdInline } from '../../../lib/markdown';
import type { ArtistRow, MembersData } from '../../../lib/artist-cache';

const { username, artist: artistSlug } = Astro.params;
if (!username || !artistSlug) return new Response(null, { status: 404 });

const db = env.DB;

const profileUser = await db.prepare(`
  SELECT id, username, display_name, profile_url, is_private, avatar_url
  FROM users WHERE profile_url = ?
`).bind(username).first<{
  id: number; username: string; display_name: string | null;
  profile_url: string; is_private: number; avatar_url: string | null;
}>();

if (!profileUser) return new Response(null, { status: 404 });

const loggedInUser = Astro.locals.user;
const isOwner      = loggedInUser?.id === profileUser.id;
const displayName  = profileUser.display_name || profileUser.username;

if (profileUser.is_private && !isOwner) return Astro.redirect(`/${username}`);

const hiddenFilter = isOwner ? '' : 'AND ua.is_hidden = 0';

const { results: allArtists } = await db.prepare(`
  SELECT DISTINCT a.artist FROM albums a
  JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
  ${hiddenFilter}
`).bind(profileUser.id).all<{ artist: string }>();

// Resolve slug → individual artist name (handles single artists and split parts)
let artistName: string | undefined;
for (const row of allArtists) {
  const parts = row.artist.split(' / ').map((s: string) => s.trim());
  const match = parts.find(p => slugify(p) === artistSlug);
  if (match) { artistName = match; break; }
}
if (!artistName) return new Response(null, { status: 404 });

const { results: albums } = await db.prepare(`
  SELECT a.id, a.slug, a.artist, a.album, a.country, a.year, a.cover_url, a.artist_mbid, a.release_type,
         ua.genre, ua.subgenres, ua.descriptors, ua.rating, ua.notes, ua.recommended
  FROM albums a
  JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
  WHERE (
    a.artist = ?
    OR a.artist LIKE ? || ' / %'
    OR a.artist LIKE '% / ' || ?
    OR a.artist LIKE '% / ' || ? || ' / %'
  ) ${hiddenFilter}
  ORDER BY a.year ASC NULLS LAST
`).bind(profileUser.id, artistName, artistName, artistName, artistName).all<{
  id: number; slug: string; artist: string; album: string; country: string;
  year: number | null; cover_url: string | null; artist_mbid: string | null; release_type: string | null;
  genre: string; subgenres: string; descriptors: string; rating: number | null; notes: string; recommended: number;
}>();

const artistMbid = albums.find(a => a.artist_mbid)?.artist_mbid ?? null;

const TYPE_ORDER: { type: string | null; label: string }[] = [
  { type: 'lp',          label: 'LP'          },
  { type: 'ep',          label: 'EP'          },
  { type: 'single',      label: 'Single'      },
  { type: 'compilation', label: 'Compilation' },
  { type: 'demo',        label: 'Demo'        },
  { type: null,          label: 'Other'       },
];

const albumsByType = TYPE_ORDER.map(({ type, label }) => ({
  label,
  albums: type === null
    ? albums.filter(a => !a.release_type || a.release_type === 'other')
    : albums.filter(a => a.release_type === type),
})).filter(s => s.albums.length > 0);

const multipleTypes = albumsByType.length > 1;

let artistRow: ArtistRow | null = null;
let membersData: MembersData = { current: [], original: [], former: [], isPersonOf: [] };
if (artistMbid) {
  artistRow = await db.prepare('SELECT * FROM artists WHERE mbid = ?')
    .bind(artistMbid).first<ArtistRow>();
  if (artistRow) {
    try { membersData = JSON.parse(artistRow.members_data) as MembersData; } catch {}
  }
}

// For members shown under their canonical name, look up any alternative credited names
// they've used in other bands we've already processed (one extra query, only if needed)
const knownAliasMap = new Map<string, string[]>();
const regularMemberMbids = [...new Set(
  [...membersData.current, ...membersData.original, ...membersData.former]
    .map(m => m.mbid).filter((id): id is string => !!id)
)];
if (regularMemberMbids.length > 0) {
  const placeholders = regularMemberMbids.map(() => '?').join(', ');
  const { results: aliasRows } = await db.prepare(
    `SELECT DISTINCT person_mbid, person_name FROM artist_members WHERE person_mbid IN (${placeholders}) AND canonical_name IS NOT NULL`
  ).bind(...regularMemberMbids).all<{ person_mbid: string; person_name: string }>();
  for (const row of aliasRows) {
    const existing = knownAliasMap.get(row.person_mbid) ?? [];
    if (!existing.includes(row.person_name)) existing.push(row.person_name);
    knownAliasMap.set(row.person_mbid, existing);
  }
}

const memberSections = [
  { label: 'Members',          list: membersData.current          },
  { label: 'Original Members', list: membersData.original         },
  { label: 'Former Members',   list: membersData.former           },
  { label: 'Project of',       list: membersData.isPersonOf ?? [] },
].filter(s => s.list.length > 0).map(s => {
  const split = s.list.length >= 5;
  const half = split ? Math.ceil(s.list.length / 2) : s.list.length;
  return { ...s, col1: s.list.slice(0, half), col2: split ? s.list.slice(half) : [] };
});

const artistCountry = albums[0]?.country ?? null;
const locationStr = (() => {
  const loc = artistRow?.formation_location ?? null;
  if (!loc) return null;
  if (!artistCountry) return loc;
  const locLow     = loc.toLowerCase();
  const countryLow = artistCountry.toLowerCase();
  if (locLow === countryLow || locLow.endsWith(`, ${countryLow}`)) return loc;
  return `${loc}, ${artistCountry}`;
})();

const artistDateStr = artistRow
  ? [
      artistRow.inception && (artistRow.dissolution
        ? `${artistRow.inception}–${artistRow.dissolution}`
        : `${artistRow.inception}–present`),
      locationStr,
    ].filter(Boolean).join(' · ')
  : '';

if (!isOwner && !profileUser.is_private) {
  Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
}

const libBase = `/${profileUser.profile_url}`;

const artistAliases: string[] = (() => {
  try { return JSON.parse(artistRow?.aliases || '[]') as string[]; } catch { return []; }
})();
const showEntityAliases = artistAliases.length > 0 && (membersData.isPersonOf?.length ?? 0) === 0;

// Aggregate all "performs as" projects from isPersonOf persons, excluding the current artist
const performsAsList = (membersData.isPersonOf ?? [])
  .flatMap(m => m.performsAs ?? [])
  .filter(p => p.mbid !== artistMbid)
  .reduce<Array<{ name: string; mbid: string }>>((acc, p) => {
    if (!acc.some(x => x.mbid === p.mbid)) acc.push(p);
    return acc;
  }, []);

function ratingClass(r: number | null) {
  if (r == null) return '';
  if (r >= 70) return 'rating-hi';
  if (r >= 50) return 'rating-mid';
  return 'rating-lo';
}
function sortedSubs(subs: string[]) {
  return [...subs].sort((a, b) => a === 'Sketchy' ? -1 : b === 'Sketchy' ? 1 : 0);
}
---

<Layout title={artistName}>
  <div class="page-header artist-header">
    <div class="breadcrumb">
      <h1>
        {profileUser.avatar_url && <a href={`/${username}`} class="header-link"><img src={profileUser.avatar_url} class="profile-avatar" alt="" /></a>}
        <a href={`${libBase}/library`}>{isOwner ? 'My Library' : `${displayName}'s Library`}</a>
      </h1>
      <h1><span class="breadcrumb-sep">›</span></h1>
      <h1><span class="breadcrumb-current">{artistName} {albums[0].country && <span class="breadcrumb-tag tip-link" data-tip={albums[0].country}>{countryCode(albums[0].country) ? countryCode(albums[0].country).toUpperCase() : albums[0].country}</span>}</span></h1>
      <span class="count" style="margin-left:4px">({albums.length} album{albums.length !== 1 ? 's' : ''})</span>
    </div>
  </div>

  <h2 class="mobile-section-title">{artistName}</h2>

  {artistRow && (
    <div class="artist-info-panel">
      <div class="artist-info-top">
        {artistRow.logo_url && (
          <img src={artistRow.logo_url} class="artist-info-logo" alt="" onerror="this.remove()" />
        )}
        <div class="artist-info-meta">
          <div class="artist-disambiguation-wrapper">
            {artistRow.disambiguation && <p class="artist-info-disambiguation">{artistRow.disambiguation}</p>}
            {showEntityAliases && <p class="artist-info-aliases">Also known as: {artistAliases.join(', ')}</p>}
            {artistDateStr && <p class="artist-info-dates">{artistDateStr}</p>}
          </div>
          
          {memberSections.length > 0 && (
            <div class="artist-info-members-grid">
              {memberSections.map(s => {
                const isPersonOfSection = s.label === 'Project of';
                // Fallback: project entity's own aliases (for solo projects with no fetched personAka)
                const personSectionAliases = (isPersonOfSection && s.list.length === 1)
                  ? artistAliases.filter(a => a !== artistName) : [];
                const renderItem = (m: typeof s.list[0]) => {
                  const dateStr = m.beginYear
                    ? (m.isActive ? `${m.beginYear}–present` : m.endYear ? `${m.beginYear}–${m.endYear}` : m.beginYear)
                    : (m.endYear ? `until ${m.endYear}` : null);
                  const akaNames = isPersonOfSection
                    ? (m.personAka && m.personAka !== artistName ? [m.personAka] : personSectionAliases)
                    : (m.canonicalName ? [m.canonicalName] : (m.mbid ? (knownAliasMap.get(m.mbid) ?? []) : []));
                  return (
                    <li>
                      {m.name}
                      {akaNames.length > 0 && <span class="member-aka"> (aka {akaNames.join(', ')})</span>}
                      {m.instruments.length > 0 && (
                        <span class="member-instruments"> — {m.instruments.join(', ')}</span>
                      )}
                      {dateStr && <span class="member-dates"> ({dateStr})</span>}
                    </li>
                  );
                };
                return (
                  <div class="artist-info-member-section">
                    <h4>{s.label}</h4>
                    <div class="member-cols">
                      <ul>{s.col1.map(renderItem)}</ul>
                      {s.col2.length > 0 && <ul>{s.col2.map(renderItem)}</ul>}
                    </div>
                  </div>
                );
              })}
            </div>
          )}
          {performsAsList.length > 0 && (
            <div class="artist-info-member-section">
              <h4>Also performs as</h4>
              <p class="artist-performs-as-list">{performsAsList.map(p => p.name).join(', ')}</p>
            </div>
          )}
        </div>
      </div>
      {artistRow.wiki_blurb && (
        <div class="artist-info-blurb">
          <p>{artistRow.wiki_blurb}</p>
          {artistRow.wiki_url && (
            <a href={artistRow.wiki_url} target="_blank" rel="noopener noreferrer" class="artist-info-wiki-link">Wikipedia ↗</a>
          )}
        </div>
      )}
    </div>
  )}

  {albumsByType.map(({ label, albums: group }) => (
    <div class="artist-type-section">
      {multipleTypes && <h3 class="artist-type-heading">{label}</h3>}
      <div class="table-wrap artist-tbl user-artist-tbl">
        <table>
          <thead>
            <tr>
              <th></th>
              <th>Album</th>
              <th>Year</th>
              <th>Genre</th>
              <th>Subgenres</th>
              <th>Descriptors</th>
              <th>Rating</th>
              <th>Notes</th>
            </tr>
          </thead>
          <tbody>
            {group.map(a => {
              const ownSubs:  string[] = JSON.parse(a.subgenres  || '[]') as string[];
              const ownDescs: string[] = (JSON.parse(a.descriptors || '[]') as string[]).sort((x, y) => x.localeCompare(y));
              return (
                <tr data-href={`${libBase}/album/${a.slug}`}>
                  <td>
                    <div class="cover-thumb" style="background:#000;overflow:hidden">
                      {a.cover_url && (
                        <img src={a.cover_url} alt="" loading="lazy"
                             style="width:100%;height:100%;object-fit:contain;display:block"
                             onerror="this.style.display='none'" />
                      )}
                    </div>
                  </td>
                  <td><a href={`${libBase}/album/${a.slug}`}>{a.year != null && <span class="year-chip col-album-year">{a.year}</span>}<span class="col-album-text">{a.album}</span>{a.recommended ? <span class="rec-star" title="Recommended"> ★</span> : null}</a></td>
                  <td>{a.year ?? ''}</td>
                  <td>{a.genre && <span class="genre">{a.genre}</span>}</td>
                  <td>
                    {sortedSubs(ownSubs).map(s => (
                      <span class={`tag${s === 'Sketchy' ? ' tag-sketchy' : ''}`}>{s}</span>
                    ))}
                  </td>
                  <td>
                    {ownDescs.map(d => (
                      <span class="tag descriptor-tag">{d}</span>
                    ))}
                  </td>
                  <td><span class={`rating ${ratingClass(a.rating)}`}>{a.rating ?? '—'}</span></td>
                  <td class="notes-cell"><span class="notes-text" set:html={a.notes ? mdInline(a.notes.split(/\r?\n/)[0]) : ''} /></td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  ))}
</Layout>

<script>
document.querySelectorAll<HTMLTableRowElement>('tr[data-href]').forEach(tr => {
  tr.addEventListener('click', e => {
    if ((e.target as Element).closest('a')) return;
    window.location.href = tr.dataset.href!;
  });
});
</script>
