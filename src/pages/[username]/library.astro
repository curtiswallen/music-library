---
import Layout from '../../layouts/Layout.astro';
import Combobox from '../../components/Combobox.astro';
import LibraryTable from '../../components/LibraryTable.astro';
import { env } from 'cloudflare:workers';
import type { LibraryEntry } from '../../types';
import { normalizeSearch } from '../../lib/utils';
import { getGenreCache } from '../../lib/genre-cache';
import { getLibraryOverview } from '../../lib/library-cache';

const { username } = Astro.params;
if (!username) return Astro.redirect('/');

const db = env.DB;
const kv = env.GENRE_CACHE;

const profileUser = await db.prepare(`
  SELECT id, username, display_name, profile_url, is_private, hide_added_at, avatar_url
  FROM users WHERE profile_url = ?
`).bind(username).first<{
  id: number; username: string; display_name: string | null;
  profile_url: string; is_private: number; hide_added_at: number; avatar_url: string | null;
}>();

if (!profileUser) return new Response(null, { status: 404 });

const loggedInUser = Astro.locals.user;
const isOwner      = loggedInUser?.id === profileUser.id;
const displayName  = profileUser.display_name || profileUser.username;
const base         = `/${username}`;
const filterBase   = `/${username}/library`;

// ── URL params ────────────────────────────────────────────────────────────────
const q           = Astro.url.searchParams.get('q')           ?? '';
const genre       = Astro.url.searchParams.get('genre')       ?? '';
const subgenres   = Astro.url.searchParams.getAll('subgenre');
const recommended = Astro.url.searchParams.get('recommended') ?? '';
const country     = Astro.url.searchParams.get('country')     ?? '';
const yearFrom    = Astro.url.searchParams.get('year_from')   ?? '';
const yearTo      = Astro.url.searchParams.get('year_to')     ?? '';
const excludes          = Astro.url.searchParams.getAll('excl');
const descriptorFilters = Astro.url.searchParams.getAll('descriptor');
const ratingMin   = Astro.url.searchParams.get('rating_min')  ?? '';
const ratingMax   = Astro.url.searchParams.get('rating_max')  ?? '';
const rated       = Astro.url.searchParams.get('rated')       ?? '';

const showAddedAt = isOwner || !profileUser.hide_added_at;
const VALID_SORTS: Record<string, string> = {
  artist: 'a.artist', album: 'a.album', year: 'a.year',
  rating: 'ua.rating', genre: 'ua.genre',
  ...(showAddedAt ? { added: 'ua.added_at' } : {}),
};
const defaultSort = showAddedAt ? 'added'  : 'artist';
const defaultDir  = showAddedAt ? 'desc'   : 'asc';
const sort        = Astro.url.searchParams.get('sort') ?? defaultSort;
const dir         = Astro.url.searchParams.get('dir')  ?? defaultDir;
const safeSort    = VALID_SORTS[sort] ? sort : defaultSort;
const safeSortCol = VALID_SORTS[safeSort];
const safeDir     = dir === 'desc' ? 'DESC' : 'ASC';

// ── Filter SQL ────────────────────────────────────────────────────────────────
const clauses: string[] = isOwner ? [] : ['ua.is_hidden = 0'];
const params:  (string | number)[] = [];

if (q) { clauses.push('(a.artist LIKE ? OR a.album LIKE ? OR a.search_text LIKE ?)'); params.push(`%${q}%`, `%${q}%`, `%${normalizeSearch(q)}%`); }
if (country)   { clauses.push('a.country = ?');    params.push(country); }
if (yearFrom)  { clauses.push('a.year >= ?');      params.push(Number(yearFrom)); }
if (yearTo)    { clauses.push('a.year <= ?');      params.push(Number(yearTo)); }
if (genre)     { clauses.push('ua.genre = ?');     params.push(genre); }
for (const s of subgenres)         { clauses.push('ua.subgenres LIKE ?');    params.push(`%"${s}"%`); }
for (const s of excludes)          { clauses.push('ua.subgenres NOT LIKE ?'); params.push(`%"${s}"%`); }
for (const d of descriptorFilters) { clauses.push('ua.descriptors LIKE ?');   params.push(`%"${d}"%`); }
if (ratingMin) { clauses.push('ua.rating >= ?');   params.push(Number(ratingMin)); }
if (ratingMax) { clauses.push('ua.rating <= ?');   params.push(Number(ratingMax)); }
if (rated === 'yes') clauses.push('ua.rating IS NOT NULL');
if (rated === 'no')  clauses.push('ua.rating IS NULL');
if (recommended)     clauses.push('ua.recommended = 1');

let albums: LibraryEntry[] = [];
let libraryCountries: string[] = [];
let allDescriptors: string[] = [];
let librarySubMap: Record<string, string[]> = {};
const libraryGenreSet = new Set<string>();

if (isOwner || !profileUser.is_private) {
  const where = clauses.length ? `AND ${clauses.join(' AND ')}` : '';
  const { results } = await db.prepare(`
    SELECT a.id, a.mbid, a.slug, a.artist, a.album, a.country, a.year, a.cover_url,
           ua.genre, ua.subgenres, ua.descriptors, ua.rating, ua.notes, ua.recommended, ua.is_hidden, ua.added_at
    FROM albums a
    JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
    WHERE 1=1 ${where}
    ORDER BY ${safeSortCol} ${safeDir} NULLS LAST
  `).bind(profileUser.id, ...params).all<LibraryEntry>();
  albums = results;

  const overview = await getLibraryOverview(kv, db, profileUser.id, isOwner);
  libraryCountries = overview.countries;
  allDescriptors   = overview.descriptors;
  librarySubMap    = overview.subMap;
  for (const g of overview.genres) libraryGenreSet.add(g);
}

const { groupedGenres: allGroupedGenres } = await getGenreCache(kv, db);
const groupedFilterGenres = allGroupedGenres
  .map(({ group, options }) => ({ group, options: options.filter(name => libraryGenreSet.has(name)) }))
  .filter(({ options }) => options.length > 0);

// ── URL helpers ───────────────────────────────────────────────────────────────

function buildParams(o: Record<string, string | string[] | null | undefined> = {}) {
  const defaults: Record<string, string | string[]> = {};
  if (q)               defaults.q            = q;
  if (country)         defaults.country      = country;
  if (yearFrom)        defaults.year_from    = yearFrom;
  if (yearTo)          defaults.year_to      = yearTo;
  if (ratingMin)       defaults.rating_min   = ratingMin;
  if (ratingMax)       defaults.rating_max   = ratingMax;
  if (rated)           defaults.rated        = rated;
  if (genre)           defaults.genre        = genre;
  defaults.sort = safeSort;
  defaults.dir  = safeDir.toLowerCase();
  if (recommended)              defaults.recommended  = '1';
  if (subgenres.length)         defaults.subgenre     = subgenres;
  if (excludes.length)          defaults.excl         = excludes;
  if (descriptorFilters.length) defaults.descriptor   = descriptorFilters;

  const merged = { ...defaults, ...o };
  const p = new URLSearchParams();
  for (const [k, v] of Object.entries(merged)) {
    if (v == null) continue;
    if (Array.isArray(v)) v.forEach(x => p.append(k, x));
    else p.set(k, v);
  }
  return `${filterBase}?${p}`;
}

function sortHref(col: string) {
  const nextDir = safeSort === col && safeDir === 'ASC' ? 'desc' : 'asc';
  return buildParams({ sort: col, dir: nextDir });
}
function sortArrow(col: string) {
  if (safeSort !== col) return '';
  return safeDir === 'ASC' ? ' ↑' : ' ↓';
}
function recToggleHref() {
  return buildParams({ recommended: recommended ? null : '1' });
}
function ratingClass(r: number | null) {
  if (r == null) return '';
  if (r >= 70) return 'rating-hi';
  if (r >= 50) return 'rating-mid';
  return 'rating-lo';
}
function sortedSubs(subs: string[]) {
  return [...subs].sort((a, b) => a === 'Sketchy' ? -1 : b === 'Sketchy' ? 1 : 0);
}
function subgenreHref(s: string) {
  const next = subgenres.includes(s) ? subgenres.filter(x => x !== s) : [...subgenres, s];
  return buildParams({ subgenre: next });
}
function yearChipLabel() {
  if (yearFrom && yearTo) return `${yearFrom}–${yearTo}`;
  if (yearFrom) return `${yearFrom}+`;
  return `≤${yearTo}`;
}

const activeFilterCount = [
  !!country, !!(yearFrom || yearTo), !!(ratingMin || ratingMax),
  !!rated, !!genre, subgenres.length > 0, excludes.length > 0, descriptorFilters.length > 0,
].filter(Boolean).length;

const hasAnyFilter = !!(q || country || yearFrom || yearTo || ratingMin || ratingMax || rated || genre || subgenres.length || excludes.length || descriptorFilters.length || recommended);
const clearFiltersHref = buildParams({
  q: null, country: null, year_from: null, year_to: null,
  rating_min: null, rating_max: null, rated: null,
  genre: null, subgenre: [], excl: [], descriptor: [], recommended: null,
});

if (!isOwner && !profileUser.is_private) {
  Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
}
---

<Layout title={isOwner ? 'My Library' : `${displayName}'s Library`}>
  <script type="application/json" id="library-sub-map" is:inline set:html={JSON.stringify(librarySubMap)}></script>
  <script is:inline>
    try {
      const k = 'lib:' + location.pathname.split('/')[1] + ':params';
      const s = sessionStorage.getItem(k);
      if (!location.search && s) location.replace(location.pathname + s);
    } catch (_) {}
  </script>

  <div class="page-header">
    <div style="display:flex;align-items:center;gap:10px">
      {profileUser.avatar_url && <img src={profileUser.avatar_url} class="profile-avatar" alt="" />}
      <h1>
        {isOwner ? 'My Library' : `${displayName}'s Library`}
        {(isOwner || !profileUser.is_private) && <span class="count">({albums.length} albums)</span>}
      </h1>
    </div>
    <div style="display:flex;gap:8px;align-items:center">
      {isOwner ? (
        <>
          <a href={`/${username}`} class="btn nav-hide-mobile">Home</a>
          {loggedInUser!.is_admin === 1 && <a href="/admin" class="btn nav-hide-mobile" title="Admin">Admin</a>}
          <a href="/settings" class="btn nav-hide-mobile" title="Settings">⚙</a>
          <form method="post" action="/auth/logout" style="margin:0" class="nav-hide-mobile">
            <button class="btn" type="submit">Sign out</button>
          </form>
          <a href="/add" class="btn icon-btn" aria-label="Add Album" data-tip="Add Album">+</a>
          <div class="nav-hamburger" id="nav-hamburger">
            <button class="btn nav-hamburger-btn" id="nav-hamburger-btn" aria-label="Menu" aria-expanded="false">☰</button>
            <div class="nav-hamburger-menu" id="nav-hamburger-menu" hidden>
              <div class="nav-hamburger-header">
                {loggedInUser!.avatar_url && <img src={loggedInUser!.avatar_url} class="user-avatar" alt="" />}
                <span>{loggedInUser!.display_name || loggedInUser!.username}</span>
              </div>
              <a href={`/${username}`} class="nav-hamburger-item">Home</a>
              {loggedInUser!.is_admin === 1 && <a href="/admin" class="nav-hamburger-item">Admin</a>}
              <a href="/settings" class="nav-hamburger-item">Settings</a>
              <form method="post" action="/auth/logout" style="margin:0">
                <button type="submit" class="nav-hamburger-item">Sign out</button>
              </form>
            </div>
          </div>
        </>
      ) : (
        <>
          <a href={`/${username}`} class="btn">{username}'s Dashboard</a>
          |
          {loggedInUser
            ? <a href={`/${loggedInUser.profile_url}/library`} class="btn">← My Library</a>
            : <a href="/auth/login" class="btn">Sign In</a>}
        </>
      )}
    </div>
  </div>
  <script is:inline>
    (function () {
      var btn  = document.getElementById('nav-hamburger-btn');
      var menu = document.getElementById('nav-hamburger-menu');
      if (!btn || !menu) return;
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        var open = menu.hidden;
        menu.hidden = !open;
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      document.addEventListener('click', function (e) {
        if (!e.target.closest('#nav-hamburger')) {
          menu.hidden = true;
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    })();
  </script>

  {(!isOwner && !!profileUser.is_private) ? (
    <div class="empty-state">
      <p>{displayName} has set their library to private.</p>
    </div>
  ) : (
    <>
      <form class="filters" method="get" action={filterBase}>
        <input type="hidden" name="sort" value={safeSort} />
        <input type="hidden" name="dir"  value={safeDir.toLowerCase()} />

        <div class="filter-bar">
          <input class="search-input" type="text" name="q"
            placeholder="Search artist or album..." value={q} autocomplete="off" />
          <button type="button" id="fp-toggle"
            class={`btn fp-toggle-btn${activeFilterCount > 0 ? ' btn-active' : ''}`}>
            {activeFilterCount > 0 ? `Filters (${activeFilterCount})` : 'Filters'}
          </button>
          <a href={recToggleHref()} class={`btn${recommended ? ' btn-active' : ''}`}>★ Rec</a>
          {hasAnyFilter && <a href={clearFiltersHref} class="btn">Clear</a>}
        </div>

        {(country || yearFrom || yearTo || ratingMin || ratingMax || rated || genre || subgenres.length > 0 || excludes.length > 0 || descriptorFilters.length > 0) && (
          <div class="filter-chips">
            {country && (
              <span class="fchip">
                {country}
                <a href={buildParams({ country: null })} class="chip-remove">×</a>
              </span>
            )}
            {(yearFrom || yearTo) && (
              <span class="fchip">
                {yearChipLabel()}
                <a href={buildParams({ year_from: null, year_to: null })} class="chip-remove">×</a>
              </span>
            )}
            {(ratingMin || ratingMax) && (
              <span class="fchip">
                {ratingMin && ratingMax ? `${ratingMin}–${ratingMax}` : ratingMin ? `≥${ratingMin}` : `≤${ratingMax}`}
                <a href={buildParams({ rating_min: null, rating_max: null })} class="chip-remove">×</a>
              </span>
            )}
            {rated && (
              <span class="fchip">
                {rated === 'yes' ? 'Has rating' : 'Unrated only'}
                <a href={buildParams({ rated: null })} class="chip-remove">×</a>
              </span>
            )}
            {genre && (
              <span class="fchip">
                {genre}
                <a href={buildParams({ genre: null, subgenre: [], excl: [] })} class="chip-remove">×</a>
              </span>
            )}
            {subgenres.map(s => (
              <span class="fchip">
                {s}
                <a href={buildParams({ subgenre: subgenres.filter(x => x !== s) })} class="chip-remove">×</a>
              </span>
            ))}
            {excludes.map(s => (
              <span class="fchip fchip-excl">
                ∅ {s}
                <a href={buildParams({ excl: excludes.filter(x => x !== s) })} class="chip-remove">×</a>
              </span>
            ))}
            {descriptorFilters.map(d => (
              <span class="fchip fchip-descriptor">
                # {d}
                <a href={buildParams({ descriptor: descriptorFilters.filter(x => x !== d) })} class="chip-remove">×</a>
              </span>
            ))}
          </div>
        )}

        <div class="filter-panel" id="fp-panel" hidden>
          <div class="fp-grid">
            <div class="fp-field-fixed">
              <label class="fp-label">Country</label>
              <Combobox id="fp-country" name="country" options={libraryCountries} value={country} placeholder="Search country..." />
            </div>
            <div class="fp-field">
              <label class="fp-label">Year</label>
              <div class="year-range-inputs">
                <input type="number" name="year_from" class="fp-year-input" placeholder="From" value={yearFrom} min="1900" max="2099" />
                <span class="year-sep">–</span>
                <input type="number" name="year_to" class="fp-year-input" placeholder="To" value={yearTo} min="1900" max="2099" />
              </div>
            </div>
            <div class="fp-field">
              <label class="fp-label">Rating</label>
              <div class="year-range-inputs">
                <input type="number" name="rating_min" class="fp-year-input" placeholder="Min" value={ratingMin} min="0" max="100" />
                <span class="year-sep">–</span>
                <input type="number" name="rating_max" class="fp-year-input" placeholder="Max" value={ratingMax} min="0" max="100" />
              </div>
            </div>
            <div class="fp-field-fixed">
              <label class="fp-label">Rated</label>
              <Combobox id="fp-rated" name="rated" value={rated}
                labeledOptions={[
                  { label: 'Has rating',   value: 'yes' },
                  { label: 'Unrated only', value: 'no'  },
                ]}
                placeholder="All albums" />
            </div>
            <div class="fp-field-fixed">
              <label class="fp-label">Genre</label>
              <Combobox id="fp-genre" name="genre" groupedOptions={groupedFilterGenres} value={genre} placeholder="Search genre..." />
            </div>
          </div>

          <div id="fp-sub-sections"
               style={genre ? '' : 'display:none'}
               data-includes={JSON.stringify(subgenres)}
               data-excludes={JSON.stringify(excludes)}>
            <div class="fp-label" style="margin-bottom: 5px;">Subgenres</div>
            <div class="fp-sub-chips" id="fp-sub-chips"></div>
            <div id="fp-sub-inputs"></div>
            <p class="fp-sub-hint">click to include · again to exclude · again to clear</p>
          </div>

          {allDescriptors.length > 0 && (
            <div class="fp-desc-section"
                 id="fp-desc-wrap"
                 data-all={JSON.stringify(allDescriptors)}
                 data-selected={JSON.stringify(descriptorFilters)}>
              <label class="fp-label" style="display:block;margin-bottom:6px">Descriptors</label>
              <div id="fp-desc-chips" class="descriptor-chips"
                   style={descriptorFilters.length > 0 ? 'margin-bottom:6px' : 'display:none;margin-bottom:6px'}></div>
              <div class="descriptor-input-wrap" style="max-width:320px">
                <input type="text" id="fp-desc-input" class="descriptor-input"
                       placeholder="Search descriptors..." autocomplete="off" />
                <div id="fp-desc-dropdown" class="descriptor-dropdown"></div>
              </div>
              <div id="fp-desc-inputs"></div>
            </div>
          )}

          <div class="fp-footer">
            <button type="submit" class="btn btn-primary">Apply</button>
            <a href={clearFiltersHref} class="btn">Clear All</a>
          </div>
        </div>
      </form>

      {albums.length === 0 ? (
        <div class="empty-state">
          {isOwner
            ? <p>No albums found. <a href="/add">Add your first album →</a></p>
            : <p>No albums match the current filters.</p>
          }
        </div>
      ) : (
        <LibraryTable
          albums={albums}
          base={base}
          isOwner={isOwner}
          showAddedAt={showAddedAt}
          safeSort={safeSort}
          currentGenre={genre}
          currentCountry={country}
          currentSubgenres={subgenres}
          sortHref={sortHref}
          sortArrow={sortArrow}
          ratingClass={ratingClass}
          sortedSubs={sortedSubs}
          subgenreHref={subgenreHref}
          buildParams={buildParams}
        />
      )}
    </>
  )}
</Layout>

<style>
.filters { display: block; margin-bottom: 20px; }
.user-chip {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 12px; color: var(--text-muted); padding-right: 10px;
}
.user-avatar { width: 22px; height: 22px; border-radius: 50%; object-fit: cover; }
.profile-avatar { width: 32px; height: 32px; border-radius: 50%; object-fit: cover; }

.filter-bar { display: flex; gap: 8px; align-items: center; }
.fp-toggle-btn { white-space: nowrap; }

.filter-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
.fchip { display: inline-flex; align-items: center; gap: 5px; padding: 3px 8px 3px 10px; border-radius: 3px; background: var(--bg-hover); border: 1px solid var(--border); font-size: 12px; color: var(--text-muted); }
.fchip-excl { border-color: #7a3030; background: rgba(180,40,40,0.10); color: #c06060; }
.chip-remove { color: var(--text-muted); text-decoration: none; font-size: 14px; line-height: 1; opacity: 0.7; margin-left: 2px; }
.chip-remove:hover { opacity: 1; color: var(--text); }

.filter-panel { margin-top: 10px; padding: 14px 16px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px; width: fit-content; max-width: 100%; }
.fp-grid { display: flex; flex-direction: row; flex-wrap: wrap; gap: 12px 20px; margin-bottom: 12px; align-items: flex-start; }
.fp-field { display: flex; flex-direction: column; gap: 5px; }
.fp-field-fixed { display: flex; flex-direction: column; gap: 5px; min-width: 160px; max-width: 250px; flex: 1 1 160px; }
#fp-sub-sections { margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border); }
.fp-label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-muted); }
.year-range-inputs { display: flex; align-items: center; gap: 6px; }
.fp-year-input { width: 72px; background: var(--bg); border: 1px solid var(--border); color: var(--text); padding: 5px 8px; border-radius: 4px; font-size: 13px; font-family: inherit; -moz-appearance: textfield; appearance: textfield; }
.fp-year-input::-webkit-inner-spin-button, .fp-year-input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
.year-sep { color: var(--text-muted); font-size: 13px; }
.filter-panel :global(.combo-input) { width: 100%; box-sizing: border-box; }
.filter-panel :global(.combo) { width: 100%; }
.fp-footer { display: flex; align-items: center; gap: 8px; margin-top: 12px; }
.fp-desc-section { margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border); }
.fchip-descriptor { border-color: var(--accent); color: var(--accent-hi); background: rgba(33,114,206,0.08); }

.added-cell { color: var(--text-muted); font-size: 11px; white-space: nowrap; }
.album-hidden { opacity: 0.5; }
.hidden-badge { font-size: 11px; opacity: 0.6; cursor: default; }

.flag-link { text-decoration: none; display: inline-flex; align-items: center; border-radius: 3px; transition: opacity 0.15s; }
.flag-link:hover { opacity: 0.75; }
.flag-active { outline: 1px solid var(--accent); border-radius: 2px; }
.flag-text { font-size: 11px; color: var(--text-muted); }
.flag-text.flag-active { color: var(--accent); }
</style>

<script>
function readLibrarySubMap(): Record<string, string[]> {
  try {
    const el = document.getElementById('library-sub-map');
    return el?.textContent ? (JSON.parse(el.textContent) as Record<string, string[]>) : {};
  } catch { return {}; }
}

function esc(s: string) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

const fpToggle      = document.getElementById('fp-toggle')!;
const fpPanel       = document.getElementById('fp-panel') as HTMLElement;
const fpGenre       = document.getElementById('fp-genre') as HTMLInputElement;
const fpSubSections = document.getElementById('fp-sub-sections') as HTMLElement;
const fpSubChips    = document.getElementById('fp-sub-chips')!;
const fpSubInputs   = document.getElementById('fp-sub-inputs')!;

fpToggle.addEventListener('click', () => { fpPanel.hidden = !fpPanel.hidden; });

const subStates = new Map<string, 'include' | 'exclude'>();
(JSON.parse(fpSubSections.dataset.includes || '[]') as string[]).forEach(s => subStates.set(s, 'include'));
(JSON.parse(fpSubSections.dataset.excludes || '[]') as string[]).forEach(s => subStates.set(s, 'exclude'));

function syncSubInputs() {
  fpSubInputs.innerHTML = '';
  for (const [sub, state] of subStates) {
    const inp = document.createElement('input');
    inp.type = 'hidden';
    inp.name = state === 'include' ? 'subgenre' : 'excl';
    inp.value = sub;
    fpSubInputs.appendChild(inp);
  }
}

function renderSubChips() {
  const subs = readLibrarySubMap()[fpGenre.value] ?? [];
  if (!subs.length) { fpSubSections.style.display = 'none'; return; }
  fpSubSections.style.display = '';
  fpSubChips.innerHTML = subs.map(s => {
    const st = subStates.get(s) ?? 'neutral';
    const label = st === 'include' ? `+ ${esc(s)}` : st === 'exclude' ? `∅ ${esc(s)}` : esc(s);
    return `<button type="button" class="sub-chip" data-sub="${esc(s)}" data-state="${st}">${label}</button>`;
  }).join('');
  fpSubChips.querySelectorAll<HTMLButtonElement>('.sub-chip').forEach(btn => {
    btn.addEventListener('click', () => {
      const sub = btn.dataset.sub!;
      const cur = subStates.get(sub) ?? 'neutral';
      const next = cur === 'neutral' ? 'include' : cur === 'include' ? 'exclude' : 'neutral';
      if (next === 'neutral') { subStates.delete(sub); btn.textContent = sub; }
      else { subStates.set(sub, next); btn.textContent = (next === 'include' ? '+ ' : '∅ ') + sub; }
      btn.dataset.state = next;
      syncSubInputs();
    });
  });
  syncSubInputs();
}

fpGenre.addEventListener('change', () => { subStates.clear(); renderSubChips(); });
renderSubChips();

// ── Descriptor filter widget ──────────────────────────────────────────────────
const descWrap = document.getElementById('fp-desc-wrap') as HTMLElement | null;
if (descWrap) {
  const allDescs: string[]      = JSON.parse(descWrap.dataset.all      || '[]');
  const selectedDescs           = new Set<string>(JSON.parse(descWrap.dataset.selected || '[]'));
  const descChipsEl             = document.getElementById('fp-desc-chips')!;
  const descInputEl             = document.getElementById('fp-desc-input') as HTMLInputElement;
  const descDropEl              = document.getElementById('fp-desc-dropdown')!;
  const descInputsEl            = document.getElementById('fp-desc-inputs')!;

  function syncDescInputs() {
    descInputsEl.innerHTML = '';
    for (const d of selectedDescs) {
      const inp = document.createElement('input');
      inp.type = 'hidden'; inp.name = 'descriptor'; inp.value = d;
      descInputsEl.appendChild(inp);
    }
  }

  function renderDescChips() {
    descChipsEl.innerHTML = '';
    descChipsEl.style.display = selectedDescs.size > 0 ? '' : 'none';
    [...selectedDescs].sort((a, b) => a.localeCompare(b, undefined, { sensitivity: 'base' }))
      .forEach(d => {
        const chip = document.createElement('span');
        chip.className = 'descriptor-chip';
        const label = document.createElement('span');
        label.textContent = d;
        const btn = document.createElement('button');
        btn.type = 'button'; btn.className = 'descriptor-chip-remove'; btn.textContent = '×';
        btn.addEventListener('click', () => { selectedDescs.delete(d); renderDescChips(); syncDescInputs(); });
        chip.appendChild(label); chip.appendChild(btn);
        descChipsEl.appendChild(chip);
      });
  }

  function showDescDropdown(q: string) {
    const lower = q.toLowerCase();
    const matches = allDescs.filter(d => !selectedDescs.has(d) && (q === '' || d.toLowerCase().includes(lower))).slice(0, 12);
    if (!matches.length) { descDropEl.innerHTML = ''; descDropEl.classList.remove('open'); return; }
    descDropEl.innerHTML = matches.map(d => `<div class="descriptor-opt">${esc(d)}</div>`).join('');
    descDropEl.classList.add('open');
    descDropEl.querySelectorAll<HTMLElement>('.descriptor-opt').forEach(el => {
      el.addEventListener('mousedown', ev => {
        ev.preventDefault();
        selectedDescs.add(el.textContent!);
        descInputEl.value = '';
        descDropEl.innerHTML = ''; descDropEl.classList.remove('open');
        renderDescChips(); syncDescInputs();
      });
    });
  }

  descInputEl.addEventListener('focus',  () => showDescDropdown(descInputEl.value.trim()));
  descInputEl.addEventListener('click',  () => showDescDropdown(descInputEl.value.trim()));
  descInputEl.addEventListener('input',  () => showDescDropdown(descInputEl.value.trim()));
  descInputEl.addEventListener('blur',   () => setTimeout(() => { descDropEl.innerHTML = ''; descDropEl.classList.remove('open'); }, 150));

  renderDescChips();
  syncDescInputs();
}

// ── sessionStorage: persist filter/sort state ─────────────────────────────
const PARAMS_KEY = 'lib:' + location.pathname.split('/')[1] + ':params';
if (location.search) sessionStorage.setItem(PARAMS_KEY, location.search);
</script>
