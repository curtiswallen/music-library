---
import Layout from '../../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import { md } from '../../lib/markdown';
import { PLATFORM_MAP, platformUrl, parseSocialLinks } from '../../lib/social-platforms';
import { COUNTRY_PATHS } from '../../generated/world-map-paths';
import { countryCode, countryName } from '../../lib/utils';

const { username } = Astro.params;
if (!username) return Astro.redirect('/');

const db = env.DB;

const profileUser = await db.prepare(`
  SELECT id, username, display_name, profile_url, is_private, hide_added_at, timezone, avatar_url, bio, social_links, country_counts
  FROM users WHERE profile_url = ?
`).bind(username).first<{
  id: number; username: string; display_name: string | null;
  profile_url: string; is_private: number; hide_added_at: number;
  timezone: string; avatar_url: string | null; bio: string | null;
  social_links: string | null; country_counts: string | null;
}>();

if (!profileUser) return new Response(null, { status: 404 });

const bioHtml     = profileUser.bio ? md.parse(profileUser.bio) as string : '';
const socialLinks = parseSocialLinks(profileUser.social_links);

const loggedInUser = Astro.locals.user;

const cfDevice = Astro.request.headers.get('CF-Device-Type') ?? '';
const ua       = Astro.request.headers.get('User-Agent') ?? '';
const isMobile = cfDevice === 'mobile' || (!cfDevice && /Mobi|Android|iPhone/i.test(ua));

// Choropleth: ISO alpha-2 → count + raw DB value (for click-through URL)
const countMap:   Record<string, number> = {};
const isoToRaw:   Record<string, string> = {};
if (!isMobile && profileUser.country_counts) {
  try {
    const cc = JSON.parse(profileUser.country_counts) as Record<string, number>;
    for (const [rawCountry, count] of Object.entries(cc)) {
      const iso = countryCode(rawCountry);
      if (!iso) continue;
      countMap[iso] = (countMap[iso] ?? 0) + count;
      isoToRaw[iso] = rawCountry;
    }
  } catch {}
}
const hasMapData = !isMobile && Object.keys(countMap).length > 0;
const isOwner      = loggedInUser?.id === profileUser.id;
const displayName  = profileUser.display_name || profileUser.username;
const userBase     = `/${username}`;
const libBase      = `/${username}/library`;

const showRecentlyAdded = isOwner || !profileUser.hide_added_at;

const TYPE_LABELS: Record<string, string> = { lp: 'LP', ep: 'EP', compilation: 'Compilation', demo: 'Demo', single: 'Single', other: 'Other' };

type DashAlbum = {
  id: number; slug: string; artist: string; album: string; year: number | null;
  cover_url: string | null; release_type: string | null; rating: number | null; recommended: number;
  added_at: string | null; country: string | null; genre: string | null;
};
type StatsRow   = { total_albums: number; rated_count: number; avg_rating: number | null; total_seconds: number };
type HeatmapRow = { day: string; count: number; seconds: number };

let recentAlbums: DashAlbum[] = [];
let topAlbums:    DashAlbum[] = [];
let queueAlbums:  DashAlbum[] = [];
let stats: StatsRow = { total_albums: 0, rated_count: 0, avg_rating: null, total_seconds: 0 };

type HeatmapCell  = { dateStr: string; count: number; seconds: number; tip: string; isFuture: boolean };
type MonthBlock   = { label: string; yearMonth: string; weeks: HeatmapCell[][] };
let heatmapWeeks: HeatmapCell[][] = [];
let monthBlocks:  MonthBlock[] = [];

// Compute UTC offset for profile owner's timezone so SQLite DATE() groups by local day.
function tzOffsetMinutes(tz: string): number {
  try {
    const now = new Date();
    const utc   = new Date(now.toLocaleString('en-US', { timeZone: 'UTC' }));
    const local = new Date(now.toLocaleString('en-US', { timeZone: tz }));
    return Math.round((local.getTime() - utc.getTime()) / 60000);
  } catch { return 0; }
}

const tz       = profileUser.timezone || 'UTC';
const offsetMin = tzOffsetMinutes(tz);
// e.g. "+330 minutes" (India) or "-300 minutes" (US Eastern)
const tzMod    = `${offsetMin >= 0 ? '+' : ''}${offsetMin} minutes`;
// "today" as a date string in the profile owner's timezone
const localToday = new Date().toLocaleDateString('en-CA', { timeZone: tz }); // YYYY-MM-DD

if (isOwner || !profileUser.is_private) {
  const hiddenWhere = isOwner ? '' : ' AND is_hidden = 0';

  const recentPromise = showRecentlyAdded
    ? db.prepare(`
        SELECT a.slug, a.artist, a.album, a.year, a.cover_url, a.country, a.release_type, ua.rating, ua.recommended, ua.added_at, ua.genre
        FROM albums a JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
        WHERE ua.is_hidden = 0 AND ua.rating IS NOT NULL
        ORDER BY ua.added_at DESC LIMIT 15
      `).bind(profileUser.id).all<DashAlbum>()
    : Promise.resolve({ results: [] as DashAlbum[] });

  const [recentRes, topRes, queueRes, statsRes, heatmapRes] = await Promise.all([
    recentPromise,
    db.prepare(`
      SELECT a.slug, a.artist, a.album, a.year, a.cover_url, a.country, a.release_type, ua.rating, ua.recommended, ua.genre
      FROM albums a JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
      WHERE ua.is_hidden = 0 AND ua.rating IS NOT NULL
      ORDER BY ua.rating DESC LIMIT 15
    `).bind(profileUser.id).all<DashAlbum>(),
    db.prepare(`
      SELECT a.id, a.slug, a.artist, a.album, a.year, a.cover_url, a.country, a.release_type, ua.rating, ua.recommended, ua.added_at, ua.genre
      FROM albums a JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
      WHERE ua.is_hidden = 0 AND ua.is_queued = 1
      ORDER BY ua.added_at DESC
    `).bind(profileUser.id).all<DashAlbum>(),
    db.prepare(`
      SELECT COUNT(*) as total_albums, COUNT(rating) as rated_count,
             ROUND(AVG(CAST(rating AS REAL)), 1) as avg_rating,
             (SELECT total_seconds FROM users WHERE id = ?) as total_seconds
      FROM user_albums WHERE user_id = ?${hiddenWhere}
    `).bind(profileUser.id, profileUser.id).first<StatsRow>(),
    showRecentlyAdded && !isMobile
      ? db.prepare(`
          SELECT DATE(added_at, '${tzMod}') as day,
                 COUNT(*) as count,
                 COALESCE(SUM(track_seconds), 0) as seconds
          FROM user_albums
          WHERE user_id = ? AND rating IS NOT NULL AND DATE(added_at, '${tzMod}') > DATE('${localToday}', '-371 days')${hiddenWhere}
          GROUP BY day
        `).bind(profileUser.id).all<HeatmapRow>()
      : Promise.resolve({ results: [] as HeatmapRow[] }),
  ]);

  recentAlbums = (recentRes as { results: DashAlbum[] }).results;
  topAlbums    = topRes.results;
  queueAlbums  = queueRes.results;
  stats        = statsRes ?? stats;

  // ── Build heatmap ────────────────────────────────────────────────────────────
  if (showRecentlyAdded && !isMobile) {
    const heatmapMap = new Map<string, HeatmapRow>();
    for (const r of (heatmapRes as { results: HeatmapRow[] }).results) {
      heatmapMap.set(r.day, r);
    }

    const todayDate = new Date(localToday + 'T00:00:00Z');

    const startDate = new Date(todayDate);
    startDate.setUTCDate(startDate.getUTCDate() - 364 - todayDate.getUTCDay());

    let cur = new Date(startDate);
    while (cur <= todayDate) {
      const week: HeatmapCell[] = [];
      for (let d = 0; d < 7; d++) {
        const dateStr  = cur.toISOString().slice(0, 10);
        const isFuture = cur > todayDate;
        const row      = isFuture ? null : (heatmapMap.get(dateStr) ?? null);
        const count    = row?.count ?? 0;
        const seconds  = row?.seconds ?? 0;
        const label = ordinal(cur.getUTCDate());
        let tip = '';
        if (!isFuture && count > 0) {
          const lines = [label, `${count} album${count !== 1 ? 's' : ''}`];
          if (seconds > 0) lines.push(fmtDuration(seconds));
          tip = lines.join('|');
        }
        week.push({ dateStr, count, seconds, isFuture, tip });
        const next = new Date(cur);
        next.setUTCDate(next.getUTCDate() + 1);
        cur = next;
      }
      heatmapWeeks.push(week);
    }

    // Group weeks by month (oldest → newest, left-to-right reading order)
    const blockMap = new Map<string, MonthBlock>();
    for (const week of heatmapWeeks) {
      const d  = new Date(week[0].dateStr + 'T00:00:00Z');
      const ym = `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}`;
      if (!blockMap.has(ym)) {
        blockMap.set(ym, {
          label: d.toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' }),
          yearMonth: ym,
          weeks: [],
        });
      }
      blockMap.get(ym)!.weeks.push(week);
    }
    monthBlocks = [...blockMap.values()].reverse(); // newest first
  }
}

function ratingClass(r: number | null) {
  if (r == null) return '';
  if (r >= 70) return 'rating-hi';
  if (r >= 50) return 'rating-mid';
  return 'rating-lo';
}

function ordinal(n: number): string {
  const v = n % 100;
  const s = (v >= 11 && v <= 13) ? 'th' : ['th','st','nd','rd'][n % 10] ?? 'th';
  return `${n}${s}`;
}

function fmtLoggedAt(dateStr: string | null, tz = 'UTC'): string {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  const parts = new Intl.DateTimeFormat('en-US', {
    timeZone: tz, month: 'numeric', day: 'numeric', year: '2-digit',
    hour: '2-digit', minute: '2-digit', hourCycle: 'h23',
  }).formatToParts(d);
  const get = (t: string) => parts.find(p => p.type === t)?.value ?? '';
  return `${get('month')}/${get('day')}/${get('year')} ${get('hour')}:${get('minute')}`;
}

function fmtDuration(s: number): string {
  if (!s) return '—';
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  const d = Math.floor(h / 24);
  const rh = h % 24;
  if (d > 0) return rh > 0 ? `${d}d ${rh}h` : `${d}d`;
  if (h > 0) return m > 0 ? `${h}h ${m}m` : `${h}h`;
  return `${m}m`;
}

const sections = [
  ...(showRecentlyAdded ? [{
    title: 'Recently Logged',
    albums: recentAlbums,
    viewAllHref: `${libBase}?sort=added&dir=desc`,
    emptyText: 'No albums logged yet.',
    showDate: true,
  }] : []),
  {
    title: 'Highest Rated',
    albums: topAlbums,
    viewAllHref: `${libBase}?sort=rating&dir=desc&rated=yes`,
    emptyText: 'No rated albums yet.',
    showDate: false,
  },
  {
    title: 'Queue',
    albums: queueAlbums,
    viewAllHref: isOwner ? libBase : null,
    emptyText: 'Queue empty.',
    showDate: true,
    showQueueAdd: isOwner,
    isQueue: isOwner,
  },
];

if (!isOwner && !profileUser.is_private) {
  Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
}
---

<Layout title={isOwner ? 'Home' : displayName}>
  <div class="page-header" slot="header">
    <div style="display:flex;align-items:center;gap:10px">
      {profileUser.avatar_url && <img src={profileUser.avatar_url} class="profile-avatar" alt="" />}
      <h1>{displayName}</h1>
    </div>
  </div>

  {(!isOwner && !!profileUser.is_private) ? (
    <div class="empty-state">
      <p>{displayName} has set their library to private.</p>
    </div>
  ) : (
    <>
    <div id="dashboard-wrapper" data-user-base={userBase} data-tz={tz}>
      {/* ── Activity section ──────────────────────────────────────────────── */}
      <div class="activity-section">
        <div class="stat-cards">
          <div class="stat-card">
            <span class="stat-val">{stats.total_albums}</span>
            <span class="stat-lbl">Albums</span>
          </div>
          <div class="stat-card">
            <span class="stat-val">{fmtDuration(stats.total_seconds)}</span>
            <span class="stat-lbl">Logged</span>
          </div>
          <div class="stat-card">
            <span class="stat-val">{stats.rated_count}</span>
            <span class="stat-lbl">Rated</span>
          </div>
          {stats.avg_rating != null && (
            <div class="stat-card">
              <span class="stat-val">{stats.avg_rating}</span>
              <span class="stat-lbl">Avg Rating</span>
            </div>
          )}
        </div>

        {bioHtml && (<div id="bio-wrapper">
           <div class="user-bio album-notes" set:html={bioHtml} />

          {socialLinks.length > 0 && (
            <div class="social-links-row">
              {socialLinks.map(link => {
                const p = PLATFORM_MAP.get(link.platform);
                if (!p) return null;
                return (
                  <a href={platformUrl(p, link.username)} target="_blank" rel="noopener noreferrer"
                    class="social-link-icon" title={p.label}
                    style={`--brand: ${p.color}`}>
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true">
                      <path d={p.svgPath} />
                    </svg>
                  </a>
                );
              })}
            </div>
          )}
        </div>)}

        {showRecentlyAdded && !isMobile && monthBlocks.length > 0 && (
          <div id="hm-tip" aria-hidden="true"></div>
        )}
        {showRecentlyAdded && !isMobile && monthBlocks.length > 0 && (
          <div class="hm-grid">
            {monthBlocks.map(block => (
              <div class="hm-block">
                <div class="hm-block-label">{block.label}</div>
                <div class="hm-dow-row" aria-hidden="true">
                  {['S','M','T','W','T','F','S'].map(d => <span class="hm-dow">{d}</span>)}
                </div>
                {block.weeks.map(cells => (
                  <div class="hm-row">
                    {cells.map(({ dateStr, count, tip, isFuture }) => {
                      const other = dateStr.slice(0, 7) !== block.yearMonth;
                      return (
                        <div
                          class="hm-cell"
                          style={other ? 'opacity:0;pointer-events:none' : undefined}
                          data-v={other ? '0' : String(isFuture ? 0 : Math.min(count, 4))}
                          data-future={!other && isFuture ? '' : undefined}
                          data-hm={!other && !isFuture && tip ? tip : undefined}
                        />
                      );
                    })}
                  </div>
                ))}
              </div>
            ))}
          </div>
        )}

        {/* ── World map ─────────────────────────────────────────────────────── */}
        {hasMapData && (
          <div class="wm-wrap">
            <svg id="world-map-svg" viewBox="-2 6 373 140" class="wm-svg" aria-hidden="true">
              <rect x="-2" y="6" width="373" height="140" class="wm-ocean" />
              {Object.entries(COUNTRY_PATHS).map(([iso, d]) => {
                const count = countMap[iso] ?? 0;
                const v = count === 0 ? '0' : count >= 30 ? '4' : count >= 10 ? '3' : count >= 3 ? '2' : '1';
                const raw = isoToRaw[iso] ?? '';
                return (
                  <path
                    d={d}
                    class="wm-country"
                    data-v={v}
                    data-iso={iso}
                    data-count={String(count)}
                    data-name={countryName(iso) || iso}
                    data-country={raw}
                  />
                );
              })}
            </svg>
            <button id="wm-expand" class="wm-expand-btn" aria-label="Expand map" title="Expand map">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="15 3 21 3 21 9" /><polyline points="9 21 3 21 3 15" />
                <line x1="21" y1="3" x2="14" y2="10" /><line x1="3" y1="21" x2="10" y2="14" />
              </svg>
            </button>
            <div id="wm-tip" aria-hidden="true"></div>
          </div>
        )}

      </div>

      {/* ── Dashboard panels ──────────────────────────────────────────────── */}
      <div class="dash-grid" style={`grid-template-columns: repeat(${sections.length}, 1fr)`}>
        {sections.map(({ title, albums, viewAllHref, emptyText, showDate, showQueueAdd, isQueue }) => (
          <div class="dash-grid-wrapper">
            <div class="dash-section-header">
              <div class="dash-title-wrapper">
                <h2 class="dash-title">{title}</h2>
                {showQueueAdd && <button class="btn dash-queue-add-btn" type="button" aria-label="Add Album to Queue" data-tip="Add Album to Queue">+</button>}
              </div>
              <div style="display:flex;align-items:center;">
                {!showQueueAdd && viewAllHref && (<a href={viewAllHref} class="dash-view-all">View all →</a>)}
              </div>
            </div>
            <section class="dash-section">
              {albums.length === 0 ? (
                <p class="dash-empty">{emptyText}</p>
              ) : (
                <div class="dash-list">
                  {albums.map(a => isQueue ? (
                    <div class="dash-row dash-queue-row" data-album-id={String(a.id)}>
                      <a href={`${userBase}/album/${a.slug}`} class="dash-queue-row-link">
                        {a.cover_url
                          ? <img src={a.cover_url} class="dash-cover" alt="" loading="lazy" />
                          : <div class="dash-cover dash-cover-empty" />}
                        <div class="dash-info">
                          <div class="dash-album-wrap">
                            {a.release_type && <span class="type-chip">{TYPE_LABELS[a.release_type]}</span>}
                            <span class="dash-album"><span class="dash-album-text">{a.album}</span></span>
                            {a.year && <span class="year-chip">{a.year}</span>}
                          </div>
                          <span class="dash-artist-name">
                            <span class="dash-artist-text">{a.artist}</span>
                            {a.genre && <span class="dash-genre">{a.genre}</span>}
                          </span>
                        </div>
                      </a>
                      <div class="dash-queue-remove-wrap">
                        <button class="dash-queue-remove tip-left" data-album-id={String(a.id)} type="button" aria-label="Remove from queue" data-tip="Remove from queue">×</button>
                        {a.added_at && <span class="dash-logged-date">{fmtLoggedAt(a.added_at, profileUser.timezone || 'UTC')}</span>}
                      </div>
                    </div>
                  ) : (
                    <a href={`${userBase}/album/${a.slug}`} class="dash-row">
                      {a.cover_url
                        ? <img src={a.cover_url} class="dash-cover" alt="" loading="lazy" />
                        : <div class="dash-cover dash-cover-empty" />}
                      <div class="dash-info">
                        <div class="dash-album-wrap">
                          {a.release_type && <span class="type-chip">{TYPE_LABELS[a.release_type]}</span>}
                          <span class="dash-album">
                            <span class="dash-album-text">{a.album}</span>
                          </span>
                          {a.recommended ? <span class="rec-star" title="Recommended">★</span> : null}
                          {a.year && <span class="year-chip">{a.year}</span>}
                        </div>
                        <span class="dash-artist-name">
                          <span class="dash-artist-text">{a.artist}</span>
                          {a.country && countryCode(a.country) && <span class="dash-cc">{countryCode(a.country).toUpperCase()}</span>}
                          {a.genre && <span class="dash-genre">{a.genre}</span>}
                        </span>
                      </div>
                      {a.rating != null
                        ? <div class="dash-rating-wrap">
                            <span class={`dash-rating rating ${ratingClass(a.rating)}`}>{a.rating}</span>
                            {showDate && a.added_at && <span class="dash-logged-date">{fmtLoggedAt(a.added_at, profileUser.timezone || 'UTC')}</span>}
                          </div>
                        : <div class="dash-rating-wrap">
                            <span class="dash-rating dash-rating-none">—</span>
                            {showDate && a.added_at && <span class="dash-logged-date">{fmtLoggedAt(a.added_at, profileUser.timezone || 'UTC')}</span>}
                          </div>}
                    </a>
                  ))}
                </div>
              )}
            </section>
          </div>
        ))}
      </div>
    </div>
    </>
  )}
</Layout>

{hasMapData && (
  <div id="wm-modal" class="wm-modal" style="display:none" aria-modal="true" role="dialog">
    <div class="wm-modal-inner">
      <button id="wm-close" class="wm-close-btn" aria-label="Close map">×</button>
      <div class="wm-modal-body">
        <div class="wm-modal-table-wrap">
          <table id="wm-modal-table">
            <thead>
              <tr>
                <th class="wm-th" data-sort="name">Country</th>
                <th class="wm-th" data-sort="count">Albums</th>
              </tr>
            </thead>
            <tbody id="wm-modal-tbody"></tbody>
          </table>
        </div>
        <div id="wm-modal-map"></div>
      </div>
      <div id="wm-modal-tip" class="wm-tip" aria-hidden="true"></div>
    </div>
  </div>
)}

<style>
#dashboard-wrapper { display: flex; flex-direction: row; gap: 28px; width: 100%; }

.profile-avatar { width: 32px; height: 32px; border-radius: 50%; object-fit: cover; }
.user-avatar    { width: 22px; height: 22px; border-radius: 50%; object-fit: cover; }
.nav-sep        { color: var(--border); user-select: none; }

/* ── Activity section ────────────────────────────────────────────────────── */
.activity-section { margin-bottom: 28px; display: flex; flex-direction: column; gap: 20px; margin-top: 15px; }

.stat-cards {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  justify-content: space-between;
}

#bio-wrapper {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.user-bio {
  max-width: 480px;
  margin-bottom: 0 !important;
}
.social-links-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 4px;
}
.social-link-icon {
  color: var(--text-muted);
  display: flex;
  align-items: center;
  transition: color 0.15s;
}
.social-link-icon:hover { color: var(--brand, var(--text)); }
.stat-card {
  padding: 0;
}
.stat-val {
  display: block;
  font-size: 22px;
  font-weight: 600;
  color: var(--text-hi);
  font-variant-numeric: tabular-nums;
  line-height: 1.2;
}
.stat-lbl {
  display: block;
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--text-muted);
}

/* ── Heatmap ─────────────────────────────────────────────────────────────── */
.hm-grid {
  display: grid;
  grid-template-columns: repeat(3, max-content);
  gap: 16px;
  margin-bottom: 4px;
}
.hm-block {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.hm-block-label {
  font-size: 9px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding-bottom: 2px;
}
.hm-dow-row,
.hm-row {
  display: flex;
  gap: 2px;
}
.hm-dow {
  width: 11px;
  text-align: center;
  font-size: 9px;
  color: var(--text-muted);
  line-height: 11px;
}
.hm-cell {
  width: 11px;
  height: 11px;
  border-radius: 2px;
  background: var(--bg-hover);
  cursor: default;
}
.hm-cell[data-future] { opacity: 0.25; }
.hm-cell[data-v="1"] { background: color-mix(in srgb, var(--mapping) 30%, var(--bg-hover)); }
.hm-cell[data-v="2"] { background: color-mix(in srgb, var(--mapping) 55%, var(--bg-hover)); }
.hm-cell[data-v="3"] { background: color-mix(in srgb, var(--mapping) 80%, var(--bg-hover)); }
.hm-cell[data-v="4"] { background: var(--mapping); }

#hm-tip {
  display: none;
  position: fixed;
  flex-direction: column;
  gap: 2px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 7px 10px;
  pointer-events: none;
  z-index: 500;
  white-space: nowrap;
  box-shadow: 0 2px 8px rgba(0,0,0,0.3);
}
:global(#hm-tip .hmt-date)  { font-size: 12px; font-weight: 600; color: var(--text); }
:global(#hm-tip .hmt-count) { font-size: 11px; color: var(--text-muted); }
:global(#hm-tip .hmt-time)  { font-size: 11px; color: var(--text-muted); }

/* ── Dashboard panels ────────────────────────────────────────────────────── */
.dash-grid {
  display: grid;
  gap: 20px;
  align-items: start;
  width: 100%;
}
.dash-grid-wrapper { min-width: 0; }
.dash-title-wrapper { display: flex; flex-direction: row; gap: 10px; align-items: center; }
.dash-section {
  /*background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 3px;
  overflow: hidden;*/
}
.dash-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 5px 10px 0;
  height: 40px;
}
.dash-title {
  font-size: 10px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--text-muted);
}
.dash-view-all { font-size: 10px; color: var(--text-muted); }
.dash-empty { padding: 20px 14px; font-size: 12px; color: var(--text-muted); }
.dash-queue-add-btn { font-size: 9px; padding: 2px 4px; height: auto; }

@media (max-width: 900px) {
  .dash-grid { grid-template-columns: 1fr !important; }
}
@media (max-width: 640px) {
  .stat-cards { gap: 20px; margin-bottom: 0; justify-content: space-between; }
  #dashboard-wrapper { flex-direction: column; gap: 8px; }
  .hm-grid, .hm-header, .wm-wrap { display: none !important; }
  .activity-section { margin-bottom: 0; }
  .dash-grid { margin-bottom: 150px; }
  :global(.dash-row) { padding: 8px 0; }
  :global(.dash-row:hover) { background: none; }
}

/* ── World map ───────────────────────────────────────────────────────────── */
.wm-wrap {
  position: relative;
  display: inline-block;
  line-height: 0;
  /* padding controls visual margin around the map; viewBox is trimmed to content */
  padding: 6px;
}
.wm-svg {
  width: 100%;
  max-width: 320px;
  display: block;
}
.wm-ocean { fill: var(--bg); }
:global(.wm-country)          { fill: var(--bg-hover); stroke: var(--bg); stroke-width: 0.3; }
:global(.wm-country[data-v="0"]) { fill: var(--bg-hover); cursor: default; pointer-events: none; }
:global(.wm-country[data-v="1"]) { fill: color-mix(in srgb, var(--mapping) 25%, var(--bg-card)); cursor: pointer; }
:global(.wm-country[data-v="2"]) { fill: color-mix(in srgb, var(--mapping) 50%, var(--bg-card)); cursor: pointer; }
:global(.wm-country[data-v="3"]) { fill: color-mix(in srgb, var(--mapping) 75%, var(--bg-card)); cursor: pointer; }
:global(.wm-country[data-v="4"]) { fill: var(--mapping); cursor: pointer; }
:global(.wm-country:not([data-v="0"]):hover) { filter: brightness(0.9); }

.wm-expand-btn {
  position: absolute;
  bottom: 4px;
  left: 4px;
  background: none;
  border: none;
  border-radius: 3px;
  padding: 3px 5px;
  cursor: pointer;
  color: var(--bg-hover);
  display: flex;
  align-items: center;
  line-height: 1;
}
.wm-expand-btn:hover { color: var(--text); }

#wm-tip {
  display: none;
  position: fixed;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 10px 6px;
  pointer-events: none;
  z-index: 500;
  white-space: nowrap;
  font-size: 10px;
  color: var(--text);
  flex-direction: row;
  gap: 10px;
}
:global(.wm-tip-country) { font-weight: 600; }
:global(.wm-tip-count)   { font-size: 10px; color: var(--text-muted); }

/* Modal */
.wm-modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.7);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.wm-modal-inner {
  position: relative;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 3px;
  width: 85vw;
  max-height: 85vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  padding: 25px;
}
.wm-modal-body {
  display: flex;
  flex-direction: row;
  overflow: hidden;
  flex: 1;
  min-height: 0;
}
.wm-modal-table-wrap {
  width: 210px;
  flex-shrink: 0;
  overflow-y: auto;
  font-size: 10px;
}
#wm-modal-table {
  width: 100%;
  border-collapse: collapse;
  cursor: pointer;
}
#wm-modal-table thead {
  position: sticky;
  top: 0;
  z-index: 1;
  background-color: var(--bg);
}
.wm-th {
  padding: 7px 8px;
  text-align: left;
  cursor: pointer;
  user-select: none;
  font-size: 9px;
  font-weight: 600;
  color: var(--text-muted);
  border-bottom: none;
  white-space: nowrap;
}
.wm-th:hover { color: var(--text); }
.wm-th.wm-th-active { color: var(--text); }
.wm-th.wm-th-active[data-dir="desc"]::after { content: ' ↓'; }
.wm-th.wm-th-active[data-dir="asc"]::after  { content: ' ↑'; }
:global(.wm-tr) { cursor: pointer; border-bottom: none; }
:global(.wm-tr:hover), :global(.wm-tr.wm-row-hl) { background: var(--bg-hover); }
:global(.wm-tr td) { padding: 4px 8px; font-size: 10px; border-bottom: none; }
:global(.wm-td-count) { text-align: right; color: var(--text-muted); width: 36px; }
:global(.wm-country.wm-path-hl) { filter: brightness(0.9); }
#wm-modal-map {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  padding: 50px 25px 50px 15px;
}
:global(#wm-modal-map svg) {
  width: 100%;
  height: auto;
  display: block;
}
.wm-close-btn {
  position: absolute;
  top: 8px;
  right: 10px;
  background: none;
  border: none;
  font-size: 20px;
  cursor: pointer;
  color: var(--text-muted);
  line-height: 1;
  z-index: 2;
}
.wm-close-btn:hover { color: var(--text); }
#wm-modal-tip {
  display: none;
  position: fixed;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 2px 6px;
  pointer-events: none;
  z-index: 1001;
  white-space: nowrap;
  font-size: 10px;
  color: var(--text);
  flex-direction: row;
  gap: 10px;
}
</style>

<script is:inline>
  (function () {
    var userBase = document.getElementById('dashboard-wrapper')?.dataset.userBase || '';

    function esc(s) {
      return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function attachDashQueueRemove(btn) {
      if (!btn) return;
      btn.addEventListener('click', async function (e) {
        e.preventDefault();
        e.stopPropagation();
        var albumId = btn.dataset.albumId;
        if (!albumId) return;
        var row = btn.closest('.dash-queue-row');
        var albumName = (row && row.querySelector('.dash-album-text') && row.querySelector('.dash-album-text').textContent) || 'this album';
        var coverEl = row && row.querySelector('img.dash-cover');
        var coverUrl = coverEl ? coverEl.src : null;
        var ok = await window.showConfirm(
          'Remove ' + albumName + ' from your queue?', 'Remove',
          { albumName: albumName !== 'this album' ? albumName : undefined, coverUrl: coverUrl || undefined }
        );
        if (!ok) return;
        btn.disabled = true;
        var res = await fetch('/api/album/' + albumId, { method: 'DELETE' });
        if (res.ok) {
          if (row) row.remove();
        } else {
          btn.disabled = false;
        }
      });
    }

    document.querySelectorAll('.dash-queue-remove').forEach(attachDashQueueRemove);

    document.querySelectorAll('.dash-queue-add-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (!window.showQueueAdd) return;
        var wrapper = btn.closest('.dash-grid-wrapper');
        window.showQueueAdd(function (album) {
          if (!wrapper) return;
          var section = wrapper.querySelector('.dash-section');
          if (!section) return;

          var emptyEl = section.querySelector('.dash-empty');
          if (emptyEl) emptyEl.remove();

          var list = section.querySelector('.dash-list');
          if (!list) {
            list = document.createElement('div');
            list.className = 'dash-list';
            section.appendChild(list);
          }

          var TYPE_LABELS = { lp:'LP', ep:'EP', compilation:'Compilation', demo:'Demo', single:'Single', other:'Other' };
          var typeChip  = album.releaseType ? '<span class="type-chip">' + (TYPE_LABELS[album.releaseType] || esc(album.releaseType)) + '</span>' : '';
          var yearChip  = album.year        ? '<span class="year-chip">'  + esc(album.year)  + '</span>' : '';
          var coverHtml = album.coverUrl
            ? '<img class="dash-cover" src="' + esc(album.coverUrl) + '" alt="" loading="lazy" />'
            : '<div class="dash-cover dash-cover-empty"></div>';
          var albumId   = String(album.albumId || '');

          var userTz = (document.getElementById('dashboard-wrapper') || {}).dataset?.tz || 'UTC';
          var dtParts = new Intl.DateTimeFormat('en-US', {
            timeZone: userTz, month: 'numeric', day: 'numeric', year: '2-digit',
            hour: '2-digit', minute: '2-digit', hourCycle: 'h23',
          }).formatToParts(new Date());
          var dget = function(t) { return (dtParts.find(function(p){ return p.type===t; }) || {}).value || ''; };
          var addedAtStr = dget('month')+'/'+dget('day')+'/'+dget('year')+' '+dget('hour')+':'+dget('minute');

          var row = document.createElement('div');
          row.className = 'dash-row dash-queue-row';
          row.dataset.albumId = albumId;
          row.innerHTML =
            '<a href="' + esc(userBase + '/album/' + album.slug) + '" class="dash-queue-row-link">' +
              coverHtml +
              '<div class="dash-info">' +
                '<div class="dash-album-wrap">' +
                  typeChip +
                  '<span class="dash-album"><span class="dash-album-text">' + esc(album.title) + '</span></span>' +
                  yearChip +
                '</div>' +
                '<span class="dash-artist-name"><span class="dash-artist-text">' + esc(album.artist) + '</span></span>' +
              '</div>' +
            '</a>' +
            '<div class="dash-queue-remove-wrap">' +
              '<button class="dash-queue-remove tip-left" data-album-id="' + esc(albumId) + '" type="button" aria-label="Remove from queue" data-tip="Remove from queue">×</button>' +
              '<span class="dash-logged-date">' + addedAtStr + '</span>' +
            '</div>';

          list.insertBefore(row, list.firstChild);
          attachDashQueueRemove(row.querySelector('.dash-queue-remove'));
        });
      });
    });
  })();
</script>

<script is:inline define:vars={{ libBase, hasMapData, isoToRaw }}>
  (function () {
    if (!hasMapData) return;
    var svg      = document.getElementById('world-map-svg');
    var tip      = document.getElementById('wm-tip');
    var modal    = document.getElementById('wm-modal');
    var modalMap = document.getElementById('wm-modal-map');
    var modalTip = document.getElementById('wm-modal-tip');
    var expandBtn = document.getElementById('wm-expand');
    var closeBtn  = document.getElementById('wm-close');
    if (!svg || !tip || !modal) return;

    function posTip(e, el) {
      var x = e.clientX + 14, y = e.clientY + 14;
      el.style.left = x + 'px'; el.style.top = y + 'px';
      var r = el.getBoundingClientRect();
      if (r.right  > window.innerWidth  - 8) el.style.left = (e.clientX - r.width  - 8) + 'px';
      if (r.bottom > window.innerHeight - 8) el.style.top  = (e.clientY - r.height - 8) + 'px';
    }

    // Mini dashboard map — tooltip + click only, no table cross-link
    function attachCountries(svgEl, tipEl) {
      svgEl.querySelectorAll('.wm-country[data-v]:not([data-v="0"])').forEach(function (path) {
        path.addEventListener('mouseenter', function (e) {
          var name  = path.getAttribute('data-name')  || '';
          var count = path.getAttribute('data-count') || '0';
          tipEl.innerHTML =
            '<span class="wm-tip-country">' + name + '</span>' +
            '<span class="wm-tip-count">'   + count + '</span>';
          tipEl.style.display = 'flex';
          posTip(e, tipEl);
        });
        path.addEventListener('mousemove', function (e) { posTip(e, tipEl); });
        path.addEventListener('mouseleave', function () { tipEl.style.display = 'none'; });
        path.addEventListener('click', function () {
          var raw = path.getAttribute('data-country') || '';
          if (raw) window.location.href = libBase + '?country=' + encodeURIComponent(raw);
        });
      });
    }

    // Modal map — tooltip + click + table row cross-highlight
    function attachCountriesModal(svgEl, tipEl) {
      svgEl.querySelectorAll('.wm-country[data-v]:not([data-v="0"])').forEach(function (path) {
        var iso = path.getAttribute('data-iso') || '';
        path.addEventListener('mouseenter', function (e) {
          var name  = path.getAttribute('data-name')  || '';
          var count = path.getAttribute('data-count') || '0';
          tipEl.innerHTML =
            '<span class="wm-tip-country">' + name + '</span>' +
            '<span class="wm-tip-count">'   + count + '</span>';
          tipEl.style.display = 'flex';
          posTip(e, tipEl);
          var row = document.querySelector('#wm-modal-tbody tr[data-iso="' + iso + '"]');
          if (row) { row.classList.add('wm-row-hl'); row.scrollIntoView({ block: 'nearest' }); }
        });
        path.addEventListener('mousemove', function (e) { posTip(e, tipEl); });
        path.addEventListener('mouseleave', function () {
          tipEl.style.display = 'none';
          var row = document.querySelector('#wm-modal-tbody tr[data-iso="' + iso + '"]');
          if (row) row.classList.remove('wm-row-hl');
        });
        path.addEventListener('click', function () {
          var raw = path.getAttribute('data-country') || '';
          if (raw) window.location.href = libBase + '?country=' + encodeURIComponent(raw);
        });
      });
    }

    function buildModalTable(modalSvg) {
      var tbody = document.getElementById('wm-modal-tbody');
      var ths   = document.querySelectorAll('#wm-modal-table .wm-th');
      if (!tbody) return;

      var countries = [];
      svg.querySelectorAll('.wm-country[data-v]:not([data-v="0"])').forEach(function (path) {
        countries.push({
          iso:   path.getAttribute('data-iso')     || '',
          name:  path.getAttribute('data-name')    || '',
          count: parseInt(path.getAttribute('data-count') || '0', 10),
          raw:   path.getAttribute('data-country') || ''
        });
      });

      var sortKey = 'count';
      var sortDir = 'desc';

      function syncHeaders() {
        ths.forEach(function (th) {
          var k = th.getAttribute('data-sort');
          var active = k === sortKey;
          th.classList.toggle('wm-th-active', active);
          if (active) th.setAttribute('data-dir', sortDir);
          else th.removeAttribute('data-dir');
        });
      }

      function renderRows() {
        var sorted = countries.slice().sort(function (a, b) {
          if (sortKey === 'name') {
            var cmp = a.name.localeCompare(b.name);
            return sortDir === 'asc' ? cmp : -cmp;
          }
          return sortDir === 'asc' ? a.count - b.count : b.count - a.count;
        });
        tbody.innerHTML = '';
        sorted.forEach(function (c) {
          var tr = document.createElement('tr');
          tr.className = 'wm-tr';
          tr.setAttribute('data-iso', c.iso);
          var tdName = document.createElement('td');
          tdName.textContent = c.name;
          var tdCount = document.createElement('td');
          tdCount.className = 'wm-td-count';
          tdCount.textContent = String(c.count);
          tr.appendChild(tdName);
          tr.appendChild(tdCount);

          tr.addEventListener('mouseenter', function () {
            modalSvg.querySelectorAll('.wm-country[data-iso="' + c.iso + '"]').forEach(function (p) {
              p.classList.add('wm-path-hl');
            });
          });
          tr.addEventListener('mouseleave', function () {
            modalSvg.querySelectorAll('.wm-country.wm-path-hl').forEach(function (p) {
              p.classList.remove('wm-path-hl');
            });
          });
          tr.addEventListener('click', function () {
            if (c.raw) window.location.href = libBase + '?country=' + encodeURIComponent(c.raw);
          });

          tbody.appendChild(tr);
        });
      }

      ths.forEach(function (th) {
        th.addEventListener('click', function () {
          var k = th.getAttribute('data-sort');
          if (k === sortKey) {
            sortDir = sortDir === 'asc' ? 'desc' : 'asc';
          } else {
            sortKey = k;
            sortDir = k === 'count' ? 'desc' : 'asc';
          }
          syncHeaders();
          renderRows();
        });
      });

      syncHeaders();
      renderRows();
    }

    attachCountries(svg, tip);

    if (expandBtn) {
      expandBtn.addEventListener('click', function () {
        if (!modalMap) return;
        if (!modalMap.firstChild) {
          var clone = svg.cloneNode(true);
          clone.removeAttribute('id');
          clone.style.maxWidth = 'none';
          clone.style.width = '100%';
          modalMap.appendChild(clone);
          var modalSvg = modalMap.querySelector('svg');
          attachCountriesModal(modalSvg, modalTip);
          buildModalTable(modalSvg);
        }
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      });
    }

    function closeModal() {
      modal.style.display = 'none';
      document.body.style.overflow = '';
      if (modalTip) modalTip.style.display = 'none';
    }

    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.style.display !== 'none') closeModal();
    });
  })();
</script>

<script is:inline>
  (function () {
    var tip = document.getElementById('hm-tip');
    if (tip) {
      function positionTip(e) {
        var x = e.clientX + 12, y = e.clientY + 12;
        tip.style.left = x + 'px';
        tip.style.top  = y + 'px';
        var r = tip.getBoundingClientRect();
        if (r.right  > window.innerWidth  - 8) tip.style.left = (e.clientX - r.width  - 8) + 'px';
        if (r.bottom > window.innerHeight - 8) tip.style.top  = (e.clientY - r.height - 8) + 'px';
      }
      document.querySelectorAll('.hm-cell[data-hm]').forEach(function (cell) {
        cell.addEventListener('mouseenter', function (e) {
          var parts = (cell.getAttribute('data-hm') || '').split('|');
          tip.innerHTML =
            '<span class="hmt-date">'  + parts[0] + '</span>' +
            (parts[1] ? '<span class="hmt-count">' + parts[1] + '</span>' : '') +
            (parts[2] ? '<span class="hmt-time">'  + parts[2] + '</span>' : '');
          tip.style.display = 'flex';
          positionTip(e);
        });
        cell.addEventListener('mousemove', positionTip);
        cell.addEventListener('mouseleave', function () { tip.style.display = 'none'; });
      });
    }
  })();

</script>
