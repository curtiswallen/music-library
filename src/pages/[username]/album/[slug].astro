---
import Layout from '../../../layouts/Layout.astro';
import AlbumForm from '../../../components/AlbumForm.astro';
import { env } from 'cloudflare:workers';
import type { Album, UserAlbum, Track } from '../../../types';
import { slugify, generateUniqueSlug, countryCode } from '../../../lib/utils';
import { md } from '../../../lib/markdown';
import { getGenreCache } from '../../../lib/genre-cache';
import { invalidateLibraryOverview } from '../../../lib/library-cache';

const { username, slug: slugParam } = Astro.params;
if (!username || !slugParam) return new Response(null, { status: 404 });

const db = env.DB;
const kv = env.GENRE_CACHE;

const profileUser = await db.prepare(`
  SELECT id, username, display_name, profile_url, is_private, hide_added_at, avatar_url
  FROM users WHERE profile_url = ?
`).bind(username).first<{
  id: number; username: string; display_name: string | null;
  profile_url: string; is_private: number; hide_added_at: number; avatar_url: string | null;
}>();

if (!profileUser) return new Response(null, { status: 404 });

const loggedInUser = Astro.locals.user;
const isOwner      = loggedInUser?.id === profileUser.id;

if (profileUser.is_private && !isOwner) return Astro.redirect(`/${username}`);

// ── POST: save edits ──────────────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  if (!isOwner) return new Response('Forbidden', { status: 403 });

  const data      = await Astro.request.formData();
  const artist    = (data.getAll('artist') as string[]).map(s => s.trim()).filter(Boolean).join(' / ') || '';
  const albumName = (data.get('album') as string) || '';

  const existing = await db.prepare('SELECT id FROM albums WHERE slug = ?')
    .bind(slugParam).first<{ id: number }>();
  if (!existing) return Astro.redirect(`/${profileUser.profile_url}`);

  const subgenres = JSON.stringify(
    ((data.get('subgenres') as string) ?? '').split(',').map(s => s.trim()).filter(Boolean)
  );

  let descriptorsList: string[] = [];
  try { descriptorsList = JSON.parse((data.get('descriptors') as string) || '[]'); } catch {}
  const newDescriptors = descriptorsList.map(d => d.trim().toLowerCase()).filter(Boolean);
  const descriptorsJson = JSON.stringify(newDescriptors);
  if (newDescriptors.length) {
    await db.batch(newDescriptors.map(d =>
      db.prepare('INSERT OR IGNORE INTO descriptors (name) VALUES (?)').bind(d)
    ));
  }

  let rawTracks: Array<Record<string, unknown>> = [];
  try { rawTracks = JSON.parse((data.get('tracks') as string) || '[]'); } catch {}

  const canonicalTracks = JSON.stringify(rawTracks.map(t => ({
    pos: t.pos, title: t.title, length: t.length ?? null,
  })));
  const tracksData = JSON.stringify(rawTracks.map(t => ({
    pos: t.pos, rating: t.rating ?? null, notable: t.notable ?? false, note: t.note ?? '',
  })));

  const newSlug = await generateUniqueSlug(db, artist, albumName, existing.id);

  await db.prepare(`
    UPDATE albums SET
      artist = ?, album = ?, country = ?, year = ?,
      slug = ?, cover_url = ?, mbid = ?, tracks = ?
    WHERE id = ?
  `).bind(
    artist, albumName,
    (data.get('country') as string) || '',
    data.get('year') ? parseInt(data.get('year') as string) : null,
    newSlug,
    (data.get('cover_url') as string) || null,
    (data.get('mbid') as string) || null,
    canonicalTracks,
    existing.id,
  ).run();

  await db.prepare(`
    UPDATE user_albums SET
      genre = ?, subgenres = ?, rating = ?, notes = ?,
      tracks_data = ?, recommended = ?, is_hidden = ?,
      release_mbid = ?, release_title = ?, release_data = ?, descriptors = ?
    WHERE album_id = ? AND user_id = ?
  `).bind(
    (data.get('genre') as string) || '',
    subgenres,
    data.get('rating') ? parseInt(data.get('rating') as string) : null,
    (data.get('notes') as string) || '',
    tracksData,
    data.get('recommended') === 'on' ? 1 : 0,
    data.get('is_hidden') === 'on' ? 1 : 0,
    (data.get('release_mbid') as string) || null,
    (data.get('release_title') as string) || null,
    (data.get('release_data') as string) || null,
    descriptorsJson,
    existing.id,
    profileUser.id,
  ).run();

  await db.prepare(`
    UPDATE albums SET
      all_subgenres  = COALESCE((SELECT json_group_array(value) FROM (SELECT DISTINCT value FROM user_albums, json_each(user_albums.subgenres)  WHERE user_albums.album_id = ?)), '[]'),
      all_descriptors = COALESCE((SELECT json_group_array(value) FROM (SELECT DISTINCT value FROM user_albums, json_each(user_albums.descriptors) WHERE user_albums.album_id = ?)), '[]')
    WHERE id = ?
  `).bind(existing.id, existing.id, existing.id).run();

  await invalidateLibraryOverview(env.GENRE_CACHE, profileUser.id);

  return Astro.redirect(`/${profileUser.profile_url}/album/${newSlug}`);
}

// ── GET: fetch album + user data ──────────────────────────────────────────────
const row = await db.prepare(`
  SELECT
    a.id, a.mbid, a.slug, a.artist, a.album, a.country, a.year, a.cover_url, a.tracks,
    a.logged_by_user_ids, a.all_subgenres, a.all_descriptors,
    ua.id as ua_id, ua.genre, ua.subgenres, ua.rating, ua.notes,
    ua.tracks_data, ua.recommended, ua.is_hidden, ua.added_at,
    ua.release_mbid, ua.release_title, ua.release_data, ua.descriptors
  FROM albums a
  JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
  WHERE a.slug = ?
`).bind(profileUser.id, slugParam).first<Album & UserAlbum & { tracks_data: string; is_hidden: number; added_at: string; logged_by_user_ids: string; all_subgenres: string; all_descriptors: string }>();

if (!row) return new Response(null, { status: 404 });
if (row.is_hidden && !isOwner) return new Response(null, { status: 404 });

const album       = row;
const subgenres:   string[] = JSON.parse(album.subgenres  || '[]');
const descriptors: string[] = (JSON.parse(album.descriptors || '[]') as string[])
  .sort((a, b) => a.localeCompare(b, undefined, { sensitivity: 'base' }));
const allSubgenres:  string[] = JSON.parse(album.all_subgenres  || '[]');
const allDescriptors: string[] = (JSON.parse(album.all_descriptors || '[]') as string[])
  .sort((a, b) => a.localeCompare(b));
const mySubSet  = new Set(subgenres);
const myDescSet = new Set(descriptors);

interface ReleaseInfo {
  format: string; date: string; country: string; disambiguation: string;
  barcode: string; trackCount: number;
  labels: Array<{ name: string; catalog: string }>;
}
let releaseInfo: ReleaseInfo | null = null;
try { if (album.release_data) releaseInfo = JSON.parse(album.release_data) as ReleaseInfo; } catch {}

type CanonTrack = { pos: number; title: string; length: number | null; rating?: number | null; notable?: boolean; note?: string };
type AnnoTrack  = { pos: number; rating: number | null; notable?: boolean; note: string };

let rawCanon: CanonTrack[] = [];
let rawAnno:  AnnoTrack[]  = [];
try { rawCanon = JSON.parse(album.tracks || '[]'); } catch {}
try { rawAnno  = JSON.parse(album.tracks_data || '[]'); } catch {}

const annoMap = new Map(rawAnno.map(t => [t.pos, t]));
const albumTracks: Track[] = rawCanon.map(t => {
  const a = annoMap.get(t.pos);
  return {
    pos:     t.pos,
    title:   t.title,
    length:  t.length ?? null,
    rating:  a ? (a.rating ?? null)   : (t.rating  ?? null),
    notable: a ? (a.notable ?? false) : (t.notable ?? false),
    note:    a ? (a.note    ?? '')    : (t.note    ?? ''),
  };
});

function fmtLen(s: number | null): string {
  if (s == null) return '';
  return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
}
const totalAlbumLen = (() => {
  const t = albumTracks.reduce((sum, t) => sum + (t.length ?? 0), 0);
  if (!t) return '';
  const h = Math.floor(t / 3600), m = Math.floor((t % 3600) / 60), s = t % 60;
  return h ? `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`
           : `${m}:${String(s).padStart(2,'0')}`;
})();

function ratingClass(r: number | null) {
  if (r == null) return '';
  if (r >= 70) return 'rating-hi';
  if (r >= 50) return 'rating-mid';
  return 'rating-lo';
}

function sortSubs(subs: string[]) {
  return [...subs].sort((a, b) => a === 'Sketchy' ? -1 : b === 'Sketchy' ? 1 : 0);
}

const libBase      = `/${profileUser.profile_url}`;
const displayName  = profileUser.display_name || profileUser.username;
const artistParts  = album.artist.split(' / ').map(s => s.trim()).filter(Boolean);

const { results: artistAlbums } = await db.prepare(`
  SELECT a.id, a.slug, a.artist, a.album, a.country, a.year, a.cover_url,
         ua.subgenres, ua.rating, ua.recommended
  FROM albums a
  JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
  WHERE a.artist = ? AND a.id != ? ${isOwner ? '' : 'AND ua.is_hidden = 0'}
  ORDER BY a.year ASC NULLS LAST
`).bind(profileUser.id, album.artist, album.id).all<{
  id: number; slug: string; artist: string; album: string; country: string;
  year: number | null; cover_url: string | null; subgenres: string; rating: number | null; recommended: boolean;
}>();

const albumCountry = countryCode(album.country);
const { results: candidates } = await db.prepare(`
  SELECT a.id, a.slug, a.artist, a.album, a.country, a.year, a.cover_url,
         ua.subgenres, ua.rating, ua.recommended, ua.descriptors
  FROM albums a
  JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
  WHERE a.artist != ? AND ua.genre = ? ${isOwner ? '' : 'AND ua.is_hidden = 0'}
`).bind(profileUser.id, album.artist, album.genre ?? '').all<{
  id: number; slug: string; artist: string; album: string; country: string;
  year: number | null; cover_url: string | null; subgenres: string; rating: number | null;
  recommended: boolean; descriptors: string;
}>();

const similar = candidates
  .map(a => {
    const aSubs:  string[] = JSON.parse(a.subgenres   || '[]');
    const aDescs: string[] = JSON.parse(a.descriptors || '[]');
    const cMatch = albumCountry && countryCode(a.country) === albumCountry ? 1 : 0;
    const sMatch = subgenres.filter(s => aSubs.includes(s)).length;
    const dMatch = descriptors.filter(d =>
      aDescs.some(ad => ad.toLowerCase() === d.toLowerCase())
    ).length;
    const ratingBonus = (album.rating == null || a.rating == null) ? 0
      : (() => {
          const diff = Math.abs(album.rating - a.rating);
          return diff <= 10 ? 1 : diff <= 25 ? 0.5 : diff <= 40 ? 0 : -1;
        })();
    return { ...a, _score: cMatch + sMatch * 2 + dMatch * 3 + ratingBonus };
  })
  .filter(a => a._score >= 2)
  .sort((a, b) => b._score - a._score)
  .slice(0, 5);

const addedAt = album.added_at
  ? new Date(album.added_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : null;

// Only owners see the edit form — skip genre lookup for public visitors
let genreMap: Record<string, string[]> = {};
let groupedGenres: Array<{ group: string; options: string[] }> = [];
if (isOwner) {
  ({ genreMap, groupedGenres } = await getGenreCache(kv, db));
}

let otherLogs: Array<{ display_name: string | null; profile_url: string; avatar_url: string | null; rating: number | null }> = [];
const otherUserIds = (JSON.parse(album.logged_by_user_ids || '[]') as number[])
  .filter(uid => uid !== profileUser.id);
if (otherUserIds.length > 0) {
  const placeholders = otherUserIds.map(() => '?').join(', ');
  const { results } = await db.prepare(`
    SELECT u.display_name, u.profile_url, u.avatar_url, ua.rating
    FROM user_albums ua
    JOIN users u ON u.id = ua.user_id
    WHERE ua.album_id = ? AND ua.user_id IN (${placeholders})
      AND u.is_private = 0 AND ua.is_hidden = 0
    ORDER BY ua.added_at DESC
  `).bind(album.id, ...otherUserIds).all<{
    display_name: string | null; profile_url: string;
    avatar_url: string | null; rating: number | null;
  }>();
  otherLogs = results;
}

const otherRatings = otherLogs.map(l => l.rating).filter((r): r is number => r != null);
const allRatings = album.rating != null ? [album.rating, ...otherRatings] : otherRatings;
const communityAvg = allRatings.length > 1
  ? Math.round(allRatings.reduce((s, r) => s + r, 0) / allRatings.length)
  : null;

const notesHtml = album.notes ? md.parse(album.notes) as string : '';

if (!isOwner && !profileUser.is_private) {
  Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
}
---

<Layout title={`${album.artist} — ${album.album}`}>
  <div class="page-header">
    <div class="breadcrumb">
      <h1><a href={libBase}>{isOwner ? 'My Library' : `${displayName}'s Library`}</a></h1>
      <h1><span class="breadcrumb-sep">›</span></h1>
      <h1>
        {artistParts.map((p, i) => (
          <>{i > 0 && <span class="breadcrumb-sep"> / </span>}<a href={`${libBase}/artist/${slugify(p)}`}>{p}</a></>
        ))}
        {album.country && <span class="breadcrumb-tag" title={album.country}>{countryCode(album.country) ? countryCode(album.country).toUpperCase() : album.country}</span>}
      </h1>
      <h1><span class="breadcrumb-sep">›</span></h1>
      <h1><span class="breadcrumb-current">{album.album}</span></h1>
    </div>
    <div class="page-header-actions" style="display:flex;gap:8px">
      {isOwner && (
        <>
          <!-- View-mode buttons (hidden when editing) -->
          <button class="btn icon-btn view-mode-btn" id="edit-btn" aria-label="Edit" data-tip="Edit">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </button>
          <a href="/add" class="btn icon-btn view-mode-btn" aria-label="Add Album" data-tip="Add Album">+</a>
          <!-- Edit-mode buttons (shown when editing) -->
          <button class="btn btn-primary icon-btn edit-mode-btn" id="header-save-btn" aria-label="Save" data-tip="Save" style="display:none">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
          <button class="btn icon-btn edit-mode-btn" id="header-cancel-btn" aria-label="Discard changes" data-tip="Discard" style="display:none">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
          </button>
        </>
      )}
      {!isOwner && loggedInUser && (
        <a href={`/${loggedInUser.profile_url}`} class="btn">← My Library</a>
      )}
      {!isOwner && !loggedInUser && (
        <a href="/auth/login" class="btn">Sign In</a>
      )}
    </div>
  </div>

  <!-- ── View mode ── -->
  <div class="view-panel" id="view-panel">
    <div class="album-hero">
      <div class="cover-col">
        <div class="cover-box-lg">
          {album.cover_url && (
            <img src={album.cover_url} alt="" onerror="this.style.display='none'" />
          )}
        </div>
        {(releaseInfo || album.release_title) && (
          <div class="release-detail">
            {releaseInfo ? (
              <dl class="release-dl">
                {releaseInfo.format         && <><dt>Format</dt><dd>{releaseInfo.format}</dd></>}
                {releaseInfo.date           && <><dt>Released</dt><dd>{releaseInfo.date}</dd></>}
                {releaseInfo.country        && <><dt>Country</dt><dd>{releaseInfo.country}</dd></>}
                {releaseInfo.labels.map(l  => <><dt>Label</dt><dd>{l.name}{l.catalog ? ` — ${l.catalog}` : ''}</dd></>)}
                {releaseInfo.barcode        && <><dt>Barcode</dt><dd>{releaseInfo.barcode}</dd></>}
                {releaseInfo.disambiguation && <><dt>Edition</dt><dd>{releaseInfo.disambiguation}</dd></>}
              </dl>
            ) : (
              <p class="release-name">{album.release_title}</p>
            )}
          </div>
        )}
        {otherLogs.length > 0 && (
          <section class="also-logged">
            <p class="attr-label">Also Logged By</p>
            <div class="also-logged-list">
              {otherLogs.slice(0, 10).map(l => (
                <a href={`/${l.profile_url}/album/${slugParam}`} class="also-logged-item">
                  {l.avatar_url
                    ? <img src={l.avatar_url} class="also-logged-avatar" alt="" />
                    : <span class="also-logged-avatar also-logged-placeholder" />
                  }
                  <span class="also-logged-name">{l.display_name || l.profile_url}</span>
                  {l.rating != null && (
                    <span class={`rating ${ratingClass(l.rating)}`}>{l.rating}</span>
                  )}
                </a>
              ))}
            </div>
          </section>
        )}
      </div>
      <div class="album-meta">
        <div class="album-mobile-header">
          <p class="album-meta-artist">
            {artistParts.map((p, i) => (
              <>{i > 0 && <span> / </span>}<a href={`${libBase}/artist/${slugify(p)}`}>{p}</a></>
            ))}
          </p>
          <p class="album-meta-title">{album.album}</p>
        </div>
        <div class="album-upper-wrapper">
          <div class="album-header">
            <div class="album-attrs">
              {album.year && <span>{album.year}</span>}
              {album.genre && <span class="album-genre-label">{album.genre}</span>}
              {album.rating != null && (
                <span class={`rating ${ratingClass(album.rating)}`}>{album.rating} / 100</span>
              )}
              {album.recommended ? <span class="rec-star" title="Recommended">★</span> : null}
              {isOwner && album.is_hidden ? (
                <span class="hidden-eye" title="Hidden from public profile">
                  <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                    <path d="m6.72 6.72a3 3 0 0 0 4.24 4.24"/>
                    <line x1="1" y1="1" x2="23" y2="23"/>
                  </svg>
                </span>
              ) : null}
              {otherLogs.length > 0 && (
                <span class="community-stat">
                  {otherLogs.length} other{otherLogs.length !== 1 ? 's' : ''}
                  {communityAvg != null && <> · avg <span class={`rating ${ratingClass(communityAvg)}`}>{communityAvg}</span></>}
                </span>
              )}
            </div>
            {allSubgenres.length > 0 && (
              <div class="album-tags">
                {sortSubs(allSubgenres).map(s => (
                  <span class={`tag${s === 'Sketchy' ? ' tag-sketchy' : ''}${!mySubSet.has(s) ? ' tag-others' : ''}`}>{s}</span>
                ))}
              </div>
            )}
            {allDescriptors.length > 0 && (
              <div class="album-tags">
                {allDescriptors.map(d => <span class={`tag descriptor-tag${!myDescSet.has(d) ? ' tag-others' : ''}`}>{d}</span>)}
              </div>
            )}
          </div>
        </div>
  
        {notesHtml && (
          <div>
            <p class="attr-label">Notes</p>
            <div class="album-notes prose" set:html={notesHtml} />
          </div>
        )}
        {addedAt && (isOwner || !profileUser.hide_added_at) && (
          <p class="added-at">Logged on {addedAt}</p>
        )}
      </div>

    {albumTracks.length > 0 && (
      <div class="tracks-wrap" style="margin-top:16px">
        <p class="attr-label" style="margin-bottom:6px">Tracks</p>
        <table class="tracks-table">
          <thead>
            <tr>
              <th class="track-num">#</th>
              <th class="track-title">Title</th>
              <th class="track-len">Length</th>
              <th class="track-rating-cell">Rating</th>
              <th>Note</th>
            </tr>
          </thead>
          <tbody>
            {albumTracks.map(t => (
              <tr>
                <td class="track-num">{t.pos}</td>
                <td>{t.notable && <span class="rec-star" title="Notable track">★ </span>}{t.title}</td>
                <td class="track-len">{fmtLen(t.length)}</td>
                <td class="track-rating-cell">
                  {t.rating != null
                    ? <span class={`rating ${ratingClass(t.rating)}`}>{t.rating}</span>
                    : <span style="color:var(--text-muted)">—</span>
                  }
                </td>
                <td class="track-note-cell">
                  {t.note}
                  {t.note && <span class="track-note-tip">{t.note}</span>}
                </td>
              </tr>
            ))}
          </tbody>
          {totalAlbumLen && (
            <tfoot>
              <tr class="tracks-total-row">
                <td class="track-num"></td><td></td>
                <td class="track-len tracks-total">{totalAlbumLen}</td>
                <td colspan="2"></td>
              </tr>
            </tfoot>
          )}
        </table>
      </div>
    )}

    <section class="related-section">
      {artistAlbums.length > 0 && (
        <div class="more-by">
          <p class="related-title">More by {album.artist} in {isOwner ? 'my' : `${displayName}'s`} library</p>
          <div class="table-wrap more-by-tbl">
            <table><tbody>
              {artistAlbums.map(a => {
                const aSubs: string[] = JSON.parse(a.subgenres || '[]');
                return (
                  <tr data-href={`${libBase}/album/${a.slug}`}>
                    <td style="width:44px">
                      <div class="cover-thumb" style="background:#000;overflow:hidden">
                        {a.cover_url && <img src={a.cover_url} alt="" loading="lazy"
                          style="width:100%;height:100%;object-fit:cover;display:block"
                          onerror="this.style.display='none'" />}
                      </div>
                    </td>
                    <td><a href={`${libBase}/album/${a.slug}`}>{a.album} {a.recommended ? <span class="rec-star" title="Recommended"> ★</span> : null}</a></td>
                    <td style="color:var(--text-muted)">{a.year ?? ''}</td>
                    <td><span class={`rating ${ratingClass(a.rating)}`}>{a.rating ?? '—'}</span></td>
                    <td>{sortSubs(aSubs).map(s => <span class={`tag${s === 'Sketchy' ? ' tag-sketchy' : ''}`}>{s}</span>)}</td>
                  </tr>
                );
              })}
            </tbody></table>
          </div>
        </div>
      )}

      {similar.length > 0 && (
        <div class="more-by">
          <p class="related-title">Similar albums in {isOwner ? 'my' : `${displayName}'s`} library</p>
          <div class="table-wrap similar-tbl">
            <table><tbody>
              {similar.map(a => {
                const aSubs: string[] = JSON.parse(a.subgenres || '[]');
                const cc = countryCode(a.country).toLowerCase();
                return (
                  <tr data-href={`${libBase}/album/${a.slug}`}>
                    <td style="width:44px">
                      <div class="cover-thumb" style="background:#000;overflow:hidden">
                        {a.cover_url && <img src={a.cover_url} alt="" loading="lazy"
                          style="width:100%;height:100%;object-fit:cover;display:block"
                          onerror="this.style.display='none'" />}
                      </div>
                    </td>
                    <td style="color:var(--text-muted)">{a.artist}</td>
                    <td>{cc && <span title={a.country} class="added-cell">{cc.toUpperCase()}</span>}</td>
                    <td>{a.album} {a.recommended ? <span class="rec-star" title="Recommended"> ★</span> : null}</td>
                    <td style="color:var(--text-muted)">{a.year ?? ''}</td>
                    <td><span class={`rating ${ratingClass(a.rating)}`}>{a.rating ?? '—'}</span></td>
                    <td class="related-tags">{sortSubs(aSubs).map(s => <span class={`tag${s === 'Sketchy' ? ' tag-sketchy' : ''}`}>{s}</span>)}</td>
                  </tr>
                );
              })}
            </tbody></table>
          </div>
        </div>
      )}
    </section>
  </div>
  </div>

  <!-- ── Edit mode (owner only) ── -->
  {isOwner && (
    <div class="edit-panel" id="edit-panel">
      <AlbumForm
        values={{
          mbid:          album.mbid,
          artist:        album.artist,
          album:         album.album,
          year:          album.year,
          country:       album.country,
          genre:         album.genre,
          subgenres,
          rating:        album.rating,
          notes:         album.notes,
          cover_url:     album.cover_url,
          tracks:        JSON.stringify(albumTracks),
          recommended:   album.recommended,
          is_hidden:     album.is_hidden,
          release_mbid:  album.release_mbid,
          release_title: album.release_title,
          release_data:  album.release_data,
          descriptors,
        }}
        submitLabel="Save Changes"
        genreMap={genreMap}
        groupedGenres={groupedGenres}
        deleteAlbumId={album.id}
        deleteBackHref={libBase}
      />
    </div>
  )}
</Layout>

<script>
import { initAlbumForm, populateReleaseSelect } from '../../../lib/album-form';

initAlbumForm();

function enterEditMode() {
  document.getElementById('view-panel')!.classList.add('hidden');
  document.getElementById('edit-panel')!.classList.add('visible');
  document.querySelectorAll<HTMLElement>('.view-mode-btn').forEach(el => el.style.display = 'none');
  document.querySelectorAll<HTMLElement>('.edit-mode-btn').forEach(el => el.style.display = '');

  const mbid = (document.getElementById('f-mbid') as HTMLInputElement | null)?.value;
  const currentReleaseMbid = (document.getElementById('f-release-mbid') as HTMLInputElement | null)?.value ?? '';
  if (mbid) {
    fetch(`/api/musicbrainz-releases?rgId=${encodeURIComponent(mbid)}`)
      .then(r => r.json())
      .then(data => {
        populateReleaseSelect(data as Array<{ id: string; label: string; data?: unknown }>, currentReleaseMbid);
      })
      .catch(() => {});
  }
}

function exitEditMode() {
  document.getElementById('edit-panel')!.classList.remove('visible');
  document.getElementById('view-panel')!.classList.remove('hidden');
  document.querySelectorAll<HTMLElement>('.view-mode-btn').forEach(el => el.style.display = '');
  document.querySelectorAll<HTMLElement>('.edit-mode-btn').forEach(el => el.style.display = 'none');
}

async function deleteAlbum(id: string, back: string) {
  if (!confirm('Remove this album from your library? This cannot be undone.')) return;
  await fetch(`/api/album/${id}`, { method: 'DELETE' });
  window.location.href = back;
}

document.getElementById('edit-btn')?.addEventListener('click', enterEditMode);
document.getElementById('header-save-btn')?.addEventListener('click', () => {
  const form = document.getElementById('album-form') as HTMLFormElement | null;
  form?.requestSubmit();
});
document.getElementById('header-cancel-btn')?.addEventListener('click', exitEditMode);
document.getElementById('cancel-btn')?.addEventListener('click', exitEditMode);
document.getElementById('form-delete-btn')?.addEventListener('click', e => {
  const btn = e.currentTarget as HTMLElement;
  deleteAlbum(btn.dataset.id!, btn.dataset.back ?? '/');
});

document.querySelectorAll<HTMLTableRowElement>('tr[data-href]').forEach(tr => {
  tr.addEventListener('click', e => {
    if ((e.target as Element).closest('a')) return;
    window.location.href = tr.dataset.href!;
  });
});

if (window.matchMedia('(max-width: 640px)').matches) {
  const allTips = () => document.querySelectorAll<HTMLElement>('.track-note-tip');
  document.querySelectorAll<HTMLElement>('.track-note-cell').forEach(cell => {
    const tip = cell.querySelector<HTMLElement>('.track-note-tip');
    if (!tip) return;
    cell.addEventListener('click', e => {
      e.stopPropagation();
      const wasOpen = tip.style.display === 'block';
      allTips().forEach(t => { t.style.display = 'none'; });
      if (!wasOpen) {
        const r = cell.getBoundingClientRect();
        tip.style.top = (r.bottom + 4) + 'px';
        tip.style.display = 'block';
      }
    });
  });
  document.addEventListener('click', () => {
    allTips().forEach(t => { t.style.display = 'none'; });
  });
}
</script>
