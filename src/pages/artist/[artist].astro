---
import Layout from '../../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import { slugify, countryCode } from '../../lib/utils';
import type { ArtistRow, MembersData } from '../../lib/artist-cache';
import ArtistInfoPanel from '../../components/ArtistInfoPanel.astro';

const { artist: artistSlug } = Astro.params;
if (!artistSlug) return new Response(null, { status: 404 });

const db = env.DB;

const { results: allArtists } = await db.prepare(`
  SELECT DISTINCT a.artist FROM albums a WHERE a.public_entry_count > 0
`).all<{ artist: string }>();

let artistName: string | undefined;
for (const row of allArtists) {
  const parts = row.artist.split(' / ').map((s: string) => s.trim());
  const match = parts.find(p => slugify(p) === artistSlug);
  if (match) { artistName = match; break; }
}
if (!artistName) return new Response(null, { status: 404 });

const { results: albums } = await db.prepare(`
  SELECT a.id, a.slug, a.artist, a.album, a.country, a.year, a.cover_url, a.artist_mbid, a.release_type,
         ROUND(a.avg_rating, 1) as avg_rating, a.rating_count, a.genre_counts, a.all_subgenres
  FROM albums a
  WHERE (
    a.artist = ?
    OR a.artist LIKE ? || ' / %'
    OR a.artist LIKE '% / ' || ?
    OR a.artist LIKE '% / ' || ? || ' / %'
  )
  AND a.public_entry_count > 0
  ORDER BY a.year ASC NULLS LAST
`).bind(artistName, artistName, artistName, artistName).all<{
  id: number; slug: string; artist: string; album: string; country: string;
  year: number | null; cover_url: string | null; artist_mbid: string | null; release_type: string | null;
  avg_rating: number | null; rating_count: number; genre_counts: string; all_subgenres: string;
}>();

if (albums.length === 0) return new Response(null, { status: 404 });

const albumMbid = albums.find(a => a.artist_mbid)?.artist_mbid ?? null;

const TYPE_ORDER: { type: string | null; label: string }[] = [
  { type: 'lp',          label: 'LP'          },
  { type: 'ep',          label: 'EP'          },
  { type: 'single',      label: 'Single'      },
  { type: 'compilation', label: 'Compilation' },
  { type: 'demo',        label: 'Demo'        },
  { type: null,          label: 'Other'       },
];

const albumsByType = TYPE_ORDER.map(({ type, label }) => ({
  label,
  albums: type === null
    ? albums.filter(a => !a.release_type || a.release_type === 'other')
    : albums.filter(a => a.release_type === type),
})).filter(s => s.albums.length > 0);

const multipleTypes = albumsByType.length > 1;

let artistRow: ArtistRow | null = null;
let membersData: MembersData = { current: [], original: [], former: [], isPersonOf: [] };
// Name-first lookup prevents MBID cross-contamination on split albums
artistRow = await db.prepare('SELECT * FROM artists WHERE name = ?')
  .bind(artistName).first<ArtistRow>();
if (!artistRow && albumMbid) {
  artistRow = await db.prepare('SELECT * FROM artists WHERE mbid = ?')
    .bind(albumMbid).first<ArtistRow>();
}
const artistMbid = artistRow?.mbid ?? albumMbid;
if (artistRow) {
  try { membersData = JSON.parse(artistRow.members_data) as MembersData; } catch {}
}

const knownAliasMap = new Map<string, string[]>();
const regularMemberMbids = [...new Set(
  [...membersData.current, ...membersData.original, ...membersData.former]
    .map(m => m.mbid).filter((id): id is string => !!id)
)];
if (regularMemberMbids.length > 0) {
  const placeholders = regularMemberMbids.map(() => '?').join(', ');
  const { results: aliasRows } = await db.prepare(
    `SELECT DISTINCT person_mbid, person_name FROM artist_members WHERE person_mbid IN (${placeholders}) AND canonical_name IS NOT NULL`
  ).bind(...regularMemberMbids).all<{ person_mbid: string; person_name: string }>();
  for (const row of aliasRows) {
    const existing = knownAliasMap.get(row.person_mbid) ?? [];
    if (!existing.includes(row.person_name)) existing.push(row.person_name);
    knownAliasMap.set(row.person_mbid, existing);
  }
}

const artistCountry = albums[0]?.country ?? null;
const locationStr = (() => {
  const loc = artistRow?.formation_location ?? null;
  if (!loc) return null;
  if (!artistCountry) return loc;
  const locLow     = loc.toLowerCase();
  const countryLow = artistCountry.toLowerCase();
  if (locLow === countryLow || locLow.endsWith(`, ${countryLow}`)) return loc;
  return `${loc}, ${artistCountry}`;
})();

const artistDateStr = artistRow
  ? [
      artistRow.inception && (artistRow.dissolution
        ? `${artistRow.inception}–${artistRow.dissolution}`
        : `${artistRow.inception}–present`),
      locationStr,
    ].filter(Boolean).join(' · ')
  : '';

const loggedInUser = Astro.locals.user;

let userHasArtist = false;
if (loggedInUser) {
  const check = await db.prepare(`
    SELECT 1 FROM user_albums ua
    JOIN albums a ON a.id = ua.album_id
    WHERE ua.user_id = ? AND (
      a.artist = ?
      OR a.artist LIKE ? || ' / %'
      OR a.artist LIKE '% / ' || ?
      OR a.artist LIKE '% / ' || ? || ' / %'
    ) LIMIT 1
  `).bind(loggedInUser.id, artistName, artistName, artistName, artistName).first();
  userHasArtist = !!check;
}

const fromParam = (Astro.url.searchParams.get('from') ?? '').replace(/[^a-z0-9-_]/gi, '');
const fromName  = (Astro.url.searchParams.get('fromName') ?? '').slice(0, 60);

const TYPE_LABELS: Record<string, string> = {
  lp: 'LP', ep: 'EP', compilation: 'Compilation', demo: 'Demo', single: 'Single', other: 'Other',
};

function ratingClass(r: number | null) {
  if (r == null) return '';
  if (r >= 70) return 'rating-hi';
  if (r >= 50) return 'rating-mid';
  return 'rating-lo';
}

function topGenre(genreCounts: string): string {
  try {
    const gc = JSON.parse(genreCounts || '{}') as Record<string, number>;
    const entries = Object.entries(gc);
    if (!entries.length) return '';
    return entries.sort((a, b) => b[1] - a[1])[0][0];
  } catch { return ''; }
}

Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
---

<Layout title={artistName}>
  <div class="page-header artist-header" slot="header">
    <div class="breadcrumb">
      <h1><a href="/">Music Library</a></h1>
      <h1><span class="breadcrumb-sep">›</span></h1>
      <h1>
        <span class="breadcrumb-current">{artistName}</span>
        {albums[0].country && (
          <span class="breadcrumb-tag tip-link" data-tip={albums[0].country}>
            {countryCode(albums[0].country) ? countryCode(albums[0].country).toUpperCase() : albums[0].country}
          </span>
        )}
      </h1>
      <span class="count" style="margin-left:4px">({albums.length} album{albums.length !== 1 ? 's' : ''})</span>
      {(fromParam || (loggedInUser && userHasArtist)) && (
        <div class="artist-view-toggle">
          {fromParam && <a href={`/${fromParam}/artist/${artistSlug}`}>{fromName || fromParam}'s</a>}
          {loggedInUser && userHasArtist && (
            <a href={`/${loggedInUser.profile_url}/artist/${artistSlug}${fromParam ? `?from=${fromParam}&fromName=${encodeURIComponent(fromName || fromParam)}` : ''}`}>mine</a>
          )}
          <span class="avc-active">community</span>
        </div>
      )}
    </div>
  </div>

  <h2 class="mobile-section-title">{artistName}</h2>

  {artistRow && (
    <ArtistInfoPanel
      artistRow={artistRow}
      membersData={membersData}
      artistName={artistName}
      artistMbid={artistMbid}
      knownAliasMap={knownAliasMap}
      artistDateStr={artistDateStr}
      isAdmin={!!loggedInUser?.is_admin}
    />
  )}

  {albumsByType.map(({ label, albums: group }) => (
    <div class="artist-type-section">
      <div class="table-wrap artist-tbl global-artist-tbl">
        <table>
          <thead>
            <tr>
              <th></th>
              <th>Album</th>
              <th>Year</th>
              <th>Genre</th>
              <th class="col-subgenres">Subgenres</th>
              <th>Avg Rating</th>
              <th># Ratings</th>
            </tr>
          </thead>
          <tbody>
            {group.map(a => {
              const genre = topGenre(a.genre_counts);
              const subs: string[] = (() => { try { return JSON.parse(a.all_subgenres || '[]') as string[]; } catch { return []; } })();
              const sorted = [...subs].sort((x, y) => x === 'Sketchy' ? -1 : y === 'Sketchy' ? 1 : 0);
              return (
                <tr data-href={`/album/${a.slug}`}>
                  <td>
                    <div class="cover-thumb" style="background:#000;overflow:hidden">
                      {a.cover_url && (
                        <img src={a.cover_url} alt="" loading="lazy"
                             style="width:100%;height:100%;object-fit:contain;display:block"
                             onerror="this.style.display='none'" />
                      )}
                    </div>
                  </td>
                  <td>
                    <a href={`/album/${a.slug}`}>
                      {a.year != null && <span class="year-chip col-album-year">{a.year}</span>}
                      {a.release_type && <span class="type-chip">{TYPE_LABELS[a.release_type] ?? a.release_type}</span>}
                      <span class="col-album-text">{a.album}</span>
                    </a>
                  </td>
                  <td>{a.year ?? ''}</td>
                  <td>{genre && <span class="genre">{genre}</span>}</td>
                  <td class="col-subgenres">
                    {sorted.map(s => (
                      <span class={`tag${s === 'Sketchy' ? ' tag-sketchy' : ''}`}>{s}</span>
                    ))}
                  </td>
                  <td><span class={`rating ${ratingClass(a.avg_rating)}`}>{a.avg_rating?.toFixed(1) ?? '—'}</span></td>
                  <td class="added-cell">{a.rating_count > 0 ? a.rating_count : '—'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  ))}
</Layout>

<script>
document.querySelectorAll<HTMLTableRowElement>('tr[data-href]').forEach(tr => {
  tr.addEventListener('click', e => {
    if ((e.target as Element).closest('a')) return;
    window.location.href = tr.dataset.href!;
  });
});
</script>
