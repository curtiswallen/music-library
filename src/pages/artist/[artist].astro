---
import Layout from '../../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import { slugify, countryCode } from '../../lib/utils';

const { artist: artistSlug } = Astro.params;
const user = Astro.locals.user!;
const db   = env.DB;

// Find artist name by matching slugified name
const { results: allArtists } = await db.prepare(`
  SELECT DISTINCT a.artist FROM albums a
  JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
`).bind(user.id).all<{ artist: string }>();

const artistName = allArtists.find(r => slugify(r.artist) === artistSlug)?.artist;
if (!artistName) return Astro.redirect('/');

const { results: albums } = await db.prepare(`
  SELECT a.id, a.slug, a.artist, a.album, a.country, a.year, a.cover_url,
         ua.genre, ua.subgenres, ua.rating, ua.notes, ua.recommended
  FROM albums a
  JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
  WHERE a.artist = ?
  ORDER BY a.year ASC NULLS LAST
`).bind(user.id, artistName).all<{
  id: number; slug: string; artist: string; album: string; country: string;
  year: number | null; cover_url: string | null;
  genre: string; subgenres: string; rating: number | null; notes: string; recommended: number;
}>();

function ratingClass(r: number | null) {
  if (r == null) return '';
  if (r >= 70) return 'rating-hi';
  if (r >= 50) return 'rating-mid';
  return 'rating-lo';
}
function sortedSubs(subs: string[]) {
  return [...subs].sort((a, b) => a === 'Sketchy' ? -1 : b === 'Sketchy' ? 1 : 0);
}
---

<Layout title={artistName}>
  <div class="page-header artist-header">
    <div class="breadcrumb">
      <h1><a href="/">Library</a></h1>
      <h1><span class="breadcrumb-sep">›</span></h1>
      <h1><span class="breadcrumb-current">{artistName} {countryCode(albums[0].country)
                  ? <span class={`fi fi-${countryCode(albums[0].country).toLowerCase()} country-flag`} title={albums[0].country} />
                  : <span style="color:var(--text-muted);font-size:11px">{albums[0].country}</span>
                }</span></h1>
      <span class="count" style="margin-left:4px">({albums.length} album{albums.length !== 1 ? 's' : ''})</span>
    </div>
    <a href="/add" class="btn">+ Add Album</a>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th></th>
          <th>Album</th>
          <th>Year</th>
          <th>Genre</th>
          <th>Subgenres</th>
          <th>Rating</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        {albums.map(a => {
          const subs: string[] = JSON.parse(a.subgenres || '[]');
          return (
            <tr data-href={`/album/${a.slug}`}>
              <td>
                <div class="cover-thumb" style="background:#000;overflow:hidden">
                  {a.cover_url && (
                    <img src={a.cover_url} alt="" loading="lazy"
                         style="width:100%;height:100%;object-fit:cover;display:block"
                         onerror="this.style.display='none'" />
                  )}
                </div>
              </td>
              <td><a href={`/album/${a.slug}`}>{a.album} {a.recommended ? <span class="rec-star" title="Recommended"> ★</span> : null}</a></td>
              <td>{a.year ?? ''}</td>
              <td>
                {a.genre && <span class="genre">{a.genre}</span>}
              </td>
              <td>
                {sortedSubs(subs).map(s => (
                  <span class={`tag${s === 'Sketchy' ? ' tag-sketchy' : ''}`}>{s}</span>
                ))}
              </td>
              <td><span class={`rating ${ratingClass(a.rating)}`}>{a.rating ?? '—'}</span></td>
              <td class="notes-cell" title={a.notes}>{a.notes}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
</Layout>

<script>
document.querySelectorAll<HTMLTableRowElement>('tr[data-href]').forEach(tr => {
  tr.addEventListener('click', e => {
    if ((e.target as Element).closest('a')) return;
    window.location.href = tr.dataset.href!;
  });
});
</script>
