---
import Layout from '../../layouts/Layout.astro';
import AlbumForm from '../../components/AlbumForm.astro';
import { env } from 'cloudflare:workers';
import type { Album, UserAlbum, Track } from '../../types';
import { slugify, generateUniqueSlug, countryCode } from '../../lib/utils';

const { slug: slugParam } = Astro.params;
if (!slugParam) return Astro.redirect('/');

const user = Astro.locals.user!;
const db   = env.DB;

// ── POST: save edits ──────────────────────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const data   = await Astro.request.formData();
  const artist = (data.get('artist') as string) || '';
  const albumName = (data.get('album') as string) || '';

  // Find album by current slug to get the id
  const existing = await db.prepare('SELECT id FROM albums WHERE slug = ?')
    .bind(slugParam).first<{ id: number }>();
  if (!existing) return Astro.redirect('/');

  const subgenres = JSON.stringify(
    ((data.get('subgenres') as string) ?? '').split(',').map(s => s.trim()).filter(Boolean)
  );

  let rawTracks: Array<Record<string, unknown>> = [];
  try { rawTracks = JSON.parse((data.get('tracks') as string) || '[]'); } catch {}

  const canonicalTracks = JSON.stringify(rawTracks.map(t => ({
    pos: t.pos, title: t.title, length: t.length ?? null,
  })));
  const tracksData = JSON.stringify(rawTracks.map(t => ({
    pos: t.pos, rating: t.rating ?? null, notable: t.notable ?? false, note: t.note ?? '',
  })));

  const newSlug = await generateUniqueSlug(db, artist, albumName, existing.id);

  await db.prepare(`
    UPDATE albums SET
      artist = ?, album = ?, country = ?, year = ?,
      slug = ?, cover_url = ?, mbid = ?, tracks = ?
    WHERE id = ?
  `).bind(
    artist,
    albumName,
    (data.get('country') as string) || '',
    data.get('year') ? parseInt(data.get('year') as string) : null,
    newSlug,
    (data.get('cover_url') as string) || null,
    (data.get('mbid') as string) || null,
    canonicalTracks,
    existing.id,
  ).run();

  await db.prepare(`
    UPDATE user_albums SET
      genre = ?, subgenres = ?, rating = ?, notes = ?,
      tracks_data = ?, recommended = ?, is_hidden = ?
    WHERE album_id = ? AND user_id = ?
  `).bind(
    (data.get('genre') as string) || '',
    subgenres,
    data.get('rating') ? parseInt(data.get('rating') as string) : null,
    (data.get('notes') as string) || '',
    tracksData,
    data.get('recommended') === 'on' ? 1 : 0,
    data.get('is_hidden') === 'on' ? 1 : 0,
    existing.id,
    user.id,
  ).run();

  return Astro.redirect(`/album/${newSlug}`);
}

// ── GET: fetch album + user data ──────────────────────────────────────────────
const row = await db.prepare(`
  SELECT
    a.id, a.mbid, a.slug, a.artist, a.album, a.country, a.year, a.cover_url, a.tracks,
    ua.id as ua_id, ua.genre, ua.subgenres, ua.rating, ua.notes,
    ua.tracks_data, ua.recommended, ua.is_hidden, ua.added_at
  FROM albums a
  JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
  WHERE a.slug = ?
`).bind(user.id, slugParam).first<Album & UserAlbum & { tracks_data: string; is_hidden: number; added_at: string }>();

if (!row) return Astro.redirect('/');

const album     = row;
const subgenres: string[] = JSON.parse(album.subgenres || '[]');

// Merge canonical tracks with per-user annotations
type CanonTrack = { pos: number; title: string; length: number | null; rating?: number | null; notable?: boolean; note?: string };
type AnnoTrack  = { pos: number; rating: number | null; notable?: boolean; note: string };

let rawCanon: CanonTrack[] = [];
let rawAnno:  AnnoTrack[]  = [];
try { rawCanon = JSON.parse(album.tracks || '[]'); } catch {}
try { rawAnno  = JSON.parse(album.tracks_data || '[]'); } catch {}

const annoMap = new Map(rawAnno.map(t => [t.pos, t]));
const albumTracks: Track[] = rawCanon.map(t => {
  const a = annoMap.get(t.pos);
  return {
    pos:     t.pos,
    title:   t.title,
    length:  t.length ?? null,
    rating:  a ? (a.rating ?? null)    : (t.rating  ?? null),
    notable: a ? (a.notable ?? false)  : (t.notable ?? false),
    note:    a ? (a.note    ?? '')     : (t.note    ?? ''),
  };
});

function fmtLen(s: number | null): string {
  if (s == null) return '';
  return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
}
const totalAlbumLen = (() => {
  const t = albumTracks.reduce((sum, t) => sum + (t.length ?? 0), 0);
  if (!t) return '';
  const h = Math.floor(t / 3600), m = Math.floor((t % 3600) / 60), s = t % 60;
  return h ? `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`
           : `${m}:${String(s).padStart(2,'0')}`;
})();

function ratingClass(r: number | null) {
  if (r == null) return '';
  if (r >= 70) return 'rating-hi';
  if (r >= 50) return 'rating-mid';
  return 'rating-lo';
}

function sortSubs(subs: string[]) {
  return [...subs].sort((a, b) => a === 'Sketchy' ? -1 : b === 'Sketchy' ? 1 : 0);
}
const sortedSubs = sortSubs(subgenres);

// Other albums by this artist (for current user)
const { results: artistAlbums } = await db.prepare(`
  SELECT a.id, a.slug, a.artist, a.album, a.country, a.year, a.cover_url,
         ua.subgenres, ua.rating, ua.recommended
  FROM albums a
  JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
  WHERE a.artist = ? AND a.id != ?
  ORDER BY a.year ASC NULLS LAST
`).bind(user.id, album.artist, album.id).all<{
  id: number; slug: string; artist: string; album: string; country: string;
  year: number | null; cover_url: string | null; subgenres: string; rating: number | null; recommended: boolean;
}>();

// Similar albums: ≥2 matching tags (subgenre or country)
const albumCountry = countryCode(album.country);
const { results: candidates } = await db.prepare(`
  SELECT a.id, a.slug, a.artist, a.album, a.country, a.year, a.cover_url,
         ua.subgenres, ua.rating, ua.recommended
  FROM albums a
  JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
  WHERE a.artist != ?
`).bind(user.id, album.artist).all<{
  id: number; slug: string; artist: string; album: string; country: string;
  year: number | null; cover_url: string | null; subgenres: string; rating: number | null; recommended: boolean;
}>();

const similar = candidates
  .map(a => {
    const aSubs: string[] = JSON.parse(a.subgenres || '[]');
    const cMatch = albumCountry && countryCode(a.country) === albumCountry ? 1 : 0;
    const sMatch = subgenres.filter(s => aSubs.includes(s)).length;
    return { ...a, _score: cMatch + sMatch };
  })
  .filter(a => a._score >= 2)
  .sort((a, b) => b._score - a._score)
  .slice(0, 5);

// Format date added
const addedAt = album.added_at
  ? new Date(album.added_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : null;
---

<Layout title={`${album.artist} — ${album.album}`}>
  <div class="page-header">
    <div class="breadcrumb">
      <h1><a href="/">Library</a></h1>
      <h1><span class="breadcrumb-sep">›</span></h1>
      <h1><a href={`/artist/${slugify(album.artist)}`}>{album.artist} {countryCode(album.country)
                  ? <span class={`fi fi-${countryCode(album.country).toLowerCase()} country-flag`} title={album.country} />
                  : <span style="color:var(--text-muted);font-size:11px">{album.country}</span>
                }</a></h1>
      <h1><span class="breadcrumb-sep">›</span></h1>
      <h1><span class="breadcrumb-current">{album.album} {album.recommended ? <span class="rec-star" title="Recommended"> ★</span> : null}</span></h1>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn" id="edit-btn">Edit</button>
      <button class="btn btn-danger" id="delete-btn" data-id={album.id}>Delete</button>
      <a href="/add" class="btn">+ Add Album</a>
    </div>
  </div>

  <!-- ── View mode ── -->
  <div class="view-panel" id="view-panel">
    <div class="album-hero">
      <div class="cover-box-lg">
        {album.cover_url && (
          <img src={album.cover_url} alt="" onerror="this.style.display='none'" />
        )}
      </div>
      <div class="album-meta">
        <div class="album-attrs">
          {album.year && <span>{album.year}</span>}
          {album.genre && <span class="album-genre-label">{album.genre}</span>}
          {album.rating != null && (
            <span class={`rating ${ratingClass(album.rating)}`}>{album.rating} / 100</span>
          )}
        </div>
        {sortedSubs.length > 0 && (
          <div class="album-tags">
            {sortedSubs.map(s => (
              <span class={`tag${s === 'Sketchy' ? ' tag-sketchy' : ''}`}>{s}</span>
            ))}
          </div>
        )}
        {album.notes && (
          <div>
            <p class="attr-label">Notes</p>
            <p class="album-notes">{album.notes}</p>
          </div>
        )}
        {addedAt && (
          <p class="added-at">Added {addedAt}</p>
        )}
        {albumTracks.length > 0 && (
          <div class="tracks-wrap" style="margin-top:16px">
            <p class="attr-label" style="margin-bottom:6px">Tracks</p>
            <table class="tracks-table">
              <thead>
                <tr>
                  <th class="track-num">#</th>
                  <th class="track-title">Title</th>
                  <th class="track-len">Length</th>
                  <th class="track-rating-cell">Rating</th>
                  <th>Note</th>
                </tr>
              </thead>
              <tbody>
                {albumTracks.map(t => (
                  <tr>
                    <td class="track-num">{t.pos}</td>
                    <td>{t.notable && <span class="rec-star" title="Notable track">★ </span>}{t.title}</td>
                    <td class="track-len">{fmtLen(t.length)}</td>
                    <td class="track-rating-cell">
                      {t.rating != null
                        ? <span class={`rating ${ratingClass(t.rating)}`}>{t.rating}</span>
                        : <span style="color:var(--text-muted)">—</span>
                      }
                    </td>
                    <td class="track-note-cell">{t.note}</td>
                  </tr>
                ))}
              </tbody>
              {totalAlbumLen && (
                <tfoot>
                  <tr class="tracks-total-row">
                    <td class="track-num"></td><td></td>
                    <td class="track-len tracks-total">{totalAlbumLen}</td>
                    <td colspan="2"></td>
                  </tr>
                </tfoot>
              )}
            </table>
          </div>
        )}

        <section class="related-section">
          {artistAlbums.length > 0 && (
            <div class="more-by">
              <p class="related-title">More by {album.artist}</p>
              <div class="table-wrap">
                <table><tbody>
                  {artistAlbums.map(a => {
                    const aSubs: string[] = JSON.parse(a.subgenres || '[]');
                    const cc = countryCode(a.country).toLowerCase();
                    return (
                      <tr data-href={`/album/${a.slug}`}>
                        <td style="width:44px">
                          <div class="cover-thumb" style="background:#000;overflow:hidden">
                            {a.cover_url && <img src={a.cover_url} alt="" loading="lazy"
                              style="width:100%;height:100%;object-fit:cover;display:block"
                              onerror="this.style.display='none'" />}
                          </div>
                        </td>
                        <td><a href={`/album/${a.slug}`}>{a.album} {a.recommended ? <span class="rec-star" title="Recommended"> ★</span> : null}</a></td>
                        <td style="color:var(--text-muted)">{a.year ?? ''}</td>
                        <td><span class={`rating ${ratingClass(a.rating)}`}>{a.rating ?? '—'}</span></td>
                        <td>{sortSubs(aSubs).map(s => <span class={`tag${s === 'Sketchy' ? ' tag-sketchy' : ''}`}>{s}</span>)}</td>
                      </tr>
                    );
                  })}
                </tbody></table>
              </div>
            </div>
          )}

          {similar.length > 0 && (
            <div class="more-by">
              <p class="related-title">Similar Albums</p>
              <div class="table-wrap">
                <table><tbody>
                  {similar.map(a => {
                    const aSubs: string[] = JSON.parse(a.subgenres || '[]');
                    const cc = countryCode(a.country).toLowerCase();
                    return (
                      <tr data-href={`/album/${a.slug}`}>
                        <td style="width:44px">
                          <div class="cover-thumb" style="background:#000;overflow:hidden">
                            {a.cover_url && <img src={a.cover_url} alt="" loading="lazy"
                              style="width:100%;height:100%;object-fit:cover;display:block"
                              onerror="this.style.display='none'" />}
                          </div>
                        </td>
                        <td style="color:var(--text-muted)"><a href={`/artist/${slugify(a.artist)}`}>{a.artist} </a></td>
                        <td>{cc && <span class={`fi fi-${cc} country-flag`} title={a.country} />}</td>
                        <td><a href={`/album/${a.slug}`}>{a.album} {a.recommended ? <span class="rec-star" title="Recommended"> ★</span> : null}</a></td>
                        <td style="color:var(--text-muted)">{a.year ?? ''}</td>
                        <td><span class={`rating ${ratingClass(a.rating)}`}>{a.rating ?? '—'}</span></td>
                        <td class="related-tags">{sortSubs(aSubs).map(s => <span class={`tag${s === 'Sketchy' ? ' tag-sketchy' : ''}`}>{s}</span>)}</td>
                      </tr>
                    );
                  })}
                </tbody></table>
              </div>
            </div>
          )}
          </section>
      </div>
    </div>

    
  </div>

  <!-- ── Edit mode ── -->
  <div class="edit-panel" id="edit-panel">
    <AlbumForm
      values={{
        mbid:        album.mbid,
        artist:      album.artist,
        album:       album.album,
        year:        album.year,
        country:     album.country,
        genre:       album.genre,
        subgenres,
        rating:      album.rating,
        notes:       album.notes,
        cover_url:   album.cover_url,
        tracks:      JSON.stringify(albumTracks),
        recommended: album.recommended,
        is_hidden:   album.is_hidden,
      }}
      submitLabel="Save Changes"
    />
  </div>
</Layout>

<script>
import { initAlbumForm } from '../../lib/album-form';

initAlbumForm();

// ── View / edit toggle ───────────────────────────────────────────────────────
document.getElementById('edit-btn')!.addEventListener('click', () => {
  document.getElementById('view-panel')!.classList.add('hidden');
  document.getElementById('edit-panel')!.classList.add('visible');
});
document.getElementById('cancel-btn')!.addEventListener('click', () => {
  document.getElementById('edit-panel')!.classList.remove('visible');
  document.getElementById('view-panel')!.classList.remove('hidden');
});

// ── Delete ───────────────────────────────────────────────────────────────────
document.getElementById('delete-btn')?.addEventListener('click', async e => {
  const id = (e.currentTarget as HTMLElement).dataset.id;
  if (!confirm('Remove this album from your library? This cannot be undone.')) return;
  await fetch(`/api/album/${id}`, { method: 'DELETE' });
  window.location.href = '/';
});

// ── Clickable related-album rows ─────────────────────────────────────────────
document.querySelectorAll<HTMLTableRowElement>('tr[data-href]').forEach(tr => {
  tr.addEventListener('click', e => {
    if ((e.target as Element).closest('a')) return;
    window.location.href = tr.dataset.href!;
  });
});
</script>
