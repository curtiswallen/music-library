---
import Layout from '../../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import type { Album } from '../../types';

const { id } = Astro.params;
const numId  = parseInt(id ?? '');
const db     = env.DB;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();

  const subgenres = JSON.stringify(
    ((data.get('subgenres') as string) ?? '').split(',').map(s => s.trim()).filter(Boolean)
  );
  const favTracks = JSON.stringify(
    ((data.get('fav_tracks') as string) ?? '').split(',').map(s => s.trim()).filter(Boolean)
  );

  await db.prepare(`
    UPDATE albums SET
      artist = ?, album = ?, country = ?, year = ?,
      genre = ?, subgenres = ?, rating = ?, notes = ?,
      fav_tracks = ?, recommended = ?, cover_url = ?, mbid = ?
    WHERE id = ?
  `).bind(
    data.get('artist') as string,
    data.get('album') as string,
    (data.get('country') as string) || '',
    data.get('year') ? parseInt(data.get('year') as string) : null,
    (data.get('genre') as string) || '',
    subgenres,
    data.get('rating') ? parseInt(data.get('rating') as string) : null,
    (data.get('notes') as string) || '',
    favTracks,
    data.get('recommended') === 'on' ? 1 : 0,
    (data.get('cover_url') as string) || null,
    (data.get('mbid') as string) || null,
    numId,
  ).run();

  return Astro.redirect('/');
}

const album = await db
  .prepare('SELECT * FROM albums WHERE id = ?')
  .bind(numId)
  .first<Album>();

if (!album) return Astro.redirect('/');

const subgenres: string[] = JSON.parse(album.subgenres || '[]');
const favTracks: string[] = JSON.parse(album.fav_tracks || '[]');
---

<Layout title={`${album.artist} — ${album.album}`}>
  <div class="page-header">
    <h1>{album.artist} — {album.album}</h1>
    <div style="display:flex;gap:8px">
      <a href="/" class="btn">← Back</a>
      <button class="btn btn-danger" id="delete-btn" data-id={album.id}>Delete</button>
    </div>
  </div>

  {album.cover_url && (
    <div class="cover-preview" style="display:block">
      <label>Cover Art</label>
      <img src={album.cover_url} alt={`${album.artist} — ${album.album}`}
           onerror="this.parentElement.style.display='none'" />
    </div>
  )}

  <form method="post">
    <input type="hidden" name="mbid"      value={album.mbid ?? ''} />
    <input type="hidden" name="cover_url" id="f-cover-url" value={album.cover_url ?? ''} />

    <div class="form-grid">
      <div class="form-group">
        <label for="f-artist">Artist *</label>
        <input id="f-artist" name="artist" type="text" required value={album.artist} />
      </div>
      <div class="form-group">
        <label for="f-album">Album *</label>
        <input id="f-album" name="album" type="text" required value={album.album} />
      </div>
      <div class="form-group">
        <label for="f-year">Year</label>
        <input id="f-year" name="year" type="number" min="1900" max="2099" value={album.year ?? ''} />
      </div>
      <div class="form-group">
        <label for="f-country">Country</label>
        <input id="f-country" name="country" type="text" value={album.country} />
      </div>
      <div class="form-group">
        <label for="f-genre">Genre</label>
        <input id="f-genre" name="genre" type="text" value={album.genre} />
      </div>
      <div class="form-group">
        <label for="f-subgenres">Subgenres <span style="font-weight:400;text-transform:none;letter-spacing:0">(comma-separated)</span></label>
        <input id="f-subgenres" name="subgenres" type="text" value={subgenres.join(', ')} />
      </div>
      <div class="form-group">
        <label for="f-rating">Rating (0–100)</label>
        <input id="f-rating" name="rating" type="number" min="0" max="100" value={album.rating ?? ''} />
      </div>
      <div class="form-group" style="justify-content:flex-end;padding-bottom:18px">
        <label style="flex-direction:row;align-items:center;gap:8px;text-transform:none;letter-spacing:0;cursor:pointer">
          <input name="recommended" type="checkbox" style="width:auto" checked={album.recommended === 1} />
          Recommended
        </label>
      </div>
    </div>

    <div class="form-group">
      <label for="f-notes">Notes</label>
      <textarea id="f-notes" name="notes" rows="4">{album.notes}</textarea>
    </div>

    <div class="form-group">
      <label for="f-fav-tracks">Favorite Tracks <span style="font-weight:400;text-transform:none;letter-spacing:0">(comma-separated)</span></label>
      <input id="f-fav-tracks" name="fav_tracks" type="text" value={favTracks.join(', ')} />
    </div>

    <div style="display:flex;gap:10px;margin-top:8px">
      <button class="btn btn-primary" type="submit">Save Changes</button>
      <a href="/" class="btn">Cancel</a>
    </div>
  </form>
</Layout>

<script>
document.getElementById('delete-btn')?.addEventListener('click', async e => {
  const id = (e.currentTarget as HTMLElement).dataset.id;
  if (!confirm('Delete this album? This cannot be undone.')) return;
  await fetch(`/api/album/${id}`, { method: 'DELETE' });
  window.location.href = '/';
});
</script>
