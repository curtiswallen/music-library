---
import Layout from '../layouts/Layout.astro';
import { env } from 'cloudflare:workers';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/auth/login');

const db = env.DB;
const profileUrl = user.profile_url!;

type DashAlbum = {
  slug: string;
  artist: string;
  album: string;
  year: number | null;
  cover_url: string | null;
  rating: number | null;
  recommended: number;
};

const [recentRes, topRes, queueRes] = await Promise.all([
  db.prepare(`
    SELECT a.slug, a.artist, a.album, a.year, a.cover_url, ua.rating, ua.recommended
    FROM albums a JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
    WHERE ua.is_hidden = 0
    ORDER BY ua.added_at DESC LIMIT 5
  `).bind(user.id).all<DashAlbum>(),
  db.prepare(`
    SELECT a.slug, a.artist, a.album, a.year, a.cover_url, ua.rating, ua.recommended
    FROM albums a JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
    WHERE ua.is_hidden = 0 AND ua.rating IS NOT NULL
    ORDER BY ua.rating DESC LIMIT 5
  `).bind(user.id).all<DashAlbum>(),
  db.prepare(`
    SELECT a.slug, a.artist, a.album, a.year, a.cover_url, ua.rating, ua.recommended
    FROM albums a JOIN user_albums ua ON ua.album_id = a.id AND ua.user_id = ?
    WHERE ua.is_hidden = 0 AND ua.rating IS NULL
    ORDER BY ua.added_at DESC LIMIT 5
  `).bind(user.id).all<DashAlbum>(),
]);

const recentAlbums = recentRes.results;
const topAlbums    = topRes.results;
const queueAlbums  = queueRes.results;

function ratingClass(r: number | null) {
  if (r == null) return '';
  if (r >= 70) return 'rating-hi';
  if (r >= 50) return 'rating-mid';
  return 'rating-lo';
}

const sections = [
  {
    title: 'Recently Logged',
    albums: recentAlbums,
    viewAllHref: `/${profileUrl}?sort=added&dir=desc`,
    emptyText: 'No albums logged yet.',
  },
  {
    title: 'Highest Rated',
    albums: topAlbums,
    viewAllHref: `/${profileUrl}?sort=rating&dir=desc&rated=yes`,
    emptyText: 'No rated albums yet.',
  },
  {
    title: 'Queue',
    albums: queueAlbums,
    viewAllHref: `/${profileUrl}?rated=no&sort=added&dir=desc`,
    emptyText: 'No unrated albums.',
  },
];
---

<Layout title="Home">
  <div class="page-header">
    <div style="display:flex;align-items:center;gap:10px">
      {user.avatar_url && <img src={user.avatar_url} class="profile-avatar" alt="" />}
      <h1>{user.display_name || user.username}</h1>
    </div>
    <div style="display:flex;gap:8px;align-items:center">
      <a href={`/${profileUrl}`} class="btn nav-hide-mobile">My Library</a>
      <span class="user-chip nav-hide-mobile" style="padding-right:0">
        {user.avatar_url && <img src={user.avatar_url} class="user-avatar" alt="" />}
        {user.display_name || user.username}
      </span>
      {user.is_admin === 1 && <a href="/admin" class="btn nav-hide-mobile">Admin</a>}
      <a href="/settings" class="btn nav-hide-mobile" title="Settings">⚙</a>
      <form method="post" action="/auth/logout" style="margin:0" class="nav-hide-mobile">
        <button class="btn" type="submit">Sign out</button>
      </form>
      <a href="/add" class="btn icon-btn" aria-label="Add Album" data-tip="Add Album">+</a>
      <div class="nav-hamburger" id="nav-hamburger">
        <button class="btn nav-hamburger-btn" id="nav-hamburger-btn" aria-label="Menu" aria-expanded="false">☰</button>
        <div class="nav-hamburger-menu" id="nav-hamburger-menu" hidden>
          <div class="nav-hamburger-header">
            {user.avatar_url && <img src={user.avatar_url} class="user-avatar" alt="" />}
            <span>{user.display_name || user.username}</span>
          </div>
          <a href={`/${profileUrl}`} class="nav-hamburger-item">My Library</a>
          {user.is_admin === 1 && <a href="/admin" class="nav-hamburger-item">Admin</a>}
          <a href="/settings" class="nav-hamburger-item">Settings</a>
          <form method="post" action="/auth/logout" style="margin:0">
            <button type="submit" class="nav-hamburger-item">Sign out</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <div class="dash-grid">
    {sections.map(({ title, albums, viewAllHref, emptyText }) => (
      <section class="dash-section">
        <div class="dash-section-header">
          <h2 class="dash-title">{title}</h2>
          <a href={viewAllHref} class="dash-view-all">View all →</a>
        </div>
        {albums.length === 0 ? (
          <p class="dash-empty">{emptyText}</p>
        ) : (
          <div class="dash-list">
            {albums.map(a => (
              <a href={`/${profileUrl}/album/${a.slug}`} class="dash-row">
                {a.cover_url
                  ? <img src={a.cover_url} class="dash-cover" alt="" loading="lazy" />
                  : <div class="dash-cover dash-cover-empty" />}
                <div class="dash-info">
                  <span class="dash-artist">{a.artist}</span>
                  <span class="dash-album-name">
                    {a.year && <span class="year-chip">{a.year}</span>}
                    <span class="dash-album-text">{a.album}</span>
                    {a.recommended === 1 && <span class="rec-star" title="Recommended"> ★</span>}
                  </span>
                </div>
                {a.rating != null
                  ? <span class={`dash-rating rating ${ratingClass(a.rating)}`}>{a.rating}</span>
                  : <span class="dash-rating dash-rating-none">—</span>}
              </a>
            ))}
          </div>
        )}
      </section>
    ))}
  </div>
</Layout>

<style>
.profile-avatar { width: 32px; height: 32px; border-radius: 50%; object-fit: cover; }
.user-avatar    { width: 22px; height: 22px; border-radius: 50%; object-fit: cover; }
.user-chip {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 12px; color: var(--text-muted);
}

.dash-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  align-items: start;
}

.dash-section {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 6px;
  overflow: hidden;
}

.dash-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 14px 10px;
  border-bottom: 1px solid var(--border);
}

.dash-title {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--text-muted);
}

.dash-view-all {
  font-size: 11px;
  color: var(--text-muted);
}
.dash-view-all:hover { color: var(--accent-hi); }

.dash-empty {
  padding: 20px 14px;
  font-size: 12px;
  color: var(--text-muted);
}

.dash-list { display: flex; flex-direction: column; }

.dash-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 14px;
  border-bottom: 1px solid var(--border);
  transition: background 0.1s;
  min-width: 0;
}
.dash-row:last-child { border-bottom: none; }
.dash-row:hover { background: var(--bg-hover); }

.dash-cover {
  width: 36px;
  height: 36px;
  flex-shrink: 0;
  object-fit: cover;
  border-radius: 2px;
  border: 1px solid var(--border);
}
.dash-cover-empty {
  background: var(--bg-hover);
}

.dash-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
  flex: 1;
  gap: 1px;
  padding-right: 10px;
}

.dash-artist {
  font-size: 12px;
  font-weight: 600;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dash-album-name {
  display: flex;
  align-items: center;
  gap: 3px;
  font-size: 11px;
  color: var(--text-muted);
  min-width: 0;
  overflow: hidden;
}

.dash-album-text {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
}

.dash-rating {
  flex-shrink: 0;
  font-size: 12px;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}
.dash-rating-none { color: var(--text-muted); font-weight: 400; }

@media (max-width: 900px) {
  .dash-grid { grid-template-columns: 1fr; }
}
</style>

<script is:inline>
  (function () {
    var btn  = document.getElementById('nav-hamburger-btn');
    var menu = document.getElementById('nav-hamburger-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var open = menu.hidden;
      menu.hidden = !open;
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    document.addEventListener('click', function (e) {
      if (!e.target.closest('#nav-hamburger')) {
        menu.hidden = true;
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>
