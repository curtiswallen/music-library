---

<Layout title="Settings">
  <div class="page-header" slot="header">
    <h1><a href="/">Music Library</a></h1>
  </div>

  {saved && <p class="flash-ok">Settings saved.</p>}

  <form method="post" class="settings-form">
    <div class="settings-section">
      <h2>Profile</h2>

      <div class="form-group">
        <label for="display_name">Display Name</label>
        <input id="display_name" name="display_name" type="text"
               value={formDisplayName} placeholder={user.username} maxlength="50" />
        <span class="field-hint">Shown as "Display Name's Library". Defaults to your Google username if empty.</span>
        {errors.display_name && <span class="field-error">{errors.display_name}</span>}
      </div>

      <div class="form-group">
        <label for="profile_url">Profile URL</label>
        <div class="url-input-wrap">
          <span class="url-prefix">{Astro.url.origin}/</span>
          <input id="profile_url" name="profile_url" type="text"
                 value={formProfileUrl} placeholder="yourname"
                 pattern="[a-z0-9][a-z0-9_\-]{1,28}[a-z0-9]|[a-z0-9]{3}"
                 maxlength="30" autocomplete="off" spellcheck="false" />
        </div>
        <span class="field-hint">3–30 characters: lowercase letters, numbers, hyphens, underscores.</span>
        {errors.profile_url && <span class="field-error">{errors.profile_url}</span>}
      </div>

      <div class="form-group">
        <label>Privacy</label>
        <div class="radio-group">
          <label class="radio-label">
            <input type="radio" name="is_private" value="0" checked={formIsPrivate === 0} />
            Public — your library is visible to other users
          </label>
          <label class="radio-label">
            <input type="radio" name="is_private" value="1" checked={formIsPrivate === 1} />
            Private — only you can see your library
          </label>
        </div>
        <span class="field-hint">Albums you've individually hidden will remain hidden even if you switch back to Public.</span>
      </div>

      <div class="form-group">
        <label>Added Dates</label>
        <div class="radio-group">
          <label class="radio-label">
            <input type="radio" name="hide_added_at" value="0" checked={formHideAddedAt === 0} />
            Visible — show dates when albums were logged on your public profile
          </label>
          <label class="radio-label">
            <input type="radio" name="hide_added_at" value="1" checked={formHideAddedAt === 1} />
            Hidden — don't show logged dates to other users
          </label>
        </div>
      </div>

      <div class="form-group">
        <label for="timezone">Timezone</label>
        <Combobox id="timezone" name="timezone"
          labeledOptions={TIMEZONES}
          value={formTimezone}
          placeholder="Search timezones…" />
        <span class="field-hint">Used for grouping your album activity by local date on your dashboard.</span>
      </div>
    </div>

    <div class="settings-footer">
      <button type="submit" class="btn">Save Settings</button>
      <a href="javascript:history.back()" class="btn">Done</a>
    </div>
  </form>
</Layout>

<style>
.settings-form {
  max-width: 520px;
  margin-top: 24px;
}
.settings-section {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 20px 24px;
  margin-bottom: 16px;
}
.settings-section h2 {
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--text-muted);
  margin: 0 0 16px;
}
.form-group {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-bottom: 16px;
}
.form-group:last-child { margin-bottom: 0; }
.form-group label:first-child {
  font-size: 13px;
  font-weight: 500;
  color: var(--text);
}
.form-group input[type="text"],
.form-group select {
  background: var(--bg);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 6px 10px;
  border-radius: 4px;
  font-size: 13px;
  font-family: inherit;
  width: 100%;
  box-sizing: border-box;
}
.form-group input[type="text"]:focus,
.form-group select:focus {
  outline: none;
  border-color: var(--accent);
}
.url-input-wrap {
  display: flex;
  align-items: center;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
}
.url-prefix {
  padding: 6px 8px 6px 10px;
  font-size: 13px;
  color: var(--text-muted);
  white-space: nowrap;
  border-right: 1px solid var(--border);
  background: var(--bg-card);
}
.url-input-wrap input {
  border: none !important;
  border-radius: 0 !important;
  flex: 1;
}
.url-input-wrap input:focus { outline: none; }
.field-hint {
  font-size: 11px;
  color: var(--text-muted);
  opacity: 0.7;
}
.field-error {
  font-size: 12px;
  color: #c06060;
}
.radio-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.radio-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--text);
  cursor: pointer;
}
.radio-label input[type="radio"] {
  width: auto;
  accent-color: var(--accent);
}
.settings-footer {
  display: flex;
  gap: 8px;
}
.flash-ok {
  color: #5a9e6f;
  font-size: 13px;
  margin-bottom: 12px;
}
</style>
