---
import Layout from '../layouts/Layout.astro';
import Combobox from '../components/Combobox.astro';
import { env } from 'cloudflare:workers';
import { SOCIAL_PLATFORMS, parseSocialLinks, type SocialLink } from '../lib/social-platforms';

const user = Astro.locals.user!;
const db   = env.DB;

const RESERVED = new Set(['add', 'album', 'artist', 'auth', 'api', 'settings', 'admin', 'login', 'logout']);
const URL_RE   = /^[a-z0-9][a-z0-9_-]{1,28}[a-z0-9]$|^[a-z0-9]{3}$/;

let errors: Record<string, string> = {};
let saved = false;

// Values to re-populate form on error
let formDisplayName  = user.display_name  ?? '';
let formProfileUrl   = user.profile_url   ?? '';
let formIsPrivate    = user.is_private;
let formHideAddedAt  = user.hide_added_at ?? 0;
let formTimezone     = user.timezone || 'UTC';
let formBio          = user.bio ?? '';
let formSocialLinks: SocialLink[] = parseSocialLinks(user.social_links);

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();

  formDisplayName = ((data.get('display_name') as string) ?? '').trim();
  formProfileUrl  = ((data.get('profile_url')  as string) ?? '').trim().toLowerCase();
  formIsPrivate   = data.get('is_private')    === '1' ? 1 : 0;
  formHideAddedAt = data.get('hide_added_at') === '1' ? 1 : 0;
  formTimezone    = ((data.get('timezone') as string) ?? 'UTC').trim() || 'UTC';
  formBio         = ((data.get('bio') as string) ?? '').trim().slice(0, 1000);

  const rawSocialLinks = (data.get('social_links') as string) ?? '[]';
  const parsed = parseSocialLinks(rawSocialLinks);
  const validIds = new Set(SOCIAL_PLATFORMS.map(p => p.id));
  formSocialLinks = parsed.filter(l => validIds.has(l.platform)).slice(0, 10);

  // Validate display_name
  if (formDisplayName.length > 50) {
    errors.display_name = 'Display name must be 50 characters or fewer.';
  }

  // Validate profile_url
  if (!formProfileUrl) {
    errors.profile_url = 'Profile URL is required.';
  } else if (!URL_RE.test(formProfileUrl)) {
    errors.profile_url = 'URL must be 3–30 characters: lowercase letters, numbers, hyphens, and underscores only.';
  } else if (RESERVED.has(formProfileUrl)) {
    errors.profile_url = `"${formProfileUrl}" is a reserved word and cannot be used as a URL.`;
  } else {
    // Uniqueness check (exclude current user)
    const clash = await db.prepare(
      'SELECT id FROM users WHERE profile_url = ? AND id != ?'
    ).bind(formProfileUrl, user.id).first<{ id: number }>();
    if (clash) errors.profile_url = 'That URL is already taken.';
  }

  if (Object.keys(errors).length === 0) {
    await db.prepare(`
      UPDATE users
      SET display_name = ?, profile_url = ?, is_private = ?, hide_added_at = ?, timezone = ?, bio = ?, social_links = ?
      WHERE id = ?
    `).bind(
      formDisplayName || null,
      formProfileUrl  || null,
      formIsPrivate,
      formHideAddedAt,
      formTimezone,
      formBio || null,
      formSocialLinks.length > 0 ? JSON.stringify(formSocialLinks) : null,
      user.id,
    ).run();

    return Astro.redirect('/settings?saved=1');
  }
}

if (Astro.url.searchParams.get('saved') === '1') saved = true;

const TIMEZONES: { label: string; value: string }[] = [
  { label: 'UTC',                        value: 'UTC' },
  { label: 'Eastern (New York)',         value: 'America/New_York' },
  { label: 'Central (Chicago)',          value: 'America/Chicago' },
  { label: 'Mountain (Denver)',          value: 'America/Denver' },
  { label: 'Mountain no-DST (Phoenix)',  value: 'America/Phoenix' },
  { label: 'Pacific (Los Angeles)',      value: 'America/Los_Angeles' },
  { label: 'Alaska (Anchorage)',         value: 'America/Anchorage' },
  { label: 'Hawaii (Honolulu)',          value: 'Pacific/Honolulu' },
  { label: 'Atlantic (Halifax)',         value: 'America/Halifax' },
  { label: 'Toronto',                    value: 'America/Toronto' },
  { label: 'Vancouver',                  value: 'America/Vancouver' },
  { label: 'Winnipeg',                   value: 'America/Winnipeg' },
  { label: 'Mexico City',                value: 'America/Mexico_City' },
  { label: 'Bogotá',                     value: 'America/Bogota' },
  { label: 'Lima',                       value: 'America/Lima' },
  { label: 'Caracas',                    value: 'America/Caracas' },
  { label: 'Santiago',                   value: 'America/Santiago' },
  { label: 'São Paulo',                  value: 'America/Sao_Paulo' },
  { label: 'Buenos Aires',               value: 'America/Argentina/Buenos_Aires' },
  { label: 'London',                     value: 'Europe/London' },
  { label: 'Dublin',                     value: 'Europe/Dublin' },
  { label: 'Lisbon',                     value: 'Europe/Lisbon' },
  { label: 'Paris',                      value: 'Europe/Paris' },
  { label: 'Berlin',                     value: 'Europe/Berlin' },
  { label: 'Rome',                       value: 'Europe/Rome' },
  { label: 'Madrid',                     value: 'Europe/Madrid' },
  { label: 'Amsterdam',                  value: 'Europe/Amsterdam' },
  { label: 'Brussels',                   value: 'Europe/Brussels' },
  { label: 'Stockholm',                  value: 'Europe/Stockholm' },
  { label: 'Oslo',                       value: 'Europe/Oslo' },
  { label: 'Copenhagen',                 value: 'Europe/Copenhagen' },
  { label: 'Helsinki',                   value: 'Europe/Helsinki' },
  { label: 'Warsaw',                     value: 'Europe/Warsaw' },
  { label: 'Prague',                     value: 'Europe/Prague' },
  { label: 'Vienna',                     value: 'Europe/Vienna' },
  { label: 'Zurich',                     value: 'Europe/Zurich' },
  { label: 'Athens',                     value: 'Europe/Athens' },
  { label: 'Istanbul',                   value: 'Europe/Istanbul' },
  { label: 'Moscow',                     value: 'Europe/Moscow' },
  { label: 'Kyiv',                       value: 'Europe/Kyiv' },
  { label: 'Cairo',                      value: 'Africa/Cairo' },
  { label: 'Johannesburg',               value: 'Africa/Johannesburg' },
  { label: 'Lagos',                      value: 'Africa/Lagos' },
  { label: 'Nairobi',                    value: 'Africa/Nairobi' },
  { label: 'Dubai',                      value: 'Asia/Dubai' },
  { label: 'Karachi',                    value: 'Asia/Karachi' },
  { label: 'Kolkata / Mumbai',           value: 'Asia/Kolkata' },
  { label: 'Dhaka',                      value: 'Asia/Dhaka' },
  { label: 'Yangon',                     value: 'Asia/Yangon' },
  { label: 'Bangkok',                    value: 'Asia/Bangkok' },
  { label: 'Jakarta',                    value: 'Asia/Jakarta' },
  { label: 'Singapore',                  value: 'Asia/Singapore' },
  { label: 'Hong Kong',                  value: 'Asia/Hong_Kong' },
  { label: 'Beijing / Shanghai',         value: 'Asia/Shanghai' },
  { label: 'Taipei',                     value: 'Asia/Taipei' },
  { label: 'Seoul',                      value: 'Asia/Seoul' },
  { label: 'Tokyo',                      value: 'Asia/Tokyo' },
  { label: 'Perth',                      value: 'Australia/Perth' },
  { label: 'Darwin',                     value: 'Australia/Darwin' },
  { label: 'Brisbane',                   value: 'Australia/Brisbane' },
  { label: 'Adelaide',                   value: 'Australia/Adelaide' },
  { label: 'Sydney / Melbourne',         value: 'Australia/Sydney' },
  { label: 'Auckland',                   value: 'Pacific/Auckland' },
  { label: 'Fiji',                       value: 'Pacific/Fiji' },
];
---

<Layout title="Settings">
  <div class="page-header" slot="header">
    <h1><a href="/">Music Library</a></h1>
  </div>

  {saved && <p class="flash-ok">Settings saved.</p>}

  <form method="post" class="settings-form">
    <div class="settings-section">

      <div class="form-group">
        <label for="display_name">Display name</label>
        <input id="display_name" name="display_name" type="text"
               value={formDisplayName} placeholder={user.username} maxlength="50" />
        <span class="field-hint">Shown as "Display Name's Library". Defaults to your Google username if empty.</span>
        {errors.display_name && <span class="field-error">{errors.display_name}</span>}
      </div>

      <div class="form-group">
        <label for="profile_url">Profile URL</label>
        <div class="url-input-wrap">
          <span class="url-prefix">{Astro.url.origin}/</span>
          <input id="profile_url" name="profile_url" type="text"
                 value={formProfileUrl} placeholder="yourname"
                 pattern="[a-z0-9][a-z0-9_\-]{1,28}[a-z0-9]|[a-z0-9]{3}"
                 maxlength="30" autocomplete="off" spellcheck="false" />
        </div>
        <span class="field-hint">3–30 characters: lowercase letters, numbers, hyphens, underscores.</span>
        {errors.profile_url && <span class="field-error">{errors.profile_url}</span>}
      </div>

      <div class="form-group">
        <label>Privacy</label>
        <div class="radio-group">
          <label class="radio-label">
            <input type="radio" name="is_private" value="0" checked={formIsPrivate === 0} />
            Public — your library is visible to other users
          </label>
          <label class="radio-label">
            <input type="radio" name="is_private" value="1" checked={formIsPrivate === 1} />
            Private — only you can see your library
          </label>
        </div>
        <span class="field-hint">Albums you've individually hidden will remain hidden even if you switch back to Public.</span>
      </div>

      <div class="form-group">
        <label>Added Dates</label>
        <div class="radio-group">
          <label class="radio-label">
            <input type="radio" name="hide_added_at" value="0" checked={formHideAddedAt === 0} />
            Visible — show dates when albums were logged on your public profile
          </label>
          <label class="radio-label">
            <input type="radio" name="hide_added_at" value="1" checked={formHideAddedAt === 1} />
            Hidden — don't show logged dates to other users
          </label>
        </div>
      </div>

      <div class="form-group">
        <label for="timezone">Timezone</label>
        <Combobox id="timezone" name="timezone"
          labeledOptions={TIMEZONES}
          value={formTimezone}
          placeholder="Search timezones…" />
        <span class="field-hint">Used for grouping your album activity by local date on your dashboard.</span>
      </div>

      <div class="form-group">
        <label for="bio">Bio</label>
        <textarea id="bio" name="bio" rows="4" maxlength="1000"
                  placeholder="Write a short bio…">{formBio}</textarea>
        <span class="field-hint">Shown on your public dashboard. Markdown supported (links, bold, etc.). Max 1000 characters.</span>
      </div>

      <div class="form-group">
        <label>Social Links</label>
        <div id="slk-list" style={formSocialLinks.length === 0 ? 'display:none' : undefined}>
          {formSocialLinks.map(link => {
            const p = SOCIAL_PLATFORMS.find(pl => pl.id === link.platform);
            return (
              <div class="slk-item" data-platform={link.platform} data-username={link.username}>
                <span class="slk-label">{p?.label ?? link.platform}</span>
                <span class="slk-username">{link.username}</span>
                <button type="button" class="slk-remove" aria-label="Remove">×</button>
              </div>
            );
          })}
        </div>
        <div id="slk-add-row" style={formSocialLinks.length >= 10 ? 'display:none' : undefined}>
          <button type="button" id="slk-add-btn" class="btn">+ Add Link</button>
        </div>
        <div id="slk-add-form">
          <select id="slk-platform-sel">
            <option value="">Choose platform…</option>
            {SOCIAL_PLATFORMS.map(p => <option value={p.id}>{p.label}</option>)}
          </select>
          <div class="slk-username-wrap">
            <span id="slk-prefix-lbl" class="slk-affix"></span>
            <input type="text" id="slk-username-inp" placeholder="username" autocomplete="off" spellcheck="false" />
            <span id="slk-suffix-lbl" class="slk-affix"></span>
          </div>
          <div class="slk-add-actions">
            <button type="button" id="slk-confirm-btn" class="btn">Add</button>
            <button type="button" id="slk-cancel-btn" class="btn">Cancel</button>
          </div>
        </div>
        <input type="hidden" name="social_links" id="slk-json"
               value={JSON.stringify(formSocialLinks)} />
        <span class="field-hint">Up to 10 links, shown as icons on your public profile.</span>
      </div>
    </div>

    <div class="settings-footer">
      <button type="submit" class="btn">Save settings</button>
    </div>
  </form>
</Layout>

<style>
.settings-form {
  max-width: 520px;
  margin-top: 24px;
}
.settings-section {
  margin-bottom: 16px;
}
.form-group {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-bottom: 16px;
}
.form-group:last-child { margin-bottom: 0; }
.form-group label:first-child {
  font-size: 11px;
  font-weight: 500;
  color: var(--text);
}
.form-group input[type="text"],
.form-group select,
.form-group textarea {
  background: var(--bg);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 6px 10px;
  border-radius: 4px;
  font-size: 11px;
  font-family: inherit;
  width: 100%;
  box-sizing: border-box;
}
.form-group input[type="text"]:focus,
.form-group select:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--accent);
}
.form-group textarea { resize: vertical; line-height: 1.5; }
.url-input-wrap {
  display: flex;
  align-items: center;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
}
.url-prefix {
  padding: 6px 8px 6px 10px;
  font-size: 11px;
  color: var(--text-muted);
  white-space: nowrap;
  border-right: 1px solid var(--border);
  background: var(--bg-card);
}
.url-input-wrap input {
  border: none !important;
  border-radius: 0 !important;
  flex: 1;
}
.url-input-wrap input:focus { outline: none; }
.field-hint {
  font-size: 11px;
  color: var(--text-muted);
  opacity: 0.7;
}
.field-error {
  font-size: 11px;
  color: #c06060;
}
.radio-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.radio-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  color: var(--text);
  cursor: pointer;
}
.radio-label input[type="radio"] {
  width: auto;
  accent-color: var(--accent);
}
.settings-footer {
  display: flex;
  gap: 8px;
}
.flash-ok {
  color: #5a9e6f;
  font-size: 11px;
  margin-bottom: 12px;
}
#slk-list { display: flex; flex-direction: column; gap: 4px; align-self: flex-start; }
:global(.slk-item) {
  display: flex; align-items: center; gap: 8px;
  padding: 5px 8px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 4px;
  font-size: 11px;
}
:global(.slk-item.slk-new) { opacity: 0.6; }
:global(.slk-label) { font-weight: 500; min-width: 90px; }
:global(.slk-username) { color: var(--text-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
:global(.slk-remove) {
  background: none; border: none; cursor: pointer;
  color: var(--text-muted); font-size: 14px; line-height: 1; padding: 0 2px;
}
:global(.slk-remove:hover) { color: var(--text); }
#slk-add-form {
  display: none;
  flex-direction: column;
  gap: 6px;
  padding: 10px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 3px;
}
#slk-add-form select {
  background: var(--bg);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 5px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-family: inherit;
  width: 100%;
  box-sizing: border-box;
}
#slk-add-form select:focus { outline: none; border-color: var(--accent); }
.slk-username-wrap {
  display: none;
  align-items: center;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
  font-size: 11px;
}
.slk-username-wrap:focus-within { border-color: var(--accent); }
.slk-affix {
  padding: 5px 6px;
  color: var(--text-muted);
  white-space: nowrap;
  background: var(--bg-card);
  font-size: 11px;
}
#slk-prefix-lbl { border-right: 1px solid var(--border); }
#slk-suffix-lbl { border-left: 1px solid var(--border); }
#slk-username-inp {
  flex: 1; border: none !important; border-radius: 0 !important;
  background: var(--bg); color: var(--text);
  padding: 5px 8px; font-size: 11px; font-family: inherit; min-width: 0;
}
#slk-username-inp:focus { outline: none; }
.slk-add-actions { display: flex; gap: 6px; }
</style>

<script is:inline define:vars={{ platformData: SOCIAL_PLATFORMS.map(p => ({ id: p.id, label: p.label, urlPrefix: p.urlPrefix, urlSuffix: p.urlSuffix ?? '', inputPlaceholder: p.inputPlaceholder })) }}>
(function () {
  const list        = document.getElementById('slk-list');
  const addRow      = document.getElementById('slk-add-row');
  const addBtn      = document.getElementById('slk-add-btn');
  const addForm     = document.getElementById('slk-add-form');
  const platformSel = document.getElementById('slk-platform-sel');
  const usernameInp  = document.getElementById('slk-username-inp');
  const usernameWrap = document.getElementById('slk-username-inp').closest('.slk-username-wrap');
  const prefixLbl    = document.getElementById('slk-prefix-lbl');
  const suffixLbl    = document.getElementById('slk-suffix-lbl');
  const confirmBtn  = document.getElementById('slk-confirm-btn');
  const cancelBtn   = document.getElementById('slk-cancel-btn');
  const hiddenInp   = document.getElementById('slk-json');

  const byId = Object.fromEntries(platformData.map(p => [p.id, p]));

  function serialize() {
    const items = [...list.querySelectorAll('.slk-item')];
    hiddenInp.value = JSON.stringify(items.map(el => ({
      platform: el.dataset.platform,
      username: el.dataset.username,
    })));
    const count = items.length;
    list.style.display = count === 0 ? 'none' : 'flex';
    addRow.style.display = count >= 10 ? 'none' : '';
  }

  function makeItem(platform, username) {
    const el = document.createElement('div');
    el.className = 'slk-item slk-new';
    el.dataset.platform = platform;
    el.dataset.username = username;
    const label = byId[platform]?.label ?? platform;
    el.innerHTML = `
      <span class="slk-label">${label}</span>
      <span class="slk-username">${username}</span>
      <button type="button" class="slk-remove" aria-label="Remove">×</button>
    `;
    return el;
  }

  list.addEventListener('click', e => {
    if (e.target.classList.contains('slk-remove')) {
      e.target.closest('.slk-item').remove();
      serialize();
    }
  });

  addBtn.addEventListener('click', () => {
    addForm.style.display = 'flex';
    addRow.style.display = 'none';
    platformSel.focus();
  });

  cancelBtn.addEventListener('click', () => {
    addForm.style.display = 'none';
    const count = list.querySelectorAll('.slk-item').length;
    addRow.style.display = count >= 10 ? 'none' : '';
    platformSel.value = '';
    usernameInp.value = '';
    usernameInp.placeholder = 'username';
    prefixLbl.textContent = '';
    suffixLbl.textContent = '';
    suffixLbl.style.display = 'none';
    usernameWrap.style.display = 'none';
  });

  platformSel.addEventListener('change', () => {
    const p = byId[platformSel.value];
    if (!p) { usernameWrap.style.display = 'none'; return; }
    prefixLbl.textContent = p.urlPrefix;
    suffixLbl.textContent = p.urlSuffix ?? '';
    suffixLbl.style.display = p.urlSuffix ? '' : 'none';
    usernameInp.placeholder = p.inputPlaceholder;
    usernameInp.value = '';
    usernameWrap.style.display = 'flex';
    usernameInp.focus();
  });

  confirmBtn.addEventListener('click', () => {
    const platform = platformSel.value;
    const username = usernameInp.value.trim();
    if (!platform || !username) { usernameInp.focus(); return; }
    if (list.querySelectorAll('.slk-item').length >= 10) return;
    list.appendChild(makeItem(platform, username));
    serialize();
    cancelBtn.click();
  });

  usernameInp.addEventListener('keydown', e => {
    if (e.key === 'Enter') { e.preventDefault(); confirmBtn.click(); }
    if (e.key === 'Escape') cancelBtn.click();
  });
})();
</script>
