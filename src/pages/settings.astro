---
import Layout from '../layouts/Layout.astro';
import { env } from 'cloudflare:workers';

const user = Astro.locals.user!;
const db   = env.DB;

const RESERVED = new Set(['add', 'album', 'artist', 'auth', 'api', 'settings', 'admin', 'login', 'logout']);
const URL_RE   = /^[a-z0-9][a-z0-9_-]{1,28}[a-z0-9]$|^[a-z0-9]{3}$/;

let errors: Record<string, string> = {};
let saved = false;

// Values to re-populate form on error
let formDisplayName  = user.display_name  ?? '';
let formProfileUrl   = user.profile_url   ?? '';
let formIsPrivate    = user.is_private;
let formHideAddedAt  = user.hide_added_at ?? 0;
let formTimezone     = user.timezone || 'UTC';

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();

  formDisplayName = ((data.get('display_name') as string) ?? '').trim();
  formProfileUrl  = ((data.get('profile_url')  as string) ?? '').trim().toLowerCase();
  formIsPrivate   = data.get('is_private')    === '1' ? 1 : 0;
  formHideAddedAt = data.get('hide_added_at') === '1' ? 1 : 0;
  formTimezone    = ((data.get('timezone') as string) ?? 'UTC').trim() || 'UTC';

  // Validate display_name
  if (formDisplayName.length > 50) {
    errors.display_name = 'Display name must be 50 characters or fewer.';
  }

  // Validate profile_url
  if (!formProfileUrl) {
    errors.profile_url = 'Profile URL is required.';
  } else if (!URL_RE.test(formProfileUrl)) {
    errors.profile_url = 'URL must be 3–30 characters: lowercase letters, numbers, hyphens, and underscores only.';
  } else if (RESERVED.has(formProfileUrl)) {
    errors.profile_url = `"${formProfileUrl}" is a reserved word and cannot be used as a URL.`;
  } else {
    // Uniqueness check (exclude current user)
    const clash = await db.prepare(
      'SELECT id FROM users WHERE profile_url = ? AND id != ?'
    ).bind(formProfileUrl, user.id).first<{ id: number }>();
    if (clash) errors.profile_url = 'That URL is already taken.';
  }

  if (Object.keys(errors).length === 0) {
    await db.prepare(`
      UPDATE users
      SET display_name = ?, profile_url = ?, is_private = ?, hide_added_at = ?, timezone = ?
      WHERE id = ?
    `).bind(
      formDisplayName || null,
      formProfileUrl  || null,
      formIsPrivate,
      formHideAddedAt,
      formTimezone,
      user.id,
    ).run();

    return Astro.redirect('/settings?saved=1');
  }
}

if (Astro.url.searchParams.get('saved') === '1') saved = true;
---

<Layout title="Settings">
  <div class="page-header">
    <h1>Settings</h1>
    <a href={`/${user.profile_url}`} class="btn">← Dashboard</a>
  </div>

  {saved && <p class="flash-ok">Settings saved.</p>}

  <form method="post" class="settings-form">
    <div class="settings-section">
      <h2>Profile</h2>

      <div class="form-group">
        <label for="display_name">Display Name</label>
        <input id="display_name" name="display_name" type="text"
               value={formDisplayName} placeholder={user.username} maxlength="50" />
        <span class="field-hint">Shown as "Display Name's Library". Defaults to your Google username if empty.</span>
        {errors.display_name && <span class="field-error">{errors.display_name}</span>}
      </div>

      <div class="form-group">
        <label for="profile_url">Profile URL</label>
        <div class="url-input-wrap">
          <span class="url-prefix">{Astro.url.origin}/</span>
          <input id="profile_url" name="profile_url" type="text"
                 value={formProfileUrl} placeholder="yourname"
                 pattern="[a-z0-9][a-z0-9_\-]{1,28}[a-z0-9]|[a-z0-9]{3}"
                 maxlength="30" autocomplete="off" spellcheck="false" />
        </div>
        <span class="field-hint">3–30 characters: lowercase letters, numbers, hyphens, underscores.</span>
        {errors.profile_url && <span class="field-error">{errors.profile_url}</span>}
      </div>

      <div class="form-group">
        <label>Privacy</label>
        <div class="radio-group">
          <label class="radio-label">
            <input type="radio" name="is_private" value="0" checked={formIsPrivate === 0} />
            Public — your library is visible to other users
          </label>
          <label class="radio-label">
            <input type="radio" name="is_private" value="1" checked={formIsPrivate === 1} />
            Private — only you can see your library
          </label>
        </div>
        <span class="field-hint">Albums you've individually hidden will remain hidden even if you switch back to Public.</span>
      </div>

      <div class="form-group">
        <label>Added Dates</label>
        <div class="radio-group">
          <label class="radio-label">
            <input type="radio" name="hide_added_at" value="0" checked={formHideAddedAt === 0} />
            Visible — show dates when albums were logged on your public profile
          </label>
          <label class="radio-label">
            <input type="radio" name="hide_added_at" value="1" checked={formHideAddedAt === 1} />
            Hidden — don't show logged dates to other users
          </label>
        </div>
      </div>

      <div class="form-group">
        <label for="timezone">Timezone</label>
        <select id="timezone" name="timezone">
          <option value="UTC"                              selected={formTimezone === 'UTC'}>UTC</option>
          <optgroup label="North America">
            <option value="America/New_York"    selected={formTimezone === 'America/New_York'}>Eastern (New York)</option>
            <option value="America/Chicago"     selected={formTimezone === 'America/Chicago'}>Central (Chicago)</option>
            <option value="America/Denver"      selected={formTimezone === 'America/Denver'}>Mountain (Denver)</option>
            <option value="America/Phoenix"     selected={formTimezone === 'America/Phoenix'}>Mountain no-DST (Phoenix)</option>
            <option value="America/Los_Angeles" selected={formTimezone === 'America/Los_Angeles'}>Pacific (Los Angeles)</option>
            <option value="America/Anchorage"   selected={formTimezone === 'America/Anchorage'}>Alaska (Anchorage)</option>
            <option value="Pacific/Honolulu"    selected={formTimezone === 'Pacific/Honolulu'}>Hawaii (Honolulu)</option>
            <option value="America/Halifax"     selected={formTimezone === 'America/Halifax'}>Atlantic (Halifax)</option>
            <option value="America/Toronto"     selected={formTimezone === 'America/Toronto'}>Toronto</option>
            <option value="America/Vancouver"   selected={formTimezone === 'America/Vancouver'}>Vancouver</option>
            <option value="America/Winnipeg"    selected={formTimezone === 'America/Winnipeg'}>Winnipeg</option>
            <option value="America/Mexico_City" selected={formTimezone === 'America/Mexico_City'}>Mexico City</option>
          </optgroup>
          <optgroup label="South America">
            <option value="America/Bogota"       selected={formTimezone === 'America/Bogota'}>Bogotá</option>
            <option value="America/Lima"         selected={formTimezone === 'America/Lima'}>Lima</option>
            <option value="America/Caracas"      selected={formTimezone === 'America/Caracas'}>Caracas</option>
            <option value="America/Santiago"     selected={formTimezone === 'America/Santiago'}>Santiago</option>
            <option value="America/Sao_Paulo"    selected={formTimezone === 'America/Sao_Paulo'}>São Paulo</option>
            <option value="America/Argentina/Buenos_Aires" selected={formTimezone === 'America/Argentina/Buenos_Aires'}>Buenos Aires</option>
          </optgroup>
          <optgroup label="Europe">
            <option value="Europe/London"    selected={formTimezone === 'Europe/London'}>London</option>
            <option value="Europe/Dublin"    selected={formTimezone === 'Europe/Dublin'}>Dublin</option>
            <option value="Europe/Lisbon"    selected={formTimezone === 'Europe/Lisbon'}>Lisbon</option>
            <option value="Europe/Paris"     selected={formTimezone === 'Europe/Paris'}>Paris</option>
            <option value="Europe/Berlin"    selected={formTimezone === 'Europe/Berlin'}>Berlin</option>
            <option value="Europe/Rome"      selected={formTimezone === 'Europe/Rome'}>Rome</option>
            <option value="Europe/Madrid"    selected={formTimezone === 'Europe/Madrid'}>Madrid</option>
            <option value="Europe/Amsterdam" selected={formTimezone === 'Europe/Amsterdam'}>Amsterdam</option>
            <option value="Europe/Brussels"  selected={formTimezone === 'Europe/Brussels'}>Brussels</option>
            <option value="Europe/Stockholm" selected={formTimezone === 'Europe/Stockholm'}>Stockholm</option>
            <option value="Europe/Oslo"      selected={formTimezone === 'Europe/Oslo'}>Oslo</option>
            <option value="Europe/Copenhagen" selected={formTimezone === 'Europe/Copenhagen'}>Copenhagen</option>
            <option value="Europe/Helsinki"  selected={formTimezone === 'Europe/Helsinki'}>Helsinki</option>
            <option value="Europe/Warsaw"    selected={formTimezone === 'Europe/Warsaw'}>Warsaw</option>
            <option value="Europe/Prague"    selected={formTimezone === 'Europe/Prague'}>Prague</option>
            <option value="Europe/Vienna"    selected={formTimezone === 'Europe/Vienna'}>Vienna</option>
            <option value="Europe/Zurich"    selected={formTimezone === 'Europe/Zurich'}>Zurich</option>
            <option value="Europe/Athens"    selected={formTimezone === 'Europe/Athens'}>Athens</option>
            <option value="Europe/Istanbul"  selected={formTimezone === 'Europe/Istanbul'}>Istanbul</option>
            <option value="Europe/Moscow"    selected={formTimezone === 'Europe/Moscow'}>Moscow</option>
            <option value="Europe/Kyiv"      selected={formTimezone === 'Europe/Kyiv'}>Kyiv</option>
          </optgroup>
          <optgroup label="Africa">
            <option value="Africa/Cairo"         selected={formTimezone === 'Africa/Cairo'}>Cairo</option>
            <option value="Africa/Johannesburg"  selected={formTimezone === 'Africa/Johannesburg'}>Johannesburg</option>
            <option value="Africa/Lagos"         selected={formTimezone === 'Africa/Lagos'}>Lagos</option>
            <option value="Africa/Nairobi"       selected={formTimezone === 'Africa/Nairobi'}>Nairobi</option>
          </optgroup>
          <optgroup label="Asia">
            <option value="Asia/Dubai"      selected={formTimezone === 'Asia/Dubai'}>Dubai</option>
            <option value="Asia/Karachi"    selected={formTimezone === 'Asia/Karachi'}>Karachi</option>
            <option value="Asia/Kolkata"    selected={formTimezone === 'Asia/Kolkata'}>Kolkata / Mumbai</option>
            <option value="Asia/Dhaka"      selected={formTimezone === 'Asia/Dhaka'}>Dhaka</option>
            <option value="Asia/Yangon"     selected={formTimezone === 'Asia/Yangon'}>Yangon</option>
            <option value="Asia/Bangkok"    selected={formTimezone === 'Asia/Bangkok'}>Bangkok</option>
            <option value="Asia/Jakarta"    selected={formTimezone === 'Asia/Jakarta'}>Jakarta</option>
            <option value="Asia/Singapore"  selected={formTimezone === 'Asia/Singapore'}>Singapore</option>
            <option value="Asia/Hong_Kong"  selected={formTimezone === 'Asia/Hong_Kong'}>Hong Kong</option>
            <option value="Asia/Shanghai"   selected={formTimezone === 'Asia/Shanghai'}>Beijing / Shanghai</option>
            <option value="Asia/Taipei"     selected={formTimezone === 'Asia/Taipei'}>Taipei</option>
            <option value="Asia/Seoul"      selected={formTimezone === 'Asia/Seoul'}>Seoul</option>
            <option value="Asia/Tokyo"      selected={formTimezone === 'Asia/Tokyo'}>Tokyo</option>
          </optgroup>
          <optgroup label="Australia / Pacific">
            <option value="Australia/Perth"      selected={formTimezone === 'Australia/Perth'}>Perth</option>
            <option value="Australia/Darwin"     selected={formTimezone === 'Australia/Darwin'}>Darwin</option>
            <option value="Australia/Brisbane"   selected={formTimezone === 'Australia/Brisbane'}>Brisbane</option>
            <option value="Australia/Adelaide"   selected={formTimezone === 'Australia/Adelaide'}>Adelaide</option>
            <option value="Australia/Sydney"     selected={formTimezone === 'Australia/Sydney'}>Sydney / Melbourne</option>
            <option value="Pacific/Auckland"     selected={formTimezone === 'Pacific/Auckland'}>Auckland</option>
            <option value="Pacific/Fiji"         selected={formTimezone === 'Pacific/Fiji'}>Fiji</option>
          </optgroup>
        </select>
        <span class="field-hint">Used for grouping your album activity by local date on your dashboard.</span>
      </div>
    </div>

    <div class="settings-footer">
      <button type="submit" class="btn btn-primary">Save Settings</button>
    </div>
  </form>
</Layout>

<style>
.settings-form {
  max-width: 520px;
  margin-top: 24px;
}
.settings-section {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 20px 24px;
  margin-bottom: 16px;
}
.settings-section h2 {
  font-size: 13px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--text-muted);
  margin: 0 0 16px;
}
.form-group {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-bottom: 16px;
}
.form-group:last-child { margin-bottom: 0; }
.form-group label:first-child {
  font-size: 13px;
  font-weight: 500;
  color: var(--text);
}
.form-group input[type="text"],
.form-group select {
  background: var(--bg);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 6px 10px;
  border-radius: 4px;
  font-size: 13px;
  font-family: inherit;
  width: 100%;
  box-sizing: border-box;
}
.form-group input[type="text"]:focus,
.form-group select:focus {
  outline: none;
  border-color: var(--accent);
}
.url-input-wrap {
  display: flex;
  align-items: center;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
}
.url-prefix {
  padding: 6px 8px 6px 10px;
  font-size: 13px;
  color: var(--text-muted);
  white-space: nowrap;
  border-right: 1px solid var(--border);
  background: var(--bg-card);
}
.url-input-wrap input {
  border: none !important;
  border-radius: 0 !important;
  flex: 1;
}
.url-input-wrap input:focus { outline: none; }
.field-hint {
  font-size: 11px;
  color: var(--text-muted);
  opacity: 0.7;
}
.field-error {
  font-size: 12px;
  color: #c06060;
}
.radio-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.radio-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--text);
  cursor: pointer;
}
.radio-label input[type="radio"] {
  width: auto;
  accent-color: var(--accent);
}
.settings-footer {
  display: flex;
  gap: 8px;
}
.flash-ok {
  color: #5a9e6f;
  font-size: 13px;
  margin-bottom: 12px;
}
</style>
