---
import Layout from '../layouts/Layout.astro';
import { env } from 'cloudflare:workers';

if (Astro.request.method === 'POST') {
  const db = env.DB;
  const data = await Astro.request.formData();

  const subgenres = JSON.stringify(
    ((data.get('subgenres') as string) ?? '').split(',').map(s => s.trim()).filter(Boolean)
  );
  const favTracks = JSON.stringify(
    ((data.get('fav_tracks') as string) ?? '').split(',').map(s => s.trim()).filter(Boolean)
  );

  await db.prepare(`
    INSERT INTO albums (mbid, artist, album, country, year, genre, subgenres, rating, notes, fav_tracks, recommended, cover_url)
    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
  `).bind(
    (data.get('mbid') as string) || null,
    data.get('artist') as string,
    data.get('album') as string,
    (data.get('country') as string) || '',
    data.get('year') ? parseInt(data.get('year') as string) : null,
    (data.get('genre') as string) || '',
    subgenres,
    data.get('rating') ? parseInt(data.get('rating') as string) : null,
    (data.get('notes') as string) || '',
    favTracks,
    data.get('recommended') === 'on' ? 1 : 0,
    (data.get('cover_url') as string) || null,
  ).run();

  return Astro.redirect('/');
}
---

<Layout title="Add Album">
  <div class="page-header">
    <h1>Add Album</h1>
    <a href="/" class="btn">← Back</a>
  </div>

  <!-- MusicBrainz autofill -->
  <div class="form-group mb-wrap">
    <label for="mb-search">Search MusicBrainz to autofill</label>
    <div class="mb-input-row">
      <input id="mb-search" type="text" placeholder="Artist, album title..." autocomplete="off" />
      <span class="spinner" id="mb-spinner"></span>
    </div>
    <div class="mb-results" id="mb-results"></div>
  </div>

  <form method="post" id="album-form">
    <input type="hidden" name="mbid"      id="f-mbid" />
    <input type="hidden" name="cover_url" id="f-cover-url" />

    <div class="form-grid">
      <div class="form-group">
        <label for="f-artist">Artist *</label>
        <input id="f-artist" name="artist" type="text" required />
      </div>
      <div class="form-group">
        <label for="f-album">Album *</label>
        <input id="f-album" name="album" type="text" required />
      </div>
      <div class="form-group">
        <label for="f-year">Year</label>
        <input id="f-year" name="year" type="number" min="1900" max="2099" />
      </div>
      <div class="form-group">
        <label for="f-country">Country</label>
        <input id="f-country" name="country" type="text" />
      </div>
      <div class="form-group">
        <label for="f-genre">Genre</label>
        <input id="f-genre" name="genre" type="text" placeholder="e.g. Black Metal" />
      </div>
      <div class="form-group">
        <label for="f-subgenres">Subgenres <span style="font-weight:400;text-transform:none;letter-spacing:0">(comma-separated)</span></label>
        <input id="f-subgenres" name="subgenres" type="text" placeholder="Melodic, Atmospheric" />
      </div>
      <div class="form-group">
        <label for="f-rating">Rating (0–100)</label>
        <input id="f-rating" name="rating" type="number" min="0" max="100" />
      </div>
      <div class="form-group" style="justify-content:flex-end;padding-bottom:18px">
        <label style="flex-direction:row;align-items:center;gap:8px;text-transform:none;letter-spacing:0;cursor:pointer">
          <input id="f-recommended" name="recommended" type="checkbox" style="width:auto" />
          Recommended
        </label>
      </div>
    </div>

    <div class="form-group">
      <label for="f-notes">Notes</label>
      <textarea id="f-notes" name="notes" rows="4" placeholder="Your thoughts..."></textarea>
    </div>

    <div class="form-group">
      <label for="f-fav-tracks">Favorite Tracks <span style="font-weight:400;text-transform:none;letter-spacing:0">(comma-separated)</span></label>
      <input id="f-fav-tracks" name="fav_tracks" type="text" />
    </div>

    <div class="cover-preview" id="cover-preview">
      <label>Cover Art</label>
      <img id="cover-img" src="" alt="Album cover" />
    </div>

    <div style="display:flex;gap:10px;margin-top:8px">
      <button class="btn btn-primary" type="submit">Save Album</button>
      <a href="/" class="btn">Cancel</a>
    </div>
  </form>
</Layout>

<script>
const searchInput = document.getElementById('mb-search') as HTMLInputElement;
const resultsEl   = document.getElementById('mb-results') as HTMLDivElement;
const spinner     = document.getElementById('mb-spinner') as HTMLSpanElement;

interface MBResult {
  mbid: string;
  title: string;
  artist: string;
  year: string;
  country: string;
  coverUrl: string;
}

let timer: ReturnType<typeof setTimeout>;

searchInput.addEventListener('input', () => {
  clearTimeout(timer);
  const q = searchInput.value.trim();
  if (q.length < 2) { close(); return; }
  timer = setTimeout(() => doSearch(q), 380);
});

async function doSearch(q: string) {
  spinner.classList.add('active');
  close();
  try {
    const res  = await fetch(`/api/musicbrainz?q=${encodeURIComponent(q)}`);
    const data = await res.json() as MBResult[];
    renderResults(data);
  } catch {
    resultsEl.innerHTML = '<p class="mb-empty">Search failed.</p>';
    resultsEl.classList.add('open');
  } finally {
    spinner.classList.remove('active');
  }
}

function renderResults(items: MBResult[]) {
  if (!items.length) {
    resultsEl.innerHTML = '<p class="mb-empty">No results.</p>';
    resultsEl.classList.add('open');
    return;
  }
  resultsEl.innerHTML = items.map((r, i) => `
    <div class="mb-item" data-i="${i}">
      <img class="mb-thumb" src="${r.coverUrl}" alt=""
           onerror="this.style.visibility='hidden'" loading="lazy" />
      <div class="mb-info">
        <strong>${esc(r.title)}</strong>
        <span>${esc(r.artist)}${r.year ? ' · ' + r.year : ''}${r.country ? ' · ' + r.country : ''}</span>
      </div>
    </div>
  `).join('');
  resultsEl.classList.add('open');
  resultsEl.querySelectorAll('.mb-item').forEach((el, i) => {
    el.addEventListener('click', () => pick(items[i]));
  });
}

function pick(r: MBResult) {
  set('f-mbid',       r.mbid);
  set('f-artist',     r.artist);
  set('f-album',      r.title);
  set('f-year',       r.year);
  set('f-country',    r.country);
  set('f-cover-url',  r.coverUrl);
  searchInput.value = `${r.artist} — ${r.title}`;
  if (r.coverUrl) {
    (document.getElementById('cover-img') as HTMLImageElement).src = r.coverUrl;
    (document.getElementById('cover-preview') as HTMLDivElement).style.display = 'block';
  }
  close();
}

function set(id: string, val: string) {
  (document.getElementById(id) as HTMLInputElement).value = val ?? '';
}
function close() { resultsEl.classList.remove('open'); resultsEl.innerHTML = ''; }
function esc(s: string) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

document.addEventListener('click', e => {
  if (!(e.target as Element).closest('.mb-wrap')) close();
});
</script>
