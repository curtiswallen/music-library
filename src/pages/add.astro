---
import Layout from '../layouts/Layout.astro';
import AlbumForm from '../components/AlbumForm.astro';
import { env } from 'cloudflare:workers';
import { generateUniqueSlug, normalizeSearch } from '../lib/utils';
import { syncArtistData, syncAllArtistsForAlbum } from '../lib/artist-cache';
import { getGenreCache } from '../lib/genre-cache';
import { getDescriptorCache } from '../lib/descriptor-cache';
import { invalidateLibraryOverview } from '../lib/library-cache';

const user = Astro.locals.user!;
const db   = env.DB;
const kv   = env.GENRE_CACHE;

if (Astro.request.method === 'POST') {
  const data      = await Astro.request.formData();
  const artist      = (data.getAll('artist') as string[]).map(s => s.trim()).filter(Boolean).join(' / ') || '';
  const album       = (data.get('album') as string) || '';
  const mbid        = (data.get('mbid') as string) || null;
  const artistMbid  = (data.get('artist_mbid') as string) || null;
  const releaseType = (data.get('release_type') as string) || null;
  const dbAlbumId   = (data.get('db_album_id') as string)
    ? parseInt(data.get('db_album_id') as string) : null;

  const subgenresList = ((data.get('subgenres') as string) ?? '').split(',').map(s => s.trim()).filter(Boolean);
  const subgenres = JSON.stringify(subgenresList);

  const canonicalDescriptors = await getDescriptorCache(kv, db);
  const canonicalSet = new Set(canonicalDescriptors.map(d => d.toLowerCase()));
  let descriptorsList: string[] = [];
  try { descriptorsList = JSON.parse((data.get('descriptors') as string) || '[]'); } catch {}
  const newDescriptors = descriptorsList.map(d => d.trim().toLowerCase()).filter(d => canonicalSet.has(d));
  const descriptorsJson = JSON.stringify(newDescriptors);

  let rawTracks: Array<Record<string, unknown>> = [];
  try { rawTracks = JSON.parse((data.get('tracks') as string) || '[]'); } catch {}

  const trackSeconds = rawTracks.reduce((s, t) => {
    const l = Number(t.length);
    return s + (Number.isFinite(l) && l > 0 ? l : 0);
  }, 0);

  const canonicalTracks = JSON.stringify(rawTracks.map(t => ({
    pos: t.pos, title: t.title, length: t.length ?? null,
  })));
  const tracksData = JSON.stringify(rawTracks.map(t => ({
    pos: t.pos, rating: t.rating ?? null, notable: t.notable ?? false, note: t.note ?? '',
  })));

  let albumId: number;
  let albumSlug: string;

  if (dbAlbumId) {
    const existing = await db.prepare('SELECT id, slug FROM albums WHERE id = ?')
      .bind(dbAlbumId).first<{ id: number; slug: string }>();
    if (!existing) return new Response('Album not found', { status: 404 });
    albumId   = existing.id;
    albumSlug = existing.slug;
  } else if (mbid) {
    const existing = await db.prepare('SELECT id, slug FROM albums WHERE mbid = ?')
      .bind(mbid).first<{ id: number; slug: string }>();
    if (existing) {
      albumId   = existing.id;
      albumSlug = existing.slug;
    } else {
      // Check for a manually-added row with matching artist+title that hasn't been linked to MB yet
      const manualMatch = await db.prepare(
        'SELECT id, slug FROM albums WHERE mbid IS NULL AND LOWER(artist) = LOWER(?) AND LOWER(album) = LOWER(?)'
      ).bind(artist, album).first<{ id: number; slug: string }>();

      if (manualMatch) {
        // Upgrade the existing row with MB data; preserve its slug so existing user URLs stay valid
        await db.prepare(`
          UPDATE albums SET
            mbid = ?, artist = ?, album = ?, country = ?, year = ?,
            cover_url = ?, tracks = ?, search_text = ?, artist_mbid = ?, release_type = ?
          WHERE id = ?
        `).bind(
          mbid, artist, album,
          (data.get('country') as string) || '',
          data.get('year') ? parseInt(data.get('year') as string) : null,
          (data.get('cover_url') as string) || null,
          canonicalTracks,
          normalizeSearch(`${artist} ${album}`),
          artistMbid, releaseType,
          manualMatch.id,
        ).run();
        albumId   = manualMatch.id;
        albumSlug = manualMatch.slug;
      } else {
        albumSlug = await generateUniqueSlug(db, artist, album);
        const r = await db.prepare(`
          INSERT INTO albums (mbid, slug, artist, album, country, year, cover_url, tracks, search_text, artist_mbid, release_type)
          VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        `).bind(
          mbid, albumSlug, artist, album,
          (data.get('country') as string) || '',
          data.get('year') ? parseInt(data.get('year') as string) : null,
          (data.get('cover_url') as string) || null,
          canonicalTracks,
          normalizeSearch(`${artist} ${album}`),
          artistMbid, releaseType,
        ).run();
        albumId = r.meta.last_row_id as number;
      }
    }
  } else {
    const existing = await db.prepare(
      'SELECT id, slug FROM albums WHERE LOWER(artist) = LOWER(?) AND LOWER(album) = LOWER(?)'
    ).bind(artist, album).first<{ id: number; slug: string }>();
    if (existing) {
      albumId   = existing.id;
      albumSlug = existing.slug;
    } else {
      albumSlug = await generateUniqueSlug(db, artist, album);
      const r = await db.prepare(`
        INSERT INTO albums (mbid, slug, artist, album, country, year, cover_url, tracks, search_text, artist_mbid, release_type)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
      `).bind(
        null, albumSlug, artist, album,
        (data.get('country') as string) || '',
        data.get('year') ? parseInt(data.get('year') as string) : null,
        (data.get('cover_url') as string) || null,
        canonicalTracks,
        normalizeSearch(`${artist} ${album}`),
        artistMbid, releaseType,
      ).run();
      albumId = r.meta.last_row_id as number;
    }
  }

  const alreadyLogged = await db.prepare(
    'SELECT 1 FROM user_albums WHERE user_id = ? AND album_id = ?'
  ).bind(user.id, albumId).first();
  if (alreadyLogged) {
    return Astro.redirect(`/${user.profile_url}/album/${albumSlug}`);
  }

  await db.prepare(`
    INSERT OR IGNORE INTO user_albums
      (user_id, album_id, genre, subgenres, rating, notes, tracks_data, recommended, is_hidden, release_mbid, release_title, release_data, descriptors, track_seconds)
    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
  `).bind(
    user.id,
    albumId,
    (data.get('genre') as string) || '',
    subgenres,
    data.get('rating') ? parseInt(data.get('rating') as string) : null,
    (data.get('notes') as string) || '',
    tracksData,
    data.get('recommended') === 'on' ? 1 : 0,
    data.get('is_hidden') === 'on' ? 1 : 0,
    (data.get('release_mbid') as string) || null,
    (data.get('release_title') as string) || null,
    (data.get('release_data') as string) || null,
    descriptorsJson,
    trackSeconds,
  ).run();

  if (data.get('rating')) {
    await db.prepare('UPDATE users SET total_seconds = total_seconds + ? WHERE id = ?')
      .bind(trackSeconds, user.id).run();
  }

  const trackRatingInserts = rawTracks
    .filter(t => t.rating != null)
    .map(t => db.prepare(
      'INSERT OR IGNORE INTO track_ratings (album_id, user_id, track_pos, rating) VALUES (?, ?, ?, ?)'
    ).bind(albumId, user.id, String(t.pos), Number(t.rating)));
  if (trackRatingInserts.length > 0) {
    await db.batch(trackRatingInserts);
  }

  await db.batch([
    db.prepare('DELETE FROM user_album_subgenres WHERE album_id = ? AND user_id = ?').bind(albumId, user.id),
    db.prepare('DELETE FROM user_album_descriptors WHERE album_id = ? AND user_id = ?').bind(albumId, user.id),
    ...subgenresList.map(s =>
      db.prepare('INSERT OR IGNORE INTO user_album_subgenres (album_id, user_id, subgenre) VALUES (?, ?, ?)').bind(albumId, user.id, s)
    ),
    ...newDescriptors.map(d =>
      db.prepare('INSERT OR IGNORE INTO user_album_descriptors (album_id, user_id, descriptor) VALUES (?, ?, ?)').bind(albumId, user.id, d)
    ),
  ]);

  await db.prepare(`
    UPDATE albums SET
      logged_by_user_ids = (SELECT json_group_array(user_id) FROM user_albums WHERE album_id = ? AND (is_queued = 0 OR is_queued IS NULL)),
      all_subgenres      = COALESCE((SELECT json_group_array(subgenre)    FROM (SELECT DISTINCT subgenre    FROM user_album_subgenres  WHERE album_id = ?)), '[]'),
      all_descriptors    = COALESCE((SELECT json_group_array(descriptor)  FROM (SELECT DISTINCT descriptor  FROM user_album_descriptors WHERE album_id = ?)), '[]'),
      genre_counts       = COALESCE((SELECT json_group_object(genre, cnt) FROM (SELECT genre, COUNT(*) as cnt FROM user_albums WHERE album_id = ? AND genre != '' GROUP BY genre)), '{}'),
      subgenre_counts    = COALESCE((SELECT json_group_object(subgenre, cnt)    FROM (SELECT subgenre,    COUNT(*) as cnt FROM user_album_subgenres  WHERE album_id = ? GROUP BY subgenre)),    '{}'),
      descriptor_counts  = COALESCE((SELECT json_group_object(descriptor, cnt) FROM (SELECT descriptor,  COUNT(*) as cnt FROM user_album_descriptors WHERE album_id = ? GROUP BY descriptor)),  '{}'),
      avg_rating         = (SELECT AVG(rating)   FROM user_albums WHERE album_id = ? AND rating IS NOT NULL),
      rating_count       = (SELECT COUNT(rating) FROM user_albums WHERE album_id = ? AND rating IS NOT NULL)
    WHERE id = ?
  `).bind(albumId, albumId, albumId, albumId, albumId, albumId, albumId, albumId, albumId).run();

  await invalidateLibraryOverview(kv, user.id);

  if (artist.includes(' / ') && mbid) {
    Astro.locals.cfContext.waitUntil(syncAllArtistsForAlbum(db, mbid));
  } else if (artistMbid) {
    const primaryArtist = artist.split(' / ')[0].trim();
    Astro.locals.cfContext.waitUntil(syncArtistData(db, artistMbid, primaryArtist));
  }

  return Astro.redirect(`/${user.profile_url}/album/${albumSlug}`);
}

const [{ genreMap, groupedGenres }, canonicalDescriptors] = await Promise.all([
  getGenreCache(kv, db),
  getDescriptorCache(kv, db),
]);
---

<Layout title="Add Album">
  <div class="page-header">
    <h1>Add Album</h1>
    <a href={`/${user.profile_url}`} class="btn">← Back</a>
  </div>

  <div id="add-wrapper" data-profile-url={user.profile_url}>
    <AlbumForm includeDbAlbumId submitLabel="Save Album" cancelHref={`/${user.profile_url}`} genreMap={genreMap} groupedGenres={groupedGenres} canonicalDescriptors={canonicalDescriptors}>
      <button slot="extra-actions" id="add-to-queue-btn" class="btn" type="button"
              style="display:none;margin-left:auto" title="Add to queue without rating">
        Add to Queue
      </button>
    </AlbumForm>
  </div>
</Layout>

<script>
import { initAlbumForm, setArtists, setDescriptors, populateReleaseSelect, readGenreMap } from '../lib/album-form';
import type { TrackData } from '../lib/album-form';

interface MBResult {
  mbid:        string;
  title:       string;
  artist:      string;
  artists:     string[];
  artistId:    string;
  year:        string;
  tags:        string[];
  coverUrl:    string;
  releaseType: string;
  dbId?:       number;
  country?:    string;
  slug?:       string;
  fromDb?:     boolean;
  inLibrary?:  boolean;
  dbTracks?:   Array<{ pos: number; title: string; length: number | null }>;
}

const profileUrl = (document.getElementById('add-wrapper') as HTMLElement).dataset.profileUrl!;

const { setTracks, renderSubgenreWidget, setSelectedSubs } = initAlbumForm();

// ── MusicBrainz search ──────────────────────────────────────────────────────
const searchInput = document.getElementById('mb-search') as HTMLInputElement;
const resultsEl   = document.getElementById('mb-results') as HTMLDivElement;
const spinner     = document.getElementById('mb-spinner') as HTMLSpanElement;

let timer: ReturnType<typeof setTimeout>;
let searchSeq = 0;

searchInput.addEventListener('input', () => {
  clearTimeout(timer);
  const q = searchInput.value.trim();
  if (q.length < 2) { closeResults(); return; }
  timer = setTimeout(() => doSearch(q), 380);
});

async function doSearch(q: string) {
  const seq = ++searchSeq;
  spinner.classList.add('active');
  closeResults();
  try {
    const res  = await fetch(`/api/musicbrainz?q=${encodeURIComponent(q)}`);
    if (seq !== searchSeq) return;
    const data = await res.json() as MBResult[];
    renderResults(data);
  } catch {
    if (seq !== searchSeq) return;
    resultsEl.innerHTML = '<p class="mb-empty">Search failed.</p>';
    resultsEl.classList.add('open');
  } finally {
    if (seq === searchSeq) spinner.classList.remove('active');
  }
}

function renderResults(items: MBResult[]) {
  if (!items.length) {
    resultsEl.innerHTML = '<p class="mb-empty">No results.</p>';
    resultsEl.classList.add('open');
    return;
  }
  resultsEl.innerHTML = items.map((r, i) => `
    <div class="mb-item${r.inLibrary ? ' mb-item-in-library' : ''}" data-i="${i}">
      <div class="mb-thumb-wrap">
        <img class="mb-thumb" src="${esc(r.coverUrl)}" alt=""
             onerror="this.style.opacity='0'" loading="lazy" />
      </div>
      <div class="mb-info">
        <strong>${esc(r.title)}</strong>
        <span>${esc(r.artist)}${r.year ? ' · ' + r.year : ''}${r.inLibrary ? ' <span class="mb-in-library-badge">In library</span>' : ''}</span>
      </div>
    </div>
  `).join('');
  resultsEl.classList.add('open');
  resultsEl.querySelectorAll('.mb-item').forEach((el, i) => {
    el.addEventListener('click', () => pick(items[i]));
  });
}

function pick(r: MBResult) {
  if (r.inLibrary && r.slug) {
    window.location.href = `/${profileUrl}/album/${r.slug}`;
    return;
  }
  set('f-mbid',        r.mbid ?? '');
  set('f-db-album-id', r.dbId ? String(r.dbId) : '');
  set('f-artist-mbid', r.artistId ?? '');
  set('f-release-type', r.releaseType ?? '');
  setCanonicalLocked(!!r.mbid);
  setArtists(r.artists?.length ? r.artists : r.artist.split(' / '));
  set('f-album',  r.title);
  set('f-year',   r.year);
  searchInput.value = `${r.artist} — ${r.title}`;

  if (r.tags?.length) resolveGenre(r.tags);

  if (r.country) {
    set('f-country', r.country);
  } else if (r.artistId) {
    fetch(`/api/musicbrainz-artist?id=${encodeURIComponent(r.artistId)}`)
      .then(res => res.json())
      .then(data => { const d = data as { country: string }; if (d.country) set('f-country', d.country); })
      .catch(() => {});
  }

  if (r.dbTracks?.length && !r.mbid) {
    setTracks(r.dbTracks.map(t => ({ pos: t.pos, title: t.title, length: t.length, rating: null, notable: false, note: '' })));
  } else if (r.mbid) {
    const loadingEl = document.getElementById('tracks-loading') as HTMLElement;
    loadingEl.hidden = false;
    setTracks([]);
    fetch(`/api/musicbrainz-release?id=${encodeURIComponent(r.mbid)}`)
      .then(res => res.json())
      .then(data => { setTracks(data as TrackData[]); })
      .catch(() => {})
      .finally(() => { loadingEl.hidden = true; });
  }

  // Reset release select, then fetch releases if we have an MBID
  populateReleaseSelect([]);
  set('f-release-mbid', '');
  set('f-release-title', '');
  if (r.mbid) {
    fetch(`/api/musicbrainz-releases?rgId=${encodeURIComponent(r.mbid)}`)
      .then(res => res.json())
      .then(data => { populateReleaseSelect(data as Array<{ id: string; label: string; data?: unknown }>); })
      .catch(() => {});
  }

  const coverPreview    = document.getElementById('cover-preview')    as HTMLElement;
  const coverUploadWrap = document.getElementById('cover-upload-wrap') as HTMLElement;
  const img             = document.getElementById('cover-img')        as HTMLImageElement;
  if (r.coverUrl) {
    img.onload  = () => {
      img.style.display = '';
      set('f-cover-url', r.coverUrl);
      coverPreview.style.display    = 'block';
      coverUploadWrap.style.display = 'none';
    };
    img.onerror = () => {
      set('f-cover-url', '');
      coverPreview.style.display    = 'none';
      coverUploadWrap.style.display = '';
    };
    img.src = r.coverUrl;
  } else {
    set('f-cover-url', '');
    coverPreview.style.display    = 'none';
    coverUploadWrap.style.display = '';
  }

  closeResults();
  document.getElementById('album-form')?.dispatchEvent(new Event('input'));

  // Reveal the "Add to Queue" shortcut once an album is selected
  const qBtn = document.getElementById('add-to-queue-btn') as HTMLButtonElement | null;
  if (qBtn) {
    qBtn.style.display = '';
    qBtn.dataset.mbid        = r.mbid        ?? '';
    qBtn.dataset.title       = r.title       ?? '';
    qBtn.dataset.artist      = r.artist      ?? '';
    qBtn.dataset.year        = r.year        ?? '';
    qBtn.dataset.coverUrl    = r.coverUrl    ?? '';
    qBtn.dataset.releaseType = r.releaseType ?? '';
    qBtn.dataset.artistMbid  = r.artistId    ?? '';
    qBtn.dataset.dbId        = r.dbId        != null ? String(r.dbId) : '';
  }
}

function resolveGenre(tags: string[]) {
  const genreInput = document.getElementById('f-genre') as HTMLInputElement;
  if (genreInput.value) return;

  const genreNames = Object.keys(readGenreMap());
  // Broad tags that should lose to any specific match
  const GENERIC = new Set(['rock', 'pop', 'electronic', 'folk', 'jazz', 'classical',
                            'blues', 'country', 'world music', 'experimental', 'ambient', 'metal']);

  // Collect exact matches across all tags (tags are ordered by MB vote count)
  const exactMatches: string[] = [];
  for (const t of tags) {
    const key = genreNames.find(k => k.toLowerCase() === t.trim().toLowerCase());
    if (key && !exactMatches.includes(key)) exactMatches.push(key);
  }

  // Prefer specific over generic; fall back to first exact match
  const best = exactMatches.find(k => !GENERIC.has(k.toLowerCase())) ?? exactMatches[0];
  if (best) {
    set('f-genre', best);
    setSelectedSubs([]);
    return;
  }

  // No exact match: try partial match across all tags (handles "melodic black metal" → genre + subgenre)
  for (const t of tags) {
    const tag = t.trim().toLowerCase();
    const matchKey = genreNames.find(k => tag.includes(k.toLowerCase()));
    if (matchKey) {
      set('f-genre', matchKey);
      const prefix = tag.replace(matchKey.toLowerCase(), '').trim();
      setSelectedSubs([]);
      renderSubgenreWidget();
      if (prefix) {
        const prefixTitle = prefix.replace(/\b\w/g, c => c.toUpperCase());
        const subChips = document.querySelectorAll<HTMLButtonElement>('.subgenre-chip');
        const match = Array.from(subChips).find(c => c.dataset.sub?.toLowerCase() === prefixTitle.toLowerCase());
        if (match) match.click();
      }
      return;
    }
  }
}

function set(id: string, val: string) {
  const el = document.getElementById(id) as HTMLInputElement;
  if (!el) return;
  el.value = val ?? '';
  if (id === 'f-release-type') {
    const h = document.getElementById('f-release-type-val') as HTMLInputElement | null;
    if (h) h.value = val ?? '';
  }
  const hidden = el.closest?.('.combo')?.querySelector<HTMLInputElement>('.combo-hidden');
  if (hidden) hidden.value = val ?? '';
}

function setReleaseTypeLocked(locked: boolean) {
  const sel  = document.getElementById('f-release-type')      as HTMLSelectElement | null;
  const note = document.getElementById('f-release-type-note') as HTMLElement | null;
  if (sel)  sel.disabled       = locked;
  if (note) note.style.display = locked ? '' : 'none';
}
function setCanonicalLocked(locked: boolean) {
  document.querySelectorAll<HTMLInputElement>('.artist-input').forEach(el => { el.readOnly = locked; });
  const addBtn = document.getElementById('add-artist-btn') as HTMLButtonElement | null;
  if (addBtn) addBtn.style.display = locked ? 'none' : '';
  document.querySelectorAll<HTMLButtonElement>('.remove-artist-btn').forEach(btn => {
    if (locked) { btn.style.display = 'none'; }
    else { const count = document.querySelectorAll('.artist-input').length; btn.style.display = count > 1 ? '' : 'none'; }
  });
  const albumInput = document.getElementById('f-album') as HTMLInputElement | null;
  if (albumInput) albumInput.readOnly = locked;
  const yearInput = document.getElementById('f-year') as HTMLInputElement | null;
  if (yearInput) yearInput.readOnly = locked;
  setReleaseTypeLocked(locked);
  const replaceBtn = document.getElementById('cover-replace-btn') as HTMLButtonElement | null;
  if (replaceBtn) replaceBtn.style.display = locked ? 'none' : '';
  const note = document.getElementById('canonical-lock-note') as HTMLElement | null;
  if (note) note.style.display = locked ? '' : 'none';
}
function closeResults() { resultsEl.classList.remove('open'); resultsEl.innerHTML = ''; }

document.getElementById('clear-form-btn')?.addEventListener('click', () => {
  const qBtn = document.getElementById('add-to-queue-btn') as HTMLButtonElement | null;
  if (qBtn) qBtn.style.display = 'none';
  searchInput.value = '';
  closeResults();
  setArtists(['']);
  set('f-mbid', '');
  set('f-db-album-id', '');
  set('f-artist-mbid', '');
  set('f-release-type', '');
  setCanonicalLocked(false);
  set('f-album', '');
  set('f-year', '');
  set('f-country', '');
  set('f-genre', '');
  setSelectedSubs([]);
  set('f-cover-url', '');
  set('f-release-mbid', '');
  set('f-release-title', '');
  set('f-release-data', '');
  setDescriptors([]);
  setTracks([]);
  populateReleaseSelect([]);
  const notes = document.getElementById('f-notes') as HTMLTextAreaElement | null;
  if (notes) notes.value = '';
  (document.getElementById('clear-rating') as HTMLButtonElement | null)?.click();
  const img = document.getElementById('cover-img') as HTMLImageElement | null;
  if (img) img.src = '';
  const coverPreview    = document.getElementById('cover-preview')     as HTMLElement | null;
  const coverUploadWrap = document.getElementById('cover-upload-wrap') as HTMLElement | null;
  if (coverPreview)    coverPreview.style.display    = 'none';
  if (coverUploadWrap) coverUploadWrap.style.display = '';
  const recommended = document.querySelector<HTMLInputElement>('[name="recommended"]');
  const isHidden    = document.querySelector<HTMLInputElement>('[name="is_hidden"]');
  if (recommended) recommended.checked = false;
  if (isHidden)    isHidden.checked    = false;
  document.getElementById('rec-btn')?.classList.remove('active');
  document.getElementById('hidden-btn')?.classList.remove('active');
  const loadingEl = document.getElementById('tracks-loading') as HTMLElement | null;
  if (loadingEl) loadingEl.hidden = true;
  document.getElementById('album-form')?.dispatchEvent(new Event('input'));
});

function esc(s: string) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

document.addEventListener('click', e => {
  if (!(e.target as Element).closest('.mb-wrap')) closeResults();
});

// ── Pre-fill from URL params (e.g. "Log Album" on album detail pages) ───────
(function () {
  const params      = new URLSearchParams(window.location.search);
  const dbId        = params.get('dbId');
  const mbid        = params.get('mbid');
  const title       = params.get('title');
  const artist      = params.get('artist');
  const year        = params.get('year');
  const cover       = params.get('cover');
  const releaseType = params.get('releaseType');
  const artistMbid  = params.get('artistMbid');

  if (!title && !artist) return;

  set('f-mbid',        mbid        ?? '');
  set('f-db-album-id', dbId        ?? '');
  set('f-artist-mbid', artistMbid  ?? '');
  set('f-release-type', releaseType ?? '');
  setArtists(artist ? artist.split(' / ') : ['']);
  set('f-album', title  ?? '');
  set('f-year',  year   ?? '');
  setCanonicalLocked(!!mbid);

  if (cover) {
    const img             = document.getElementById('cover-img')         as HTMLImageElement | null;
    const coverPreview    = document.getElementById('cover-preview')     as HTMLElement | null;
    const coverUploadWrap = document.getElementById('cover-upload-wrap') as HTMLElement | null;
    if (img) {
      img.onload  = () => { img.style.display = ''; set('f-cover-url', cover); if (coverPreview) coverPreview.style.display = 'block'; if (coverUploadWrap) coverUploadWrap.style.display = 'none'; };
      img.onerror = () => { set('f-cover-url', ''); if (coverPreview) coverPreview.style.display = 'none'; if (coverUploadWrap) coverUploadWrap.style.display = ''; };
      img.src = cover;
    }
  }

  if (mbid) {
    const loadingEl = document.getElementById('tracks-loading') as HTMLElement | null;
    if (loadingEl) loadingEl.hidden = false;
    setTracks([]);
    fetch(`/api/musicbrainz-release?id=${encodeURIComponent(mbid)}`)
      .then(res => res.json())
      .then(data => { setTracks(data as TrackData[]); })
      .catch(() => {})
      .finally(() => { if (loadingEl) loadingEl.hidden = true; });
    fetch(`/api/musicbrainz-releases?rgId=${encodeURIComponent(mbid)}`)
      .then(res => res.json())
      .then(data => { populateReleaseSelect(data as Array<{ id: string; label: string; data?: unknown }>); })
      .catch(() => {});
  }

  const qBtn = document.getElementById('add-to-queue-btn') as HTMLButtonElement | null;
  if (qBtn) {
    qBtn.style.display     = '';
    qBtn.dataset.mbid        = mbid        ?? '';
    qBtn.dataset.title       = title       ?? '';
    qBtn.dataset.artist      = artist      ?? '';
    qBtn.dataset.year        = year        ?? '';
    qBtn.dataset.coverUrl    = cover       ?? '';
    qBtn.dataset.releaseType = releaseType ?? '';
    qBtn.dataset.artistMbid  = artistMbid  ?? '';
    qBtn.dataset.dbId        = dbId        ?? '';
  }
})();

// ── "Add to Queue" shortcut button ─────────────────────────────────────────
(document.getElementById('add-to-queue-btn') as HTMLButtonElement | null)
  ?.addEventListener('click', async function () {
    const btn = this as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '…';

    const body = btn.dataset.dbId
      ? { albumId: parseInt(btn.dataset.dbId, 10) }
      : {
          mbid:        btn.dataset.mbid        || undefined,
          title:       btn.dataset.title       || '',
          artist:      btn.dataset.artist      || '',
          year:        btn.dataset.year        ? parseInt(btn.dataset.year, 10) : undefined,
          coverUrl:    btn.dataset.coverUrl    || undefined,
          releaseType: btn.dataset.releaseType || undefined,
          artistMbid:  btn.dataset.artistMbid  || undefined,
        };

    const res = await fetch('/api/queue', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    if (res.ok || res.status === 409) {
      window.location.href = `/${profileUrl}/library`;
    } else {
      btn.textContent = 'Add to Queue';
      btn.disabled = false;
    }
  });
</script>
