---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title } = Astro.props;
const pageTitle = title ? `${title} — Music Library` : 'Music Library';
const user = Astro.locals.user;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{pageTitle}</title>
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        if (saved) document.documentElement.setAttribute('data-theme', saved);
      })();
    </script>
  </head>
  <body>
    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark/light mode" title="Toggle theme">
      <span class="theme-icon"></span>
    </button>
    <nav>
      <div style="display:flex;gap:8px;align-items:center">
        {user ? (
          <>
            <a href={`/${user.profile_url}`} class="user-chip nav-hide-mobile">{user.display_name || user.username}</a>
            {user.is_admin === 1 && <a href="/admin" class="btn nav-hide-mobile">Admin</a>}
            <a href="/settings" class="btn icon-btn nav-hide-mobile" aria-label="Settings" data-tip="Settings">⚙</a>
            <form method="post" action="/auth/logout" style="margin:0" class="nav-hide-mobile">
              <button class="btn" type="submit">Sign out</button>
            </form>
            <button id="add-album-btn" class="btn icon-btn" aria-label="Log Album" data-tip="Log Album"
                    data-profile-url={user.profile_url} type="button">+</button>
            <div class="nav-hamburger" id="nav-hamburger">
              <button class="btn nav-hamburger-btn" id="nav-hamburger-btn" aria-label="Menu" aria-expanded="false">☰</button>
              <div class="nav-hamburger-menu" id="nav-hamburger-menu" hidden>
                <div class="nav-hamburger-header">
                  {user.avatar_url && <img src={user.avatar_url} class="profile-avatar" alt="" />}
                  <span>{user.display_name || user.username}</span>
                </div>
                <a href="/" class="nav-hamburger-item">Community</a>
                <a href={`/${user.profile_url}`} class="nav-hamburger-item">Dashboard</a>
                <a href={`/${user.profile_url}/library`} class="nav-hamburger-item">My Library</a>
                <a href="/add" class="nav-hamburger-item">Add Album</a>
                {user.is_admin === 1 && <a href="/admin" class="nav-hamburger-item">Admin</a>}
                <a href="/settings" class="nav-hamburger-item">Settings</a>
                <form method="post" action="/auth/logout" style="margin:0">
                  <button type="submit" class="nav-hamburger-item">Sign out</button>
                </form>
              </div>
            </div>
          </>
        ) : (
          <a href="/auth/login" class="btn">Sign In</a>
        )}
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <script is:inline>
      (function () {
        const btn = document.getElementById('theme-toggle');
        function getEffective() {
          const saved = localStorage.getItem('theme');
          if (saved) return saved;
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        function apply(theme) {
          document.documentElement.setAttribute('data-theme', theme);
          localStorage.setItem('theme', theme);
          btn.querySelector('.theme-icon').textContent = theme === 'dark' ? '☀' : '☾';
        }
        apply(getEffective());
        btn.addEventListener('click', function () {
          apply(getEffective() === 'dark' ? 'light' : 'dark');
        });
      })();

      (function () {
        var hbtn = document.getElementById('nav-hamburger-btn');
        var menu = document.getElementById('nav-hamburger-menu');
        if (!hbtn || !menu) return;
        hbtn.addEventListener('click', function (e) {
          e.stopPropagation();
          var open = menu.hidden;
          menu.hidden = !open;
          hbtn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
        document.addEventListener('click', function (e) {
          if (!e.target.closest('#nav-hamburger')) {
            menu.hidden = true;
            hbtn.setAttribute('aria-expanded', 'false');
          }
        });
      })();
    </script>

    <!-- Album-pick modal (search MB → navigate to /add?params) -->
    <div id="ap-modal" class="confirm-overlay" style="display:none">
      <div class="qa-box">
        <div class="qa-header">
          <span class="qa-title">Log an Album</span>
          <button id="ap-close" class="btn" type="button">×</button>
        </div>
        <div style="position:relative">
          <input id="ap-input" type="text" class="search-input qa-search-input"
                 placeholder="Search MusicBrainz..." autocomplete="off" spellcheck="false" />
          <span id="ap-spinner" class="spinner" style="position:absolute;right:10px;top:50%;transform:translateY(-50%)"></span>
        </div>
        <div id="ap-results" class="mb-results qa-results"></div>
      </div>
    </div>

    <!-- Queue-add modal -->
    <div id="qa-modal" class="confirm-overlay" style="display:none">
      <div class="qa-box">
        <div class="qa-header">
          <span class="qa-title">Add to Queue</span>
          <button id="qa-close" class="btn" type="button">×</button>
        </div>
        <div style="position:relative">
          <input id="qa-input" type="text" class="search-input qa-search-input"
                 placeholder="Search MusicBrainz..." autocomplete="off" spellcheck="false" />
          <span id="qa-spinner" class="spinner" style="position:absolute;right:10px;top:50%;transform:translateY(-50%)"></span>
        </div>
        <div id="qa-results" class="mb-results qa-results"></div>
        <p id="qa-msg" style="display:none" class="qa-msg"></p>
      </div>
    </div>

    <!-- Confirm modal -->
    <div id="confirm-modal" class="confirm-overlay" style="display:none">
      <div class="confirm-box">
        <div class="confirm-body">
          <img id="confirm-modal-cover" class="confirm-cover" src="" alt="" hidden />
          <p id="confirm-modal-msg" class="confirm-msg"></p>
        </div>
        <div class="confirm-actions">
          <button id="confirm-modal-cancel" class="btn">Cancel</button>
          <button id="confirm-modal-ok" class="btn btn-danger">Confirm</button>
        </div>
      </div>
    </div>

    <script is:inline>
    (function () {
      var overlay   = document.getElementById('confirm-modal');
      var msgEl     = document.getElementById('confirm-modal-msg');
      var coverImg  = document.getElementById('confirm-modal-cover');
      var okBtn     = document.getElementById('confirm-modal-ok');
      var cancelBtn = document.getElementById('confirm-modal-cancel');
      var _resolve  = null;
      function close(result) {
        overlay.style.display = 'none';
        if (_resolve) { _resolve(result); _resolve = null; }
      }
      function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }
      cancelBtn.addEventListener('click', function () { close(false); });
      okBtn.addEventListener('click', function () { close(true); });
      overlay.addEventListener('click', function (e) { if (e.target === overlay) close(false); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && overlay.style.display !== 'none') close(false); });
      window.showConfirm = function (message, okLabel, opts) {
        return new Promise(function (resolve) {
          _resolve = resolve;
          if (opts && opts.albumName) {
            msgEl.innerHTML = 'Remove <span class="confirm-album-name">' + escHtml(opts.albumName) + '</span> from your queue?';
          } else {
            msgEl.textContent = message;
          }
          okBtn.textContent = okLabel || 'Confirm';
          if (opts && opts.coverUrl) {
            coverImg.src = opts.coverUrl;
            coverImg.hidden = false;
          } else {
            coverImg.src = '';
            coverImg.hidden = true;
          }
          overlay.style.display = 'flex';
          okBtn.focus();
        });
      };
    })();
    </script>

    <script is:inline>
    (function () {
      var modal    = document.getElementById('ap-modal');
      var closeBtn = document.getElementById('ap-close');
      var input    = document.getElementById('ap-input');
      var spinner  = document.getElementById('ap-spinner');
      var results  = document.getElementById('ap-results');
      var navBtn   = document.getElementById('add-album-btn');
      if (!modal) return;

      var _timer, _seq = 0;
      var profileUrl = (navBtn && navBtn.dataset.profileUrl) || '';

      function openModal() {
        input.value = '';
        results.innerHTML = '';
        results.classList.remove('open');
        modal.style.display = 'flex';
        setTimeout(function () { input.focus(); }, 50);
      }
      function closeModal() { modal.style.display = 'none'; _seq++; }

      if (navBtn) navBtn.addEventListener('click', openModal);
      closeBtn.addEventListener('click', closeModal);
      modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal.style.display !== 'none') closeModal();
      });

      input.addEventListener('input', function () {
        clearTimeout(_timer);
        var q = input.value.trim();
        if (q.length < 2) { results.innerHTML = ''; results.classList.remove('open'); return; }
        _timer = setTimeout(function () { doSearch(q); }, 380);
      });

      function doSearch(q) {
        var seq = ++_seq;
        spinner.classList.add('active');
        results.innerHTML = ''; results.classList.remove('open');
        fetch('/api/musicbrainz?q=' + encodeURIComponent(q))
          .then(function (r) { return r.json(); })
          .then(function (data) { if (seq !== _seq) return; renderItems(data); })
          .catch(function () {
            if (seq !== _seq) return;
            results.innerHTML = '<p class="mb-empty">Search failed.</p>';
            results.classList.add('open');
          })
          .finally(function () { if (seq === _seq) spinner.classList.remove('active'); });
      }

      function esc(s) {
        return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      function renderItems(items) {
        if (!items || !items.length) {
          results.innerHTML = '<p class="mb-empty">No results.</p>';
          results.classList.add('open');
          return;
        }
        results.innerHTML = items.map(function (r, i) {
          return '<div class="mb-item' + (r.inLibrary ? ' mb-item-in-library' : '') + '" data-i="' + i + '">'
            + '<div class="mb-thumb-wrap"><img class="mb-thumb" src="' + esc(r.coverUrl) + '" alt=""'
            + ' onerror="this.style.opacity=\'0\'" loading="lazy" /></div>'
            + '<div class="mb-info"><strong>' + esc(r.title) + '</strong>'
            + '<span>' + esc(r.artist) + (r.year ? ' · ' + r.year : '')
            + (r.inLibrary ? ' <span class="mb-in-library-badge">In library</span>' : '') + '</span>'
            + '</div></div>';
        }).join('');
        results.classList.add('open');
        var stored = items.slice();
        results.querySelectorAll('.mb-item').forEach(function (el, i) {
          el.addEventListener('click', function () { pickItem(stored[i]); });
        });
      }

      function pickItem(r) {
        if (r.inLibrary && r.slug && profileUrl) {
          window.location.href = '/' + profileUrl + '/album/' + r.slug;
          return;
        }
        var p = new URLSearchParams();
        if (r.dbId != null) p.set('dbId', String(r.dbId));
        if (r.mbid)         p.set('mbid', r.mbid);
        window.location.href = '/add?' + p.toString();
      }

      window.showAlbumPick = openModal;
    })();
    </script>

    <script is:inline>
    (function () {
      var modal   = document.getElementById('qa-modal');
      var closeBtn = document.getElementById('qa-close');
      var input   = document.getElementById('qa-input');
      var spinner = document.getElementById('qa-spinner');
      var results = document.getElementById('qa-results');
      var msg     = document.getElementById('qa-msg');
      if (!modal) return;

      var _timer, _seq = 0, _onQueued = null;

      function openModal(onQueued) {
        _onQueued = onQueued || null;
        input.value = '';
        results.innerHTML = '';
        results.classList.remove('open');
        msg.style.display = 'none';
        modal.style.display = 'flex';
        setTimeout(function () { input.focus(); }, 50);
      }
      function closeModal() {
        modal.style.display = 'none';
        _seq++; // cancel in-flight searches
        _onQueued = null;
      }

      closeBtn.addEventListener('click', closeModal);
      modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modal.style.display !== 'none') closeModal();
      });

      input.addEventListener('input', function () {
        clearTimeout(_timer);
        var q = input.value.trim();
        if (q.length < 2) { results.innerHTML = ''; results.classList.remove('open'); return; }
        _timer = setTimeout(function () { doSearch(q); }, 380);
      });

      function doSearch(q) {
        var seq = ++_seq;
        spinner.classList.add('active');
        results.innerHTML = ''; results.classList.remove('open');
        fetch('/api/musicbrainz?q=' + encodeURIComponent(q))
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (seq !== _seq) return;
            renderItems(data);
          })
          .catch(function () {
            if (seq !== _seq) return;
            results.innerHTML = '<p class="mb-empty">Search failed.</p>';
            results.classList.add('open');
          })
          .finally(function () { if (seq === _seq) spinner.classList.remove('active'); });
      }

      function esc(s) {
        return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      function renderItems(items) {
        if (!items || !items.length) {
          results.innerHTML = '<p class="mb-empty">No results.</p>';
          results.classList.add('open');
          return;
        }
        results.innerHTML = items.map(function (r, i) {
          return '<div class="mb-item' + (r.inLibrary ? ' mb-item-in-library' : '') + '" data-i="' + i + '">'
            + '<div class="mb-thumb-wrap"><img class="mb-thumb" src="' + esc(r.coverUrl) + '" alt=""'
            + ' onerror="this.style.opacity=\'0\'" loading="lazy" /></div>'
            + '<div class="mb-info"><strong>' + esc(r.title) + '</strong>'
            + '<span>' + esc(r.artist) + (r.year ? ' · ' + r.year : '')
            + (r.inLibrary ? ' <span class="mb-in-library-badge">In library</span>' : '') + '</span>'
            + '</div></div>';
        }).join('');
        results.classList.add('open');
        var stored = items.slice();
        results.querySelectorAll('.mb-item').forEach(function (el, i) {
          el.addEventListener('click', function () { queueItem(stored[i]); });
        });
      }

      function queueItem(r) {
        results.innerHTML = ''; results.classList.remove('open');
        spinner.classList.add('active');
        input.disabled = true;
        msg.style.display = 'none';

        var body = r.dbId != null
          ? { albumId: r.dbId }
          : { mbid: r.mbid, title: r.title, artist: r.artist,
              year: r.year ? parseInt(r.year, 10) : null,
              coverUrl: r.coverUrl, releaseType: r.releaseType, artistMbid: r.artistId };

        fetch('/api/queue', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        })
          .then(function (res) { return res.json().then(function (d) { return { ok: res.ok, status: res.status, data: d }; }); })
          .then(function (res) {
            spinner.classList.remove('active');
            input.disabled = false;
            if (res.ok || res.status === 409) {
              if (res.status === 409 && res.data.status === 'logged') {
                msg.textContent = r.artist + ' — ' + r.title + ' is already in your library.';
              } else {
                msg.textContent = (res.status === 409 ? 'Already queued: ' : 'Queued: ')
                  + r.artist + ' — ' + r.title;
              }
              msg.style.display = 'block';
              input.value = '';
              if (res.ok && _onQueued) {
                _onQueued({
                  slug: res.data.slug, title: r.title, artist: r.artist,
                  year: r.year, coverUrl: r.coverUrl, releaseType: r.releaseType,
                  albumId: res.data.albumId,
                });
              }
            } else {
              msg.textContent = 'Failed to queue. Please try again.';
              msg.style.display = 'block';
            }
          })
          .catch(function () {
            spinner.classList.remove('active');
            input.disabled = false;
            msg.textContent = 'Failed to queue. Please try again.';
            msg.style.display = 'block';
          });
      }

      window.showQueueAdd = function (onQueued) { openModal(onQueued); };
    })();
    </script>
  </body>
</html>
